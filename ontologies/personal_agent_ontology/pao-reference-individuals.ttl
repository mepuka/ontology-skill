@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pao: <https://purl.org/pao/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

pao:UserPreference a owl:NamedIndividual ;
    rdfs:label "user preference"@en ;
    skos:definition "A claim type indicating the claim records a user preference."@en .

pao:reference-individuals a owl:Ontology ;
    dcterms:created "2026-02-19" ;
    dcterms:creator "ontology-architect skill" ;
    dcterms:description "Named individuals for status values, agent roles, and classifiers."@en ;
    dcterms:license <https://spdx.org/licenses/MIT> ;
    dcterms:title "Personal Agent Ontology — Reference Individuals"@en ;
    owl:versionIRI <https://purl.org/pao/reference-individuals/0.2.0> ;
    owl:versionInfo "0.2.0" .

pao:Active a owl:NamedIndividual,
        pao:SessionStatus ;
    rdfs:label "active"@en ;
    skos:definition "Status value: an entity is currently active."@en .

pao:AgentRole owl:equivalentClass [ owl:oneOf ( pao:AssistantRole pao:UserRole ) ] .

pao:Archived a owl:NamedIndividual,
        pao:ItemFate ;
    rdfs:label "archived"@en ;
    skos:definition "Item fate: moved to long-term storage."@en .

pao:AssistantRole a owl:NamedIndividual,
        pao:AgentRole ;
    rdfs:label "assistant role"@en ;
    skos:definition "The role of the AI assistant in a conversation."@en .

pao:Blocked a owl:NamedIndividual,
        pao:TaskStatus ;
    rdfs:label "blocked"@en ;
    skos:definition "Status value: a task cannot proceed because of unresolved dependencies."@en .

pao:Completed a owl:NamedIndividual,
        pao:TaskStatus ;
    rdfs:label "completed"@en ;
    skos:definition "Status value: a task or process has finished successfully."@en .

pao:ComplianceStatus owl:equivalentClass [ owl:oneOf ( pao:Compliant pao:NonCompliant ) ] .

pao:Compliant a owl:NamedIndividual,
        pao:ComplianceStatus ;
    rdfs:label "compliant"@en ;
    skos:definition "Compliance status: a tool invocation followed all applicable policies."@en .

pao:Confidential a owl:NamedIndividual,
        pao:SensitivityLevel ;
    rdfs:label "confidential"@en ;
    skos:definition "Sensitivity level: restricted personal data."@en .

pao:Dropped a owl:NamedIndividual,
        pao:ItemFate ;
    rdfs:label "dropped"@en ;
    skos:definition "Item fate: excluded from summary."@en .

pao:Ended a owl:NamedIndividual,
        pao:SessionStatus ;
    rdfs:label "ended"@en ;
    skos:definition "Status value: a session has ended normally."@en .

pao:InProgress a owl:NamedIndividual,
        pao:TaskStatus ;
    rdfs:label "in progress"@en ;
    skos:definition "Status value: a task is currently being worked on."@en .

pao:Internal a owl:NamedIndividual,
        pao:SensitivityLevel ;
    rdfs:label "internal"@en ;
    skos:definition "Sensitivity level: organization-internal data."@en .

pao:Interrupted a owl:NamedIndividual,
        pao:SessionStatus ;
    rdfs:label "interrupted"@en ;
    skos:definition "Status value: a session ended abnormally."@en .

pao:NonCompliant a owl:NamedIndividual,
        pao:ComplianceStatus ;
    rdfs:label "non compliant"@en ;
    skos:definition "Compliance status: a tool invocation violated one or more policies."@en .

pao:Pending a owl:NamedIndividual,
        pao:TaskStatus ;
    rdfs:label "pending"@en ;
    skos:definition "Status value: a task has not yet started."@en .

pao:Preserved a owl:NamedIndividual,
        pao:ItemFate ;
    rdfs:label "preserved"@en ;
    skos:definition "Item fate: content incorporated into summary."@en .

pao:Public a owl:NamedIndividual,
        pao:SensitivityLevel ;
    rdfs:label "public"@en ;
    skos:definition "Sensitivity level: unrestricted data."@en .

pao:Restricted a owl:NamedIndividual,
        pao:SensitivityLevel ;
    rdfs:label "restricted"@en ;
    skos:definition "Sensitivity level: highly sensitive data requiring special controls."@en .

pao:Summarized a owl:NamedIndividual,
        pao:ItemFate ;
    rdfs:label "summarized"@en ;
    skos:definition "Item fate: partially represented in summary."@en .

pao:UserRole a owl:NamedIndividual,
        pao:AgentRole ;
    rdfs:label "user role"@en ;
    skos:definition "The role of the human user in a conversation."@en .

pao:SessionStatus owl:equivalentClass [ owl:oneOf ( pao:Active pao:Ended pao:Interrupted ) ] .

pao:ItemFate owl:equivalentClass [ owl:oneOf ( pao:Preserved pao:Dropped pao:Summarized pao:Archived ) ] .

pao:SensitivityLevel owl:equivalentClass [ owl:oneOf ( pao:Public pao:Internal pao:Confidential pao:Restricted ) ] .

pao:TaskStatus owl:equivalentClass [ owl:oneOf ( pao:Pending pao:InProgress pao:Completed pao:Blocked ) ] .

[] a owl:AllDifferent ;
    owl:distinctMembers ( pao:AssistantRole pao:UserRole ) .

[] a owl:AllDifferent ;
    owl:distinctMembers ( pao:Pending pao:InProgress pao:Completed pao:Blocked ) .

[] a owl:AllDifferent ;
    owl:distinctMembers ( pao:Active pao:Ended pao:Interrupted ) .

[] a owl:AllDifferent ;
    owl:distinctMembers ( pao:Public pao:Internal pao:Confidential pao:Restricted ) .

[] a owl:AllDifferent ;
    owl:distinctMembers ( pao:Preserved pao:Dropped pao:Summarized pao:Archived ) .

[] a owl:AllDifferent ;
    owl:distinctMembers ( pao:Compliant pao:NonCompliant ) .
