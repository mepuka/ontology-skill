@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix pao: <https://purl.org/pao/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

pao:AIAgentShape a sh:NodeShape ;
    sh:property [ sh:class pao:ExternalService ;
            sh:path pao:hasExternalService ],
        [ sh:class pao:PermissionMode ;
            sh:maxCount 1 ;
            sh:path pao:operatesInMode ],
        [ sh:class pao:Persona ;
            sh:maxCount 1 ;
            sh:path pao:hasPersona ],
        [ sh:class pao:ToolDefinition ;
            sh:minCount 1 ;
            sh:path pao:hasAvailableTool ],
        [ sh:class pao:Hook ;
            sh:path pao:hasHook ],
        [ sh:class pao:Integration ;
            sh:path pao:hasIntegration ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:hasAgentId ] ;
    sh:targetClass pao:AIAgent .

pao:ActionShape a sh:NodeShape ;
    sh:property [ sh:class pao:Agent ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:performedBy ] ;
    sh:targetClass pao:Action .

pao:AuditEntryShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:path pao:hasDecisionReason ],
        [ sh:class pao:ToolInvocation ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:auditForInvocation ],
        [ sh:class pao:AuthorizationDecision ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:recordsDecision ],
        [ sh:class pao:AuditLog ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:writtenToAuditLog ] ;
    sh:targetClass pao:AuditEntry .

pao:CheckpointShape a sh:NodeShape ;
    sh:property [ sh:class pao:CheckpointDecision ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:checkpointDecision ],
        [ sh:class pao:Task ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:checkpointForTask ] ;
    sh:targetClass pao:Checkpoint .

pao:ClaimShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:hasContent ],
        [ sh:class pao:Agent ;
            sh:minCount 1 ;
            sh:path pao:aboutAgent ],
        [ sh:datatype xsd:decimal ;
            sh:maxCount 1 ;
            sh:maxInclusive 1.0 ;
            sh:minCount 0 ;
            sh:minInclusive 0.0 ;
            sh:path pao:hasConfidence ],
        [ sh:class pao:ClaimType ;
            sh:maxCount 1 ;
            sh:minCount 0 ;
            sh:path pao:claimType ],
        [ sh:class pao:MemoryTier ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:storedIn ] ;
    sh:targetClass pao:Claim .

pao:ClarificationRequestShape a sh:NodeShape ;
    sh:property [ sh:class pao:Turn ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:clarifiesTurn ] ;
    sh:targetClass pao:ClarificationRequest .

pao:CommunicationChannelShape a sh:NodeShape ;
    sh:property [ sh:class pao:ChannelType ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:hasChannelType ] ;
    sh:targetClass pao:CommunicationChannel .

pao:CompactionDispositionShape a sh:NodeShape ;
    sh:property [ sh:class pao:ItemFate ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:hasItemFate ],
        [ sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:dispositionOf ] ;
    sh:targetClass pao:CompactionDisposition .

pao:CompactionEventShape a sh:NodeShape ;
    sh:property [ sh:class pao:MemoryItem ;
            sh:minCount 1 ;
            sh:path pao:producedSummary ],
        [ sh:class pao:Conversation ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:inConversation ],
        [ sh:minCount 1 ;
            sh:path pao:compactedItem ],
        [ sh:class pao:ContextWindow ;
            sh:maxCount 1 ;
            sh:path pao:compactedContextOf ] ;
    sh:targetClass pao:CompactionEvent .

pao:ConsentRecordShape a sh:NodeShape ;
    sh:property [ sh:class pao:Agent ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:consentSubject ] ;
    sh:targetClass pao:ConsentRecord .

pao:ContentBlockShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:nonNegativeInteger ;
            sh:maxCount 1 ;
            sh:path pao:blockSequenceIndex ],
        [ sh:class pao:ContentBlockType ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:hasContentBlockType ] ;
    sh:targetClass pao:ContentBlock .

pao:ContextWindowShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:nonNegativeInteger ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:hasTokensUsed ],
        [ sh:datatype xsd:nonNegativeInteger ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:hasTokenCapacity ] ;
    sh:sparql [ sh:message "hasTokensUsed must not exceed hasTokenCapacity" ;
            sh:select """PREFIX pao: <https://purl.org/pao/>
SELECT $this WHERE {
  $this pao:hasTokensUsed ?used .
  $this pao:hasTokenCapacity ?cap .
  FILTER(?used > ?cap)
}""" ] ;
    sh:targetClass pao:ContextWindow .

pao:ConversationShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:hasConversationId ],
        [ sh:class pao:Agent ;
            sh:minCount 1 ;
            sh:path pao:hasParticipant ] ;
    sh:targetClass pao:Conversation .

pao:DialogActShape a sh:NodeShape ;
    sh:property [ sh:class pao:CommunicativeFunction ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:hasCommunicativeFunction ] ;
    sh:targetClass pao:DialogAct .

pao:EpisodeShape a sh:NodeShape ;
    sh:property [ sh:class skos:Concept ;
            sh:minCount 1 ;
            sh:path pao:hasTopic ],
        [ sh:class time:Interval ;
            sh:minCount 1 ;
            sh:path pao:hasTemporalExtent ] ;
    sh:targetClass pao:Episode .

pao:ErasureEventShape a sh:NodeShape ;
    sh:property [ sh:class pao:Agent ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:requestedBy ] ;
    sh:targetClass pao:ErasureEvent .

pao:ErrorRecoveryEventShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:nonNegativeInteger ;
            sh:maxCount 1 ;
            sh:path pao:hasAttemptCount ],
        [ sh:class pao:ToolInvocation ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:recoveringFrom ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:path pao:hasRecoveryOutcome ] ;
    sh:targetClass pao:ErrorRecoveryEvent .

pao:EventShape a sh:NodeShape ;
    sh:property [ sh:minCount 1 ;
            sh:path pao:hasTemporalExtent ] ;
    sh:targetClass pao:Event .

pao:ExternalServiceShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:hasServiceTransport ],
        [ sh:class pao:ServiceCapability ;
            sh:minCount 1 ;
            sh:path pao:exposesCapability ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:hasServiceIdentifier ] ;
    sh:targetClass pao:ExternalService .

pao:GoalShape a sh:NodeShape ;
    sh:property [ sh:class pao:Agent ;
            sh:minCount 1 ;
            sh:path pao:pursuedBy ],
        [ sh:class pao:TaskStatus ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:hasStatus ] ;
    sh:targetClass pao:Goal .

pao:GroundingActShape a sh:NodeShape ;
    sh:property [ sh:class pao:CommonGround ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:contributesToCommonGround ] ;
    sh:targetClass pao:GroundingAct .

pao:HookExecutionShape a sh:NodeShape ;
    sh:property [ sh:class pao:ToolInvocation ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:interceptsInvocation ] ;
    sh:targetClass pao:HookExecution .

pao:IntegrationShape a sh:NodeShape ;
    sh:property [ sh:class pao:IntegrationStatus ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:hasIntegrationStatus ],
        [ sh:datatype xsd:anyURI ;
            sh:maxCount 1 ;
            sh:path pao:hasEndpoint ],
        [ sh:class pao:ToolDefinition ;
            sh:minCount 1 ;
            sh:path pao:providesTool ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:hasServiceName ] ;
    sh:targetClass pao:Integration .

pao:IntentionShape a sh:NodeShape ;
    sh:property [ sh:class pao:Agent ;
            sh:minCount 1 ;
            sh:path pao:intendedBy ],
        [ sh:class pao:Goal ;
            sh:minCount 1 ;
            sh:path pao:derivedFromGoal ] ;
    sh:targetClass pao:Intention .

pao:MemoryBlockShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:minCount 1 ;
            sh:path pao:hasBlockKey ],
        [ sh:datatype xsd:string ;
            sh:minCount 1 ;
            sh:path pao:hasBlockValue ] ;
    sh:targetClass pao:MemoryBlock .

pao:MemoryItemShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:dateTime ;
            sh:maxCount 1 ;
            sh:path pao:hasLastAccessTime ],
        [ sh:class pao:MemoryTier ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:storedIn ],
        [ sh:class pao:Agent ;
            sh:minCount 1 ;
            sh:path prov:wasAttributedTo ],
        [ sh:minCount 1 ;
            sh:path prov:wasGeneratedBy ],
        [ sh:class pao:SensitivityLevel ;
            sh:maxCount 1 ;
            sh:minCount 0 ;
            sh:path pao:hasSensitivityLevel ] ;
    sh:targetClass pao:MemoryItem .

pao:MemoryOperationShape a sh:NodeShape ;
    sh:property [ sh:class pao:MemoryItem ;
            sh:minCount 1 ;
            sh:path pao:operatesOn ] ;
    sh:targetClass pao:MemoryOperation .

pao:MemoryWriteConflictShape a sh:NodeShape ;
    sh:property [ sh:class pao:SharedMemoryArtifact ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:conflictOnArtifact ],
        [ sh:class pao:Agent ;
            sh:minCount 2 ;
            sh:path pao:writesByAgent ] ;
    sh:targetClass pao:MemoryWriteConflict .

pao:MessageShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:hasContent ],
        [ sh:class pao:CommunicationChannel ;
            sh:maxCount 1 ;
            sh:path pao:sentViaChannel ] ;
    sh:targetClass pao:Message .

pao:ObservationShape a sh:NodeShape ;
    sh:property [ sh:class pao:Session ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:inSession ] ;
    sh:targetClass pao:Observation .

pao:OrganizationShape a sh:NodeShape ;
    sh:property [ sh:class pao:Agent ;
            sh:minCount 1 ;
            sh:path pao:hasMember ] ;
    sh:targetClass pao:Organization .

pao:PermissionPolicyShape a sh:NodeShape ;
    sh:property [ sh:class pao:Agent ;
            sh:minCount 1 ;
            sh:path pao:appliesTo ],
        [ sh:class odrl:Permission ;
            sh:minCount 1 ;
            sh:path pao:grantsPermission ],
        [ sh:class pao:ToolDefinition ;
            sh:minCount 1 ;
            sh:path pao:restrictsToolUse ] ;
    sh:targetClass pao:PermissionPolicy .

pao:PersonaShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:hasContent ] ;
    sh:targetClass pao:Persona .

pao:PlanShape a sh:NodeShape ;
    sh:property [ sh:class pao:Goal ;
            sh:minCount 1 ;
            sh:path pao:achievesGoal ] ;
    sh:targetClass pao:Plan .

pao:RetentionPolicyShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:nonNegativeInteger ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:retentionPeriodDays ] ;
    sh:targetClass pao:RetentionPolicy .

pao:SafetyConstraintShape a sh:NodeShape ;
    sh:property [ sh:class pao:Agent ;
            sh:minCount 1 ;
            sh:path pao:appliesTo ] ;
    sh:targetClass pao:SafetyConstraint .

pao:ServiceConnectionShape a sh:NodeShape ;
    sh:property [ sh:class pao:ConnectionStatus ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:hasConnectionStatus ],
        [ sh:class pao:ExternalService ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:connectsToService ] ;
    sh:targetClass pao:ServiceConnection .

pao:SessionShape a sh:NodeShape ;
    sh:property [ sh:class pao:Conversation ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:partOfConversation ],
        [ sh:minCount 1 ;
            sh:path pao:hasTemporalExtent ],
        [ sh:class pao:ContextWindow ;
            sh:maxCount 1 ;
            sh:path pao:hasContextWindow ],
        [ sh:class pao:Agent ;
            sh:minCount 1 ;
            sh:path pao:hasParticipant ],
        [ sh:class pao:SessionStatus ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:hasStatus ],
        [ sh:class pao:CommunicationChannel ;
            sh:maxCount 1 ;
            sh:path pao:viaChannel ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:hasSessionId ] ;
    sh:targetClass pao:Session .

pao:SharedMemoryArtifactShape a sh:NodeShape ;
    sh:property [ sh:class pao:Agent ;
            sh:minCount 2 ;
            sh:path pao:sharedAcrossAgents ] ;
    sh:targetClass pao:SharedMemoryArtifact .

pao:StatusTransitionShape a sh:NodeShape ;
    sh:property [ sh:class pao:Status ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:fromStatus ],
        [ sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:transitionSubject ],
        [ sh:class pao:Status ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:toStatus ] ;
    sh:targetClass pao:StatusTransition .

pao:SubAgentShape a sh:NodeShape ;
    sh:property [ sh:class pao:Agent ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:spawnedBy ],
        [ sh:class pao:Task ;
            sh:minCount 1 ;
            sh:path pao:delegatedTask ] ;
    sh:targetClass pao:SubAgent .

pao:TaskShape a sh:NodeShape ;
    sh:property [ sh:class pao:TaskStatus ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:hasStatus ],
        [ sh:class pao:Plan ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:partOfPlan ] ;
    sh:targetClass pao:Task .

pao:ToolInvocationGroupShape a sh:NodeShape ;
    sh:property [ sh:class pao:Turn ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:groupedInTurn ] ;
    sh:targetClass pao:ToolInvocationGroup .

pao:ToolInvocationShape a sh:NodeShape ;
    sh:property [ sh:class pao:ToolDefinition ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:invokesTool ],
        [ sh:class pao:ToolResult ;
            sh:maxCount 1 ;
            sh:path pao:producedToolResult ],
        [ sh:class pao:PermissionPolicy ;
            sh:maxCount 1 ;
            sh:path pao:governedByPolicy ],
        [ sh:path pao:hasOutput ],
        [ sh:class pao:Agent ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:invokedBy ],
        [ sh:class pao:ComplianceStatus ;
            sh:maxCount 1 ;
            sh:path pao:hasComplianceStatus ],
        [ sh:path pao:hasInput ],
        [ sh:class pao:Session ;
            sh:maxCount 1 ;
            sh:path pao:inSession ] ;
    sh:targetClass pao:ToolInvocation .

pao:TurnShape a sh:NodeShape ;
    sh:property [ sh:class pao:Session ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:partOfSession ],
        [ sh:class pao:Conversation ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:partOfConversation ],
        [ sh:class pao:Agent ;
            sh:minCount 1 ;
            sh:path pao:hasParticipant ],
        [ sh:datatype xsd:nonNegativeInteger ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:hasTurnIndex ] ;
    sh:targetClass pao:Turn .
