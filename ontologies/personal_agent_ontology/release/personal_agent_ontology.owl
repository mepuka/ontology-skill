  <rdf:Description rdf:about="https://purl.org/pao/Encoding">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">encoding</rdfs:label>
    <obo:IAO_0000115 xml:lang="en">A memory operation that writes new information into a memory tier.</obo:IAO_0000115>
    <rdfs:subClassOf rdf:resource="https://purl.org/pao/MemoryOperation"/>
    <skos:definition xml:lang="en">A memory operation that writes new information into a memory tier.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/pao/blockedBy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">blocked by</rdfs:label>
    <obo:IAO_0000115 xml:lang="en">Links a task to another task that must complete before it can proceed.</obo:IAO_0000115>
    <rdfs:domain rdf:resource="https://purl.org/pao/Task"/>
    <rdfs:range rdf:resource="https://purl.org/pao/Task"/>
    <owl:inverseOf rdf:resource="https://purl.org/pao/blocks"/>
    <skos:definition xml:lang="en">Links a task to another task that must complete before it can proceed.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/pao/hasConfidence">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label xml:lang="en">has confidence</rdfs:label>
    <obo:IAO_0000115 xml:lang="en">The confidence level of a claim, between 0.0 and 1.0.</obo:IAO_0000115>
    <rdfs:domain rdf:resource="https://purl.org/pao/Claim"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    <skos:definition xml:lang="en">The confidence level of a claim, between 0.0 and 1.0.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/pao/producedSummary">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">produced summary</rdfs:label>
    <obo:IAO_0000115 xml:lang="en">Links a compaction event to the summary it generated.</obo:IAO_0000115>
    <rdfs:domain rdf:resource="https://purl.org/pao/CompactionEvent"/>
    <rdfs:range rdf:resource="https://purl.org/pao/MemoryItem"/>
    <skos:definition xml:lang="en">Links a compaction event to the summary it generated.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/pao/">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <dcterms:created>2026-02-19</dcterms:created>
    <dcterms:creator>ontology-architect skill</dcterms:creator>
    <dcterms:description xml:lang="en">An OWL 2 DL ontology modeling AI agent architecture including conversations, memory systems, goals, plans, and governance.</dcterms:description>
    <dcterms:license rdf:resource="https://spdx.org/licenses/MIT"/>
    <dcterms:rights>MIT License</dcterms:rights>
    <dcterms:title xml:lang="en">Personal Agent Ontology</dcterms:title>
    <owl:imports rdf:resource="https://purl.org/pao/bfo-declarations"/>
    <owl:imports rdf:resource="https://purl.org/pao/foaf-declarations"/>
    <owl:imports rdf:resource="https://purl.org/pao/odrl-declarations"/>
    <owl:imports rdf:resource="https://purl.org/pao/prov-declarations"/>
    <owl:imports rdf:resource="https://purl.org/pao/reference-individuals"/>
    <owl:imports rdf:resource="https://purl.org/pao/time-declarations"/>
    <owl:versionIRI rdf:resource="https://purl.org/pao/0.3.0"/>
    <owl:versionInfo>0.3.0</owl:versionInfo>
    <prov:generatedAtTime rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-18T00:00:00+00:00</prov:generatedAtTime>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n743433ab138e4b70be2883382cc8aa9ab14">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://purl.org/pao/hasTopic"/>
    <owl:someValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/pao/consentSubject">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">consent subject</rdfs:label>
    <obo:IAO_0000115 xml:lang="en">Links a consent record to the data subject agent.</obo:IAO_0000115>
    <rdfs:domain rdf:resource="https://purl.org/pao/ConsentRecord"/>
    <rdfs:range rdf:resource="https://purl.org/pao/Agent"/>
    <skos:definition xml:lang="en">Links a consent record to the data subject agent.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/pao/recordsEvent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">records event</rdfs:label>
    <obo:IAO_0000115 xml:lang="en">Links an episode to an event it records.</obo:IAO_0000115>
    <rdfs:domain rdf:resource="https://purl.org/pao/Episode"/>
    <rdfs:range rdf:resource="https://purl.org/pao/Event"/>
    <skos:definition xml:lang="en">Links an episode to an event it records.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/pao/hasBlockValue">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label xml:lang="en">has block value</rdfs:label>
    <obo:IAO_0000115 xml:lang="en">A value in a memory block's key-value store.</obo:IAO_0000115>
    <rdfs:domain rdf:resource="https://purl.org/pao/MemoryBlock"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <skos:definition xml:lang="en">A value in a memory block's key-value store.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/pao/hasLastAccessTime">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label xml:lang="en">has last access time</rdfs:label>
    <obo:IAO_0000115 xml:lang="en">The timestamp of the most recent access to this memory item.</obo:IAO_0000115>
    <rdfs:domain rdf:resource="https://purl.org/pao/MemoryItem"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
    <skos:definition xml:lang="en">The timestamp of the most recent access to this memory item.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/pao/Organization">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">organization</rdfs:label>
    <obo:IAO_0000115 xml:lang="en">An agent that is a formal body or group of people.</obo:IAO_0000115>
    <rdfs:subClassOf rdf:nodeID="n743433ab138e4b70be2883382cc8aa9ab18"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
    <rdfs:subClassOf rdf:resource="https://purl.org/pao/Agent"/>
    <skos:definition xml:lang="en">An agent that is a formal body or group of people.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n743433ab138e4b70be2883382cc8aa9ab90">
    <rdf:first rdf:resource="https://purl.org/pao/PermissionPolicy"/>
    <rdf:rest rdf:nodeID="n743433ab138e4b70be2883382cc8aa9ab91"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/pao/ConsentRecord">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">consent record</rdfs:label>
    <obo:IAO_0000115 xml:lang="en">A GDC that records a data subject's consent for a specific purpose.</obo:IAO_0000115>
    <rdfs:subClassOf rdf:nodeID="n743433ab138e4b70be2883382cc8aa9ab24"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Entity"/>
    <skos:definition xml:lang="en">A GDC that records a data subject's consent for a specific purpose.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/pao/governedByRetention">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">governed by retention</rdfs:label>
    <obo:IAO_0000115 xml:lang="en">Links a memory item to the retention policy that governs it.</obo:IAO_0000115>
    <rdfs:domain rdf:resource="https://purl.org/pao/MemoryItem"/>
    <rdfs:range rdf:resource="https://purl.org/pao/RetentionPolicy"/>
    <skos:definition xml:lang="en">Links a memory item to the retention policy that governs it.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/pao/grantsPermission">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">grants permission</rdfs:label>
    <obo:IAO_0000115 xml:lang="en">Links a permission policy to the specific permission it grants.</obo:IAO_0000115>
    <rdfs:domain rdf:resource="https://purl.org/pao/PermissionPolicy"/>
    <rdfs:range rdf:resource="http://www.w3.org/ns/odrl/2/Permission"/>
    <skos:definition xml:lang="en">Links a permission policy to the specific permission it grants.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/pao/Observation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">observation</rdfs:label>
    <obo:IAO_0000115 xml:lang="en">An event in which an agent receives environmental feedback.</obo:IAO_0000115>
    <rdfs:subClassOf rdf:nodeID="n743433ab138e4b70be2883382cc8aa9ab1"/>
    <rdfs:subClassOf rdf:resource="https://purl.org/pao/Event"/>
    <skos:definition xml:lang="en">An event in which an agent receives environmental feedback.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/pao/Intention">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">intention</rdfs:label>
    <obo:IAO_0000115 xml:lang="en">A GDC representing an agent's commitment to execute a plan (BDI model).</obo:IAO_0000115>
    <rdfs:subClassOf rdf:nodeID="n743433ab138e4b70be2883382cc8aa9ab16"/>
    <rdfs:subClassOf rdf:nodeID="n743433ab138e4b70be2883382cc8aa9ab17"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Entity"/>
    <skos:definition xml:lang="en">A GDC representing an agent's commitment to execute a plan (BDI model).</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n743433ab138e4b70be2883382cc8aa9ab26">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://purl.org/pao/hasPersona"/>
    <owl:someValuesFrom rdf:resource="https://purl.org/pao/Persona"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/pao/EpisodicMemory">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">episodic memory</rdfs:label>
    <obo:IAO_0000115 xml:lang="en">A memory tier that stores time-situated experiences and interaction histories.</obo:IAO_0000115>
    <rdfs:subClassOf rdf:resource="https://purl.org/pao/MemoryTier"/>
    <skos:definition xml:lang="en">A memory tier that stores time-situated experiences and interaction histories.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/pao/Episode">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">episode</rdfs:label>
    <obo:IAO_0000115 xml:lang="en">A memory item that records a temporally bounded cluster of related events.</obo:IAO_0000115>
    <rdfs:subClassOf rdf:nodeID="n743433ab138e4b70be2883382cc8aa9ab12"/>
    <rdfs:subClassOf rdf:nodeID="n743433ab138e4b70be2883382cc8aa9ab13"/>
    <rdfs:subClassOf rdf:nodeID="n743433ab138e4b70be2883382cc8aa9ab14"/>
    <rdfs:subClassOf rdf:nodeID="n743433ab138e4b70be2883382cc8aa9ab15"/>
    <rdfs:subClassOf rdf:resource="https://purl.org/pao/MemoryItem"/>
    <skos:definition xml:lang="en">A memory item that records a temporally bounded cluster of related events.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n743433ab138e4b70be2883382cc8aa9ab29">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://purl.org/pao/hasItemFate"/>
    <owl:someValuesFrom rdf:resource="https://purl.org/pao/ItemFate"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/pao/hasPersona">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">has persona</rdfs:label>
    <obo:IAO_0000115 xml:lang="en">Links an AI agent to its configured persona.</obo:IAO_0000115>
    <rdfs:domain rdf:resource="https://purl.org/pao/AIAgent"/>
    <rdfs:range rdf:resource="https://purl.org/pao/Persona"/>
    <skos:definition xml:lang="en">Links an AI agent to its configured persona.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/pao/hasAgentId">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label xml:lang="en">has agent id</rdfs:label>
