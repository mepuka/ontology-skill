  <rdf:Description rdf:about="https://purl.org/pao/producedToolResult">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">produced tool result</rdfs:label>
    <obo:IAO_0000115 xml:lang="en">Links a tool invocation to the result artifact it produced.</obo:IAO_0000115>
    <rdfs:domain rdf:resource="https://purl.org/pao/ToolInvocation"/>
    <rdfs:range rdf:resource="https://purl.org/pao/ToolResult"/>
    <skos:definition xml:lang="en">Links a tool invocation to the result artifact it produced.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/pao/invokedOnDeployment">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">invoked on deployment</rdfs:label>
    <obo:IAO_0000115 xml:lang="en">Links a model invocation to the deployment it was executed on.</obo:IAO_0000115>
    <rdfs:domain rdf:resource="https://purl.org/pao/ModelInvocation"/>
    <rdfs:range rdf:resource="https://purl.org/pao/ModelDeployment"/>
    <skos:definition xml:lang="en">Links a model invocation to the deployment it was executed on.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/pao/Desire">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">desire</rdfs:label>
    <obo:IAO_0000115 xml:lang="en">A generically dependent continuant that represents a desired state or outcome an agent works toward.</obo:IAO_0000115>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Entity"/>
    <skos:definition xml:lang="en">A generically dependent continuant that represents a desired state or outcome an agent works toward.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/pao/SharedMemoryArtifact">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">shared memory artifact</rdfs:label>
    <obo:IAO_0000115 xml:lang="en">A prov:Entity that represents a memory artifact accessible to multiple agents for shared read/write.</obo:IAO_0000115>
    <rdfs:subClassOf rdf:nodeID="nbf40f2f07f184d6f8ac886f2ec454632b37"/>
    <rdfs:subClassOf rdf:nodeID="nbf40f2f07f184d6f8ac886f2ec454632b38"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Entity"/>
    <skos:definition xml:lang="en">A prov:Entity that represents a memory artifact accessible to multiple agents for shared read/write.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/pao/">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <dcterms:created>2026-02-20</dcterms:created>
    <dcterms:creator>ontology-architect skill</dcterms:creator>
    <dcterms:description xml:lang="en">An OWL 2 DL ontology modeling AI agent architecture including conversations, memory systems, goals, plans, and governance.</dcterms:description>
    <dcterms:license rdf:resource="https://spdx.org/licenses/MIT"/>
    <dcterms:rights>MIT License</dcterms:rights>
    <dcterms:title xml:lang="en">Personal Agent Ontology</dcterms:title>
    <owl:imports rdf:resource="https://purl.org/pao/bfo-declarations"/>
    <owl:imports rdf:resource="https://purl.org/pao/foaf-declarations"/>
    <owl:imports rdf:resource="https://purl.org/pao/odrl-declarations"/>
    <owl:imports rdf:resource="https://purl.org/pao/prov-declarations"/>
    <owl:imports rdf:resource="https://purl.org/pao/reference-individuals"/>
    <owl:imports rdf:resource="https://purl.org/pao/time-declarations"/>
    <owl:priorVersion rdf:resource="https://purl.org/pao/0.6.0"/>
    <owl:versionIRI rdf:resource="https://purl.org/pao/0.7.0"/>
    <owl:versionInfo>0.7.0</owl:versionInfo>
    <prov:generatedAtTime rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-18T00:00:00+00:00</prov:generatedAtTime>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/pao/Intention">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">intention</rdfs:label>
    <obo:IAO_0000115 xml:lang="en">A GDC representing an agent's commitment to execute a plan (BDI model).</obo:IAO_0000115>
    <rdfs:subClassOf rdf:nodeID="nbf40f2f07f184d6f8ac886f2ec454632b59"/>
    <rdfs:subClassOf rdf:nodeID="nbf40f2f07f184d6f8ac886f2ec454632b60"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Entity"/>
    <skos:definition xml:lang="en">A GDC representing an agent's commitment to execute a plan (BDI model).</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nbf40f2f07f184d6f8ac886f2ec454632b90">
    <rdf:first rdf:resource="https://purl.org/pao/EpisodicMemory"/>
