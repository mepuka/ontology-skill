  <rdf:Description rdf:about="https://purl.org/pao/belongsTo">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">belongs to</rdfs:label>
    <obo:IAO_0000115 xml:lang="en">Links an agent to the organization it belongs to.</obo:IAO_0000115>
    <rdfs:domain rdf:resource="https://purl.org/pao/Agent"/>
    <rdfs:range rdf:resource="https://purl.org/pao/Organization"/>
    <owl:inverseOf rdf:resource="https://purl.org/pao/hasMember"/>
    <skos:definition xml:lang="en">Links an agent to the organization it belongs to.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/pao/Status">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">status</rdfs:label>
    <obo:IAO_0000115 xml:lang="en">A class whose individuals represent the current state of an entity.</obo:IAO_0000115>
    <skos:definition xml:lang="en">A class whose individuals represent the current state of an entity.</skos:definition>
  </rdf:Description>
