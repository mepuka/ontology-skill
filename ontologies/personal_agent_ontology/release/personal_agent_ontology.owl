    <skos:definition xml:lang="en">A generically dependent continuant that specifies a model family with a name and version.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/pao/retentionPeriodDays">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
