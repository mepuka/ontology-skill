    <obo:IAO_0000115 xml:lang="en">The number of days a memory item should be retained.</obo:IAO_0000115>
    <rdfs:domain rdf:resource="https://purl.org/pao/RetentionPolicy"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
    <skos:definition xml:lang="en">The number of days a memory item should be retained.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nbf40f2f07f184d6f8ac886f2ec454632b11">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
