  <rdf:Description rdf:about="https://purl.org/pao/hasSessionId">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label xml:lang="en">has session id</rdfs:label>
    <obo:IAO_0000115 xml:lang="en">The unique string identifier for this session.</obo:IAO_0000115>
    <rdfs:domain rdf:resource="https://purl.org/pao/Session"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <skos:definition xml:lang="en">The unique string identifier for this session.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/pao/CommunicationChannel">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">communication channel</rdfs:label>
    <obo:IAO_0000115 xml:lang="en">A GDC that specifies a configured communication endpoint through which agent-user dialogue occurs.</obo:IAO_0000115>
    <rdfs:subClassOf rdf:nodeID="nbf40f2f07f184d6f8ac886f2ec454632b25"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Entity"/>
    <skos:definition xml:lang="en">A GDC that specifies a configured communication endpoint through which agent-user dialogue occurs.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/pao/modelInvocationForTurn">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">model invocation for turn</rdfs:label>
    <obo:IAO_0000115 xml:lang="en">Links a model invocation to the turn it produced output for.</obo:IAO_0000115>
    <rdfs:domain rdf:resource="https://purl.org/pao/ModelInvocation"/>
    <rdfs:range rdf:resource="https://purl.org/pao/Turn"/>
    <owl:inverseOf rdf:resource="https://purl.org/pao/producedByModelInvocation"/>
    <skos:definition xml:lang="en">Links a model invocation to the turn it produced output for.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/pao/RetentionPolicy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">retention policy</rdfs:label>
    <obo:IAO_0000115 xml:lang="en">A GDC specifying how long memory items should be retained before deletion.</obo:IAO_0000115>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Entity"/>
    <skos:definition xml:lang="en">A GDC specifying how long memory items should be retained before deletion.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/pao/Task">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">task</rdfs:label>
    <obo:IAO_0000115 xml:lang="en">A generically dependent continuant that is a concrete actionable work item within a plan with status and dependencies.</obo:IAO_0000115>
    <rdfs:subClassOf rdf:nodeID="nbf40f2f07f184d6f8ac886f2ec454632b96"/>
    <rdfs:subClassOf rdf:nodeID="nbf40f2f07f184d6f8ac886f2ec454632b97"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Entity"/>
    <skos:definition xml:lang="en">A generically dependent continuant that is a concrete actionable work item within a plan with status and dependencies.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/pao/Persona">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">persona</rdfs:label>
    <obo:IAO_0000115 xml:lang="en">A GDC that specifies an agent's configured identity behavior and system prompt.</obo:IAO_0000115>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Entity"/>
    <skos:definition xml:lang="en">A GDC that specifies an agent's configured identity behavior and system prompt.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/pao/SubAgent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">sub agent</rdfs:label>
    <obo:IAO_0000115 xml:lang="en">An AI agent that was spawned by another agent to perform delegated work.</obo:IAO_0000115>
    <rdfs:subClassOf rdf:nodeID="nbf40f2f07f184d6f8ac886f2ec454632b1"/>
    <rdfs:subClassOf rdf:nodeID="nbf40f2f07f184d6f8ac886f2ec454632b2"/>
    <rdfs:subClassOf rdf:resource="https://purl.org/pao/AIAgent"/>
    <skos:definition xml:lang="en">An AI agent that was spawned by another agent to perform delegated work.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/pao/ItemFate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">item fate</rdfs:label>
    <obo:IAO_0000115 xml:lang="en">A status class whose individuals classify what happened to an item during compaction.</obo:IAO_0000115>
    <rdfs:subClassOf rdf:resource="https://purl.org/pao/Status"/>
    <skos:definition xml:lang="en">A status class whose individuals classify what happened to an item during compaction.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/pao/hasServiceIdentifier">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label xml:lang="en">has service identifier</rdfs:label>
    <obo:IAO_0000115 xml:lang="en">A unique string identifier for an external service configuration.</obo:IAO_0000115>
    <rdfs:domain rdf:resource="https://purl.org/pao/ExternalService"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <skos:definition xml:lang="en">A unique string identifier for an external service configuration.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/pao/hasExternalService">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">has external service</rdfs:label>
    <obo:IAO_0000115 xml:lang="en">Links an agent to an external service it is configured to access.</obo:IAO_0000115>
    <rdfs:domain rdf:resource="https://purl.org/pao/Agent"/>
    <rdfs:range rdf:resource="https://purl.org/pao/ExternalService"/>
    <skos:definition xml:lang="en">Links an agent to an external service it is configured to access.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/pao/FoundationModel">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">foundation model</rdfs:label>
    <obo:IAO_0000115 xml:lang="en">A generically dependent continuant that specifies a model family with a name and version.</obo:IAO_0000115>
    <rdfs:subClassOf rdf:nodeID="nbf40f2f07f184d6f8ac886f2ec454632b52"/>
    <rdfs:subClassOf rdf:nodeID="nbf40f2f07f184d6f8ac886f2ec454632b53"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
