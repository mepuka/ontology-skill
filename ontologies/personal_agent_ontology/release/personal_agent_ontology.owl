    <!-- https://purl.org/pao/AIAgent -->

    <owl:Class rdf:about="https://purl.org/pao/AIAgent">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#SoftwareAgent"/>
        <rdfs:subClassOf rdf:resource="https://purl.org/pao/Agent"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/pao/hasAvailableTool"/>
                <owl:someValuesFrom rdf:resource="https://purl.org/pao/ToolDefinition"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://purl.org/pao/HumanUser"/>
        <obo:IAO_0000115 xml:lang="en">An agent that is a software system capable of autonomous decision-making and tool use.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">ai agent</rdfs:label>
        <skos:definition xml:lang="en">An agent that is a software system capable of autonomous decision-making and tool use.</skos:definition>
    </owl:Class>



    <!-- https://purl.org/pao/Action -->

    <owl:Class rdf:about="https://purl.org/pao/Action">
        <rdfs:subClassOf rdf:resource="https://purl.org/pao/Event"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/pao/performedBy"/>
                <owl:someValuesFrom rdf:resource="https://purl.org/pao/Agent"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115 xml:lang="en">An event that is intentionally caused by an agent to affect the environment or internal state.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">action</rdfs:label>
        <skos:definition xml:lang="en">An event that is intentionally caused by an agent to affect the environment or internal state.</skos:definition>
    </owl:Class>



    <!-- https://purl.org/pao/Agent -->

    <owl:Class rdf:about="https://purl.org/pao/Agent">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Agent"/>
        <obo:IAO_0000115 xml:lang="en">An entity that bears responsibility for activities and can act on behalf of itself or others.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">agent</rdfs:label>
        <skos:definition xml:lang="en">An entity that bears responsibility for activities and can act on behalf of itself or others.</skos:definition>
    </owl:Class>



    <!-- https://purl.org/pao/AgentRole -->

    <owl:Class rdf:about="https://purl.org/pao/AgentRole">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://purl.org/pao/AssistantRole"/>
                    <rdf:Description rdf:about="https://purl.org/pao/UserRole"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000023"/>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Role"/>
        <obo:IAO_0000115 xml:lang="en">A role that an agent plays in the context of a conversation or activity.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">agent role</rdfs:label>
        <skos:definition xml:lang="en">A role that an agent plays in the context of a conversation or activity.</skos:definition>
    </owl:Class>



    <!-- https://purl.org/pao/Claim -->

    <owl:Class rdf:about="https://purl.org/pao/Claim">
        <rdfs:subClassOf rdf:resource="https://purl.org/pao/MemoryItem"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/pao/aboutAgent"/>
                <owl:someValuesFrom rdf:resource="https://purl.org/pao/Agent"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/pao/storedIn"/>
                <owl:someValuesFrom rdf:resource="https://purl.org/pao/MemoryTier"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://purl.org/pao/Episode"/>
        <obo:IAO_0000115 xml:lang="en">A memory item that represents an agent-held proposition with associated confidence, evidence, and provenance metadata.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">claim</rdfs:label>
        <skos:definition xml:lang="en">A memory item that represents an agent-held proposition with associated confidence, evidence, and provenance metadata.</skos:definition>
    </owl:Class>



    <!-- https://purl.org/pao/CompactionEvent -->

    <owl:Class rdf:about="https://purl.org/pao/CompactionEvent">
        <rdfs:subClassOf rdf:resource="https://purl.org/pao/Event"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/pao/inConversation"/>
                <owl:someValuesFrom rdf:resource="https://purl.org/pao/Conversation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/pao/producedSummary"/>
                <owl:someValuesFrom rdf:resource="https://purl.org/pao/MemoryItem"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115 xml:lang="en">A process in which an agent&apos;s context window is compressed by summarizing prior turns.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">compaction event</rdfs:label>
        <skos:definition xml:lang="en">A process in which an agent&apos;s context window is compressed by summarizing prior turns.</skos:definition>
    </owl:Class>



    <!-- https://purl.org/pao/ComplianceStatus -->

    <owl:Class rdf:about="https://purl.org/pao/ComplianceStatus">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://purl.org/pao/Compliant"/>
                    <rdf:Description rdf:about="https://purl.org/pao/NonCompliant"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://purl.org/pao/Status"/>
        <obo:IAO_0000115 xml:lang="en">A status indicating whether a tool invocation complied with applicable permission policies.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">compliance status</rdfs:label>
        <skos:definition xml:lang="en">A status indicating whether a tool invocation complied with applicable permission policies.</skos:definition>
    </owl:Class>



    <!-- https://purl.org/pao/Consolidation -->

    <owl:Class rdf:about="https://purl.org/pao/Consolidation">
        <rdfs:subClassOf rdf:resource="https://purl.org/pao/MemoryOperation"/>
        <obo:IAO_0000115 xml:lang="en">A memory operation that transforms episodic memories into semantic memories.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">consolidation</rdfs:label>
        <skos:definition xml:lang="en">A memory operation that transforms episodic memories into semantic memories.</skos:definition>
    </owl:Class>



    <!-- https://purl.org/pao/Conversation -->

    <owl:Class rdf:about="https://purl.org/pao/Conversation">
        <rdfs:subClassOf rdf:resource="https://purl.org/pao/Event"/>
        <obo:IAO_0000115 xml:lang="en">A process consisting of a coherent thread of dialogue between participants that may span multiple sessions.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">conversation</rdfs:label>
        <skos:definition xml:lang="en">A process consisting of a coherent thread of dialogue between participants that may span multiple sessions.</skos:definition>
    </owl:Class>



    <!-- https://purl.org/pao/Encoding -->

    <owl:Class rdf:about="https://purl.org/pao/Encoding">
        <rdfs:subClassOf rdf:resource="https://purl.org/pao/MemoryOperation"/>
        <obo:IAO_0000115 xml:lang="en">A memory operation that writes new information into a memory tier.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">encoding</rdfs:label>
        <skos:definition xml:lang="en">A memory operation that writes new information into a memory tier.</skos:definition>
    </owl:Class>



    <!-- https://purl.org/pao/Episode -->

    <owl:Class rdf:about="https://purl.org/pao/Episode">
        <rdfs:subClassOf rdf:resource="https://purl.org/pao/MemoryItem"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/pao/hasTemporalExtent"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2006/time#Interval"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/pao/hasTopic"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/pao/storedIn"/>
                <owl:someValuesFrom rdf:resource="https://purl.org/pao/MemoryTier"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/pao/storedIn"/>
                <owl:allValuesFrom rdf:resource="https://purl.org/pao/EpisodicMemory"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115 xml:lang="en">A memory item that records a temporally bounded cluster of related events.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">episode</rdfs:label>
        <skos:definition xml:lang="en">A memory item that records a temporally bounded cluster of related events.</skos:definition>
    </owl:Class>



    <!-- https://purl.org/pao/EpisodicMemory -->

    <owl:Class rdf:about="https://purl.org/pao/EpisodicMemory">
        <rdfs:subClassOf rdf:resource="https://purl.org/pao/MemoryTier"/>
        <obo:IAO_0000115 xml:lang="en">A memory tier that stores time-situated experiences and interaction histories.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">episodic memory</rdfs:label>
        <skos:definition xml:lang="en">A memory tier that stores time-situated experiences and interaction histories.</skos:definition>
    </owl:Class>



    <!-- https://purl.org/pao/ErasureEvent -->

    <owl:Class rdf:about="https://purl.org/pao/ErasureEvent">
        <rdfs:subClassOf rdf:resource="https://purl.org/pao/Event"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/pao/requestedBy"/>
                <owl:someValuesFrom rdf:resource="https://purl.org/pao/Agent"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115 xml:lang="en">A process in which memory items are identified and deleted to comply with privacy requirements.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">erasure event</rdfs:label>
        <skos:definition xml:lang="en">A process in which memory items are identified and deleted to comply with privacy requirements.</skos:definition>
    </owl:Class>



    <!-- https://purl.org/pao/Event -->

    <owl:Class rdf:about="https://purl.org/pao/Event">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Activity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/pao/hasTemporalExtent"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2006/time#TemporalEntity"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115 xml:lang="en">A process that is an occurrence situated in time within the agent system.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">event</rdfs:label>
        <skos:definition xml:lang="en">A process that is an occurrence situated in time within the agent system.</skos:definition>
    </owl:Class>



    <!-- https://purl.org/pao/Forgetting -->

    <owl:Class rdf:about="https://purl.org/pao/Forgetting">
        <rdfs:subClassOf rdf:resource="https://purl.org/pao/MemoryOperation"/>
        <obo:IAO_0000115 xml:lang="en">A memory operation that removes or decays memory items from a memory tier.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">forgetting</rdfs:label>
        <skos:definition xml:lang="en">A memory operation that removes or decays memory items from a memory tier.</skos:definition>
    </owl:Class>



    <!-- https://purl.org/pao/Goal -->

    <owl:Class rdf:about="https://purl.org/pao/Goal">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Entity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/pao/hasStatus"/>
                <owl:someValuesFrom rdf:resource="https://purl.org/pao/TaskStatus"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/pao/pursuedBy"/>
                <owl:someValuesFrom rdf:resource="https://purl.org/pao/Agent"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115 xml:lang="en">A generically dependent continuant that specifies a desired state an agent works toward.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">goal</rdfs:label>
        <skos:definition xml:lang="en">A generically dependent continuant that specifies a desired state an agent works toward.</skos:definition>
    </owl:Class>



    <!-- https://purl.org/pao/HumanUser -->

    <owl:Class rdf:about="https://purl.org/pao/HumanUser">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Person"/>
        <rdfs:subClassOf rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
        <rdfs:subClassOf rdf:resource="https://purl.org/pao/Agent"/>
        <obo:IAO_0000115 xml:lang="en">An agent that is a human person who interacts with AI systems.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">human user</rdfs:label>
        <skos:definition xml:lang="en">An agent that is a human person who interacts with AI systems.</skos:definition>
    </owl:Class>



    <!-- https://purl.org/pao/MemoryItem -->

    <owl:Class rdf:about="https://purl.org/pao/MemoryItem">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Entity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/ns/prov#wasAttributedTo"/>
                <owl:someValuesFrom rdf:resource="https://purl.org/pao/Agent"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/ns/prov#wasGeneratedBy"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/ns/prov#Activity"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/pao/storedIn"/>
                <owl:someValuesFrom rdf:resource="https://purl.org/pao/MemoryTier"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/pao/storedIn"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://purl.org/pao/MemoryTier"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115 xml:lang="en">A generically dependent continuant that is an information artifact persisted in an agent&apos;s memory system.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">memory item</rdfs:label>
        <skos:definition xml:lang="en">A generically dependent continuant that is an information artifact persisted in an agent&apos;s memory system.</skos:definition>
    </owl:Class>



    <!-- https://purl.org/pao/MemoryOperation -->

    <owl:Class rdf:about="https://purl.org/pao/MemoryOperation">
        <rdfs:subClassOf rdf:resource="https://purl.org/pao/Event"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/pao/operatesOn"/>
                <owl:someValuesFrom rdf:resource="https://purl.org/pao/MemoryItem"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointUnionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="https://purl.org/pao/Consolidation"/>
            <rdf:Description rdf:about="https://purl.org/pao/Encoding"/>
            <rdf:Description rdf:about="https://purl.org/pao/Forgetting"/>
            <rdf:Description rdf:about="https://purl.org/pao/Retrieval"/>
        </owl:disjointUnionOf>
        <obo:IAO_0000115 xml:lang="en">A process that acts on memory items to encode, retrieve, consolidate, or remove them.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">memory operation</rdfs:label>
        <skos:definition xml:lang="en">A process that acts on memory items to encode, retrieve, consolidate, or remove them.</skos:definition>
    </owl:Class>



    <!-- https://purl.org/pao/MemoryTier -->

    <owl:Class rdf:about="https://purl.org/pao/MemoryTier">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Entity"/>
        <owl:disjointUnionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="https://purl.org/pao/EpisodicMemory"/>
            <rdf:Description rdf:about="https://purl.org/pao/ProceduralMemory"/>
            <rdf:Description rdf:about="https://purl.org/pao/SemanticMemory"/>
            <rdf:Description rdf:about="https://purl.org/pao/WorkingMemory"/>
        </owl:disjointUnionOf>
        <obo:IAO_0000115 xml:lang="en">A generically dependent continuant that defines a layer in the agent&apos;s memory architecture with specific storage and access characteristics.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">memory tier</rdfs:label>
        <skos:definition xml:lang="en">A generically dependent continuant that defines a layer in the agent&apos;s memory architecture with specific storage and access characteristics.</skos:definition>
    </owl:Class>



    <!-- https://purl.org/pao/Message -->

    <owl:Class rdf:about="https://purl.org/pao/Message">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Entity"/>
        <obo:IAO_0000115 xml:lang="en">A generically dependent continuant that is the textual or structured content of a conversational turn.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">message</rdfs:label>
        <skos:definition xml:lang="en">A generically dependent continuant that is the textual or structured content of a conversational turn.</skos:definition>
    </owl:Class>



    <!-- https://purl.org/pao/PermissionPolicy -->

    <owl:Class rdf:about="https://purl.org/pao/PermissionPolicy">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/odrl/2/Policy"/>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Entity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/pao/appliesTo"/>
                <owl:someValuesFrom rdf:resource="https://purl.org/pao/Agent"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/pao/grantsPermission"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/ns/odrl/2/Permission"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/pao/restrictsToolUse"/>
                <owl:someValuesFrom rdf:resource="https://purl.org/pao/ToolDefinition"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://purl.org/pao/SafetyConstraint"/>
        <obo:IAO_0000115 xml:lang="en">A generically dependent continuant that specifies rules governing what actions an agent is permitted or forbidden to perform.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">permission policy</rdfs:label>
        <skos:definition xml:lang="en">A generically dependent continuant that specifies rules governing what actions an agent is permitted or forbidden to perform.</skos:definition>
    </owl:Class>



    <!-- https://purl.org/pao/Plan -->

    <owl:Class rdf:about="https://purl.org/pao/Plan">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Plan"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/pao/achievesGoal"/>
                <owl:someValuesFrom rdf:resource="https://purl.org/pao/Goal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115 xml:lang="en">A generically dependent continuant that specifies an ordered sequence of intended actions to achieve a goal.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">plan</rdfs:label>
        <skos:definition xml:lang="en">A generically dependent continuant that specifies an ordered sequence of intended actions to achieve a goal.</skos:definition>
    </owl:Class>



    <!-- https://purl.org/pao/ProceduralMemory -->

    <owl:Class rdf:about="https://purl.org/pao/ProceduralMemory">
        <rdfs:subClassOf rdf:resource="https://purl.org/pao/MemoryTier"/>
        <obo:IAO_0000115 xml:lang="en">A memory tier that stores learned action policies, skills, and behavioral patterns.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">procedural memory</rdfs:label>
        <skos:definition xml:lang="en">A memory tier that stores learned action policies, skills, and behavioral patterns.</skos:definition>
    </owl:Class>



    <!-- https://purl.org/pao/Retrieval -->

    <owl:Class rdf:about="https://purl.org/pao/Retrieval">
        <rdfs:subClassOf rdf:resource="https://purl.org/pao/MemoryOperation"/>
        <obo:IAO_0000115 xml:lang="en">A memory operation that reads information from a memory tier.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">retrieval</rdfs:label>
        <skos:definition xml:lang="en">A memory operation that reads information from a memory tier.</skos:definition>
    </owl:Class>



    <!-- https://purl.org/pao/SafetyConstraint -->

    <owl:Class rdf:about="https://purl.org/pao/SafetyConstraint">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Entity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/pao/appliesTo"/>
                <owl:someValuesFrom rdf:resource="https://purl.org/pao/Agent"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115 xml:lang="en">A generically dependent continuant that specifies a non-negotiable behavioral limit on an agent.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">safety constraint</rdfs:label>
        <skos:definition xml:lang="en">A generically dependent continuant that specifies a non-negotiable behavioral limit on an agent.</skos:definition>
    </owl:Class>



    <!-- https://purl.org/pao/SemanticMemory -->

    <owl:Class rdf:about="https://purl.org/pao/SemanticMemory">
        <rdfs:subClassOf rdf:resource="https://purl.org/pao/MemoryTier"/>
        <obo:IAO_0000115 xml:lang="en">A memory tier that stores generalized facts, knowledge, and beliefs extracted from experience.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">semantic memory</rdfs:label>
        <skos:definition xml:lang="en">A memory tier that stores generalized facts, knowledge, and beliefs extracted from experience.</skos:definition>
    </owl:Class>



    <!-- https://purl.org/pao/Session -->

    <owl:Class rdf:about="https://purl.org/pao/Session">
        <rdfs:subClassOf rdf:resource="https://purl.org/pao/Event"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/pao/hasParticipant"/>
                <owl:someValuesFrom rdf:resource="https://purl.org/pao/Agent"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/pao/hasStatus"/>
                <owl:someValuesFrom rdf:resource="https://purl.org/pao/SessionStatus"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/pao/hasTemporalExtent"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2006/time#Interval"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/pao/partOfConversation"/>
                <owl:someValuesFrom rdf:resource="https://purl.org/pao/Conversation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115 xml:lang="en">A process that is a bounded period of agent-user interaction within a conversation.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">session</rdfs:label>
        <skos:definition xml:lang="en">A process that is a bounded period of agent-user interaction within a conversation.</skos:definition>
    </owl:Class>



    <!-- https://purl.org/pao/SessionStatus -->

    <owl:Class rdf:about="https://purl.org/pao/SessionStatus">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://purl.org/pao/Active"/>
                    <rdf:Description rdf:about="https://purl.org/pao/Ended"/>
                    <rdf:Description rdf:about="https://purl.org/pao/Interrupted"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://purl.org/pao/Status"/>
        <obo:IAO_0000115 xml:lang="en">A status applicable to sessions indicating whether the session is active, ended, or interrupted.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">session status</rdfs:label>
        <skos:definition xml:lang="en">A status applicable to sessions indicating whether the session is active, ended, or interrupted.</skos:definition>
    </owl:Class>



    <!-- https://purl.org/pao/Status -->

    <owl:Class rdf:about="https://purl.org/pao/Status">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <obo:IAO_0000115 xml:lang="en">A class whose individuals represent the current state of an entity.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">status</rdfs:label>
        <skos:definition xml:lang="en">A class whose individuals represent the current state of an entity.</skos:definition>
    </owl:Class>



    <!-- https://purl.org/pao/SubAgent -->

    <owl:Class rdf:about="https://purl.org/pao/SubAgent">
        <rdfs:subClassOf rdf:resource="https://purl.org/pao/AIAgent"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/pao/delegatedTask"/>
                <owl:someValuesFrom rdf:resource="https://purl.org/pao/Task"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/pao/spawnedBy"/>
                <owl:someValuesFrom rdf:resource="https://purl.org/pao/AIAgent"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115 xml:lang="en">An AI agent that was spawned by another agent to perform delegated work.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">sub agent</rdfs:label>
        <skos:definition xml:lang="en">An AI agent that was spawned by another agent to perform delegated work.</skos:definition>
    </owl:Class>



    <!-- https://purl.org/pao/Task -->

    <owl:Class rdf:about="https://purl.org/pao/Task">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
