    </owl:Class>



    <!-- https://purl.org/pao/Turn -->

    <owl:Class rdf:about="https://purl.org/pao/Turn">
        <rdfs:subClassOf rdf:resource="https://purl.org/pao/Event"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/pao/hasParticipant"/>
                <owl:someValuesFrom rdf:resource="https://purl.org/pao/Agent"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/pao/partOfConversation"/>
                <owl:someValuesFrom rdf:resource="https://purl.org/pao/Conversation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/pao/partOfSession"/>
                <owl:someValuesFrom rdf:resource="https://purl.org/pao/Session"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/pao/hasParticipant"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://purl.org/pao/Agent"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://purl.org/pao/hasTurnIndex"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115 xml:lang="en">A process that is a single contribution by one participant in a conversation.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">turn</rdfs:label>
        <skos:definition xml:lang="en">A process that is a single contribution by one participant in a conversation.</skos:definition>
    </owl:Class>



