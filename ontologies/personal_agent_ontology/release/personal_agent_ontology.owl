  <rdf:Description rdf:about="https://purl.org/pao/intendedBy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">intended by</rdfs:label>
    <obo:IAO_0000115 xml:lang="en">Links an intention to the agent that holds it.</obo:IAO_0000115>
    <rdfs:domain rdf:resource="https://purl.org/pao/Intention"/>
    <rdfs:range rdf:resource="https://purl.org/pao/Agent"/>
    <skos:definition xml:lang="en">Links an intention to the agent that holds it.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/pao/SessionStatus">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">session status</rdfs:label>
    <obo:IAO_0000115 xml:lang="en">A status applicable to sessions indicating whether the session is active, ended, or interrupted.</obo:IAO_0000115>
    <rdfs:subClassOf rdf:resource="https://purl.org/pao/Status"/>
    <skos:definition xml:lang="en">A status applicable to sessions indicating whether the session is active, ended, or interrupted.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n743433ab138e4b70be2883382cc8aa9ab108">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AllDisjointClasses"/>
    <owl:members rdf:nodeID="n743433ab138e4b70be2883382cc8aa9ab109"/>
