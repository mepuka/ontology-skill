    <owl:someValuesFrom rdf:resource="https://purl.org/pao/CheckpointDecision"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/pao/hasFailureType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">has failure type</rdfs:label>
    <obo:IAO_0000115 xml:lang="en">Links an error recovery event to its classified failure type.</obo:IAO_0000115>
    <rdfs:domain rdf:resource="https://purl.org/pao/ErrorRecoveryEvent"/>
    <rdfs:range rdf:resource="https://purl.org/pao/FailureType"/>
    <skos:definition xml:lang="en">Links an error recovery event to its classified failure type.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/pao/invokesTool">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">invokes tool</rdfs:label>
    <obo:IAO_0000115 xml:lang="en">Links a tool invocation to the tool definition invoked.</obo:IAO_0000115>
