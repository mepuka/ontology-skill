    <owl:onProperty rdf:resource="https://purl.org/pao/storedIn"/>
    <owl:someValuesFrom rdf:resource="https://purl.org/pao/MemoryTier"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/pao/ClarificationRequest">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">clarification request</rdfs:label>
    <obo:IAO_0000115 xml:lang="en">A prov:Entity that records a request for additional information to resolve ambiguity.</obo:IAO_0000115>
    <rdfs:subClassOf rdf:nodeID="nbf40f2f07f184d6f8ac886f2ec454632b4"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Entity"/>
    <skos:definition xml:lang="en">A prov:Entity that records a request for additional information to resolve ambiguity.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/pao/hasIntegration">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">has integration</rdfs:label>
    <obo:IAO_0000115 xml:lang="en">Links an agent to an integration it has configured.</obo:IAO_0000115>
    <rdfs:domain rdf:resource="https://purl.org/pao/Agent"/>
    <rdfs:range rdf:resource="https://purl.org/pao/Integration"/>
    <skos:definition xml:lang="en">Links an agent to an integration it has configured.</skos:definition>
  </rdf:Description>
