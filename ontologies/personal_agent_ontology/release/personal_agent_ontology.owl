  <rdf:Description rdf:about="https://purl.org/pao/WorkingMemory">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">working memory</rdfs:label>
    <obo:IAO_0000115 xml:lang="en">A memory tier that holds information currently active in the agent's context window.</obo:IAO_0000115>
    <rdfs:subClassOf rdf:resource="https://purl.org/pao/MemoryTier"/>
    <skos:definition xml:lang="en">A memory tier that holds information currently active in the agent's context window.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/pao/StatusTransition">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">status transition</rdfs:label>
    <obo:IAO_0000115 xml:lang="en">A process in which an entity's status changes from one value to another.</obo:IAO_0000115>
    <rdfs:subClassOf rdf:nodeID="n743433ab138e4b70be2883382cc8aa9ab61"/>
    <rdfs:subClassOf rdf:nodeID="n743433ab138e4b70be2883382cc8aa9ab62"/>
    <rdfs:subClassOf rdf:nodeID="n743433ab138e4b70be2883382cc8aa9ab63"/>
    <rdfs:subClassOf rdf:resource="https://purl.org/pao/Event"/>
    <skos:definition xml:lang="en">A process in which an entity's status changes from one value to another.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n743433ab138e4b70be2883382cc8aa9ab121">
