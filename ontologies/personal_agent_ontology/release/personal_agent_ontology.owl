        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://purl.org/pao/Status"/>
        <obo:IAO_0000115 xml:lang="en">A status applicable to tasks indicating progress from pending through completion.</obo:IAO_0000115>
