  <rdf:Description rdf:about="https://purl.org/pao/pursuesGoal">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">pursues goal</rdfs:label>
    <obo:IAO_0000115 xml:lang="en">Links an agent to a goal it is actively pursuing.</obo:IAO_0000115>
    <rdfs:domain rdf:resource="https://purl.org/pao/Agent"/>
    <rdfs:range rdf:resource="https://purl.org/pao/Goal"/>
    <skos:definition xml:lang="en">Links an agent to a goal it is actively pursuing.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/pao/aboutAgent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">about agent</rdfs:label>
    <obo:IAO_0000115 xml:lang="en">Links a memory item to the agent it describes.</obo:IAO_0000115>
    <rdfs:domain rdf:resource="https://purl.org/pao/MemoryItem"/>
    <rdfs:range rdf:resource="https://purl.org/pao/Agent"/>
    <skos:definition xml:lang="en">Links a memory item to the agent it describes.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/pao/partOfConversation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">part of conversation</rdfs:label>
    <obo:IAO_0000115 xml:lang="en">Links a session to the conversation it is a temporal part of.</obo:IAO_0000115>
    <rdfs:domain rdf:resource="https://purl.org/pao/Event"/>
    <rdfs:range rdf:resource="https://purl.org/pao/Conversation"/>
    <rdfs:subPropertyOf rdf:resource="https://purl.org/pao/partOf"/>
    <skos:definition xml:lang="en">Links a session to the conversation it is a temporal part of.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/pao/consentPurpose">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">consent purpose</rdfs:label>
    <obo:IAO_0000115 xml:lang="en">Links a consent record to the entity describing the purpose.</obo:IAO_0000115>
    <rdfs:domain rdf:resource="https://purl.org/pao/ConsentRecord"/>
    <rdfs:range rdf:resource="http://www.w3.org/ns/prov#Entity"/>
    <skos:definition xml:lang="en">Links a consent record to the entity describing the purpose.</skos:definition>
  </rdf:Description>
