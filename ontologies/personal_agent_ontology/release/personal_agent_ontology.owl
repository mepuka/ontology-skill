    <rdfs:range rdf:resource="https://purl.org/pao/ToolDefinition"/>
    <owl:inverseOf rdf:resource="https://purl.org/pao/invokedIn"/>
    <skos:definition xml:lang="en">Links a tool invocation to the tool definition invoked.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/pao/hasRole">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">has role</rdfs:label>
    <obo:IAO_0000115 xml:lang="en">Links an agent to a role it bears in some context.</obo:IAO_0000115>
    <rdfs:domain rdf:resource="https://purl.org/pao/Agent"/>
    <rdfs:range rdf:resource="https://purl.org/pao/AgentRole"/>
    <skos:definition xml:lang="en">Links an agent to a role it bears in some context.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://purl.org/pao/governedByPolicy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">governed by policy</rdfs:label>
