        </rdfs:subClassOf>
        <obo:IAO_0000115 xml:lang="en">A generically dependent continuant that is a concrete actionable work item within a plan with status and dependencies.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">task</rdfs:label>
        <skos:definition xml:lang="en">A generically dependent continuant that is a concrete actionable work item within a plan with status and dependencies.</skos:definition>
    </owl:Class>



    <!-- https://purl.org/pao/TaskStatus -->

    <owl:Class rdf:about="https://purl.org/pao/TaskStatus">
        <owl:equivalentClass>
            <owl:Class>
