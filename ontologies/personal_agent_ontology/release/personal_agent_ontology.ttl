###  https://purl.org/pao/AIAgent
pao:AIAgent rdf:type owl:Class ;
            rdfs:subClassOf obo:BFO_0000031 ,
                            prov:SoftwareAgent ,
                            pao:Agent ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty pao:hasAvailableTool ;
                              owl:someValuesFrom pao:ToolDefinition
                            ] ;
            owl:disjointWith pao:HumanUser ;
            obo:IAO_0000115 "An agent that is a software system capable of autonomous decision-making and tool use."@en ;
            rdfs:label "ai agent"@en ;
            skos:definition "An agent that is a software system capable of autonomous decision-making and tool use."@en .


###  https://purl.org/pao/Action
pao:Action rdf:type owl:Class ;
           rdfs:subClassOf pao:Event ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty pao:performedBy ;
                             owl:someValuesFrom pao:Agent
                           ] ;
           obo:IAO_0000115 "An event that is intentionally caused by an agent to affect the environment or internal state."@en ;
           rdfs:label "action"@en ;
           skos:definition "An event that is intentionally caused by an agent to affect the environment or internal state."@en .


###  https://purl.org/pao/Agent
pao:Agent rdf:type owl:Class ;
          rdfs:subClassOf prov:Agent ;
          obo:IAO_0000115 "An entity that bears responsibility for activities and can act on behalf of itself or others."@en ;
          rdfs:label "agent"@en ;
          skos:definition "An entity that bears responsibility for activities and can act on behalf of itself or others."@en .


###  https://purl.org/pao/AgentRole
pao:AgentRole rdf:type owl:Class ;
              owl:equivalentClass [ rdf:type owl:Class ;
                                    owl:oneOf ( pao:AssistantRole
                                                pao:UserRole
                                              )
                                  ] ;
              rdfs:subClassOf obo:BFO_0000023 ,
                              prov:Role ;
              obo:IAO_0000115 "A role that an agent plays in the context of a conversation or activity."@en ;
              rdfs:label "agent role"@en ;
              skos:definition "A role that an agent plays in the context of a conversation or activity."@en .


###  https://purl.org/pao/Claim
pao:Claim rdf:type owl:Class ;
          rdfs:subClassOf pao:MemoryItem ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty pao:aboutAgent ;
                            owl:someValuesFrom pao:Agent
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty pao:storedIn ;
                            owl:someValuesFrom pao:MemoryTier
                          ] ;
          owl:disjointWith pao:Episode ;
          obo:IAO_0000115 "A memory item that represents an agent-held proposition with associated confidence, evidence, and provenance metadata."@en ;
          rdfs:label "claim"@en ;
          skos:definition "A memory item that represents an agent-held proposition with associated confidence, evidence, and provenance metadata."@en .


###  https://purl.org/pao/CompactionEvent
pao:CompactionEvent rdf:type owl:Class ;
                    rdfs:subClassOf pao:Event ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty pao:inConversation ;
                                      owl:someValuesFrom pao:Conversation
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty pao:producedSummary ;
                                      owl:someValuesFrom pao:MemoryItem
                                    ] ;
                    obo:IAO_0000115 "A process in which an agent's context window is compressed by summarizing prior turns."@en ;
                    rdfs:label "compaction event"@en ;
                    skos:definition "A process in which an agent's context window is compressed by summarizing prior turns."@en .


###  https://purl.org/pao/ComplianceStatus
pao:ComplianceStatus rdf:type owl:Class ;
                     owl:equivalentClass [ rdf:type owl:Class ;
                                           owl:oneOf ( pao:Compliant
                                                       pao:NonCompliant
                                                     )
                                         ] ;
                     rdfs:subClassOf pao:Status ;
                     obo:IAO_0000115 "A status indicating whether a tool invocation complied with applicable permission policies."@en ;
                     rdfs:label "compliance status"@en ;
                     skos:definition "A status indicating whether a tool invocation complied with applicable permission policies."@en .


###  https://purl.org/pao/Consolidation
pao:Consolidation rdf:type owl:Class ;
                  rdfs:subClassOf pao:MemoryOperation ;
                  obo:IAO_0000115 "A memory operation that transforms episodic memories into semantic memories."@en ;
                  rdfs:label "consolidation"@en ;
                  skos:definition "A memory operation that transforms episodic memories into semantic memories."@en .


###  https://purl.org/pao/Conversation
pao:Conversation rdf:type owl:Class ;
                 rdfs:subClassOf pao:Event ;
                 obo:IAO_0000115 "A process consisting of a coherent thread of dialogue between participants that may span multiple sessions."@en ;
                 rdfs:label "conversation"@en ;
                 skos:definition "A process consisting of a coherent thread of dialogue between participants that may span multiple sessions."@en .


###  https://purl.org/pao/Encoding
pao:Encoding rdf:type owl:Class ;
             rdfs:subClassOf pao:MemoryOperation ;
             obo:IAO_0000115 "A memory operation that writes new information into a memory tier."@en ;
             rdfs:label "encoding"@en ;
             skos:definition "A memory operation that writes new information into a memory tier."@en .


###  https://purl.org/pao/Episode
pao:Episode rdf:type owl:Class ;
            rdfs:subClassOf pao:MemoryItem ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty pao:hasTemporalExtent ;
                              owl:someValuesFrom time:Interval
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty pao:hasTopic ;
                              owl:someValuesFrom skos:Concept
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty pao:storedIn ;
                              owl:someValuesFrom pao:MemoryTier
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty pao:storedIn ;
                              owl:allValuesFrom pao:EpisodicMemory
                            ] ;
            obo:IAO_0000115 "A memory item that records a temporally bounded cluster of related events."@en ;
            rdfs:label "episode"@en ;
            skos:definition "A memory item that records a temporally bounded cluster of related events."@en .


###  https://purl.org/pao/EpisodicMemory
pao:EpisodicMemory rdf:type owl:Class ;
                   rdfs:subClassOf pao:MemoryTier ;
                   obo:IAO_0000115 "A memory tier that stores time-situated experiences and interaction histories."@en ;
                   rdfs:label "episodic memory"@en ;
                   skos:definition "A memory tier that stores time-situated experiences and interaction histories."@en .


###  https://purl.org/pao/ErasureEvent
pao:ErasureEvent rdf:type owl:Class ;
                 rdfs:subClassOf pao:Event ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty pao:requestedBy ;
                                   owl:someValuesFrom pao:Agent
                                 ] ;
                 obo:IAO_0000115 "A process in which memory items are identified and deleted to comply with privacy requirements."@en ;
                 rdfs:label "erasure event"@en ;
                 skos:definition "A process in which memory items are identified and deleted to comply with privacy requirements."@en .


###  https://purl.org/pao/Event
pao:Event rdf:type owl:Class ;
          rdfs:subClassOf obo:BFO_0000015 ,
                          prov:Activity ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty pao:hasTemporalExtent ;
                            owl:someValuesFrom time:TemporalEntity
                          ] ;
          obo:IAO_0000115 "A process that is an occurrence situated in time within the agent system."@en ;
          rdfs:label "event"@en ;
          skos:definition "A process that is an occurrence situated in time within the agent system."@en .


###  https://purl.org/pao/Forgetting
pao:Forgetting rdf:type owl:Class ;
               rdfs:subClassOf pao:MemoryOperation ;
               obo:IAO_0000115 "A memory operation that removes or decays memory items from a memory tier."@en ;
               rdfs:label "forgetting"@en ;
               skos:definition "A memory operation that removes or decays memory items from a memory tier."@en .


###  https://purl.org/pao/Goal
pao:Goal rdf:type owl:Class ;
         rdfs:subClassOf obo:BFO_0000031 ,
                         prov:Entity ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty pao:hasStatus ;
                           owl:someValuesFrom pao:TaskStatus
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty pao:pursuedBy ;
                           owl:someValuesFrom pao:Agent
                         ] ;
         obo:IAO_0000115 "A generically dependent continuant that specifies a desired state an agent works toward."@en ;
         rdfs:label "goal"@en ;
         skos:definition "A generically dependent continuant that specifies a desired state an agent works toward."@en .


###  https://purl.org/pao/HumanUser
pao:HumanUser rdf:type owl:Class ;
              rdfs:subClassOf obo:BFO_0000030 ,
                              prov:Person ,
                              foaf:Person ,
                              pao:Agent ;
              obo:IAO_0000115 "An agent that is a human person who interacts with AI systems."@en ;
              rdfs:label "human user"@en ;
              skos:definition "An agent that is a human person who interacts with AI systems."@en .


###  https://purl.org/pao/MemoryItem
pao:MemoryItem rdf:type owl:Class ;
               rdfs:subClassOf obo:BFO_0000031 ,
                               prov:Entity ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty prov:wasAttributedTo ;
                                 owl:someValuesFrom pao:Agent
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty prov:wasGeneratedBy ;
                                 owl:someValuesFrom prov:Activity
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty pao:storedIn ;
                                 owl:someValuesFrom pao:MemoryTier
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty pao:storedIn ;
                                 owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                 owl:onClass pao:MemoryTier
                               ] ;
               obo:IAO_0000115 "A generically dependent continuant that is an information artifact persisted in an agent's memory system."@en ;
               rdfs:label "memory item"@en ;
               skos:definition "A generically dependent continuant that is an information artifact persisted in an agent's memory system."@en .


###  https://purl.org/pao/MemoryOperation
pao:MemoryOperation rdf:type owl:Class ;
                    rdfs:subClassOf pao:Event ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty pao:operatesOn ;
                                      owl:someValuesFrom pao:MemoryItem
                                    ] ;
                    owl:disjointUnionOf ( pao:Consolidation
                                          pao:Encoding
                                          pao:Forgetting
                                          pao:Retrieval
                                        ) ;
                    obo:IAO_0000115 "A process that acts on memory items to encode, retrieve, consolidate, or remove them."@en ;
                    rdfs:label "memory operation"@en ;
                    skos:definition "A process that acts on memory items to encode, retrieve, consolidate, or remove them."@en .


###  https://purl.org/pao/MemoryTier
pao:MemoryTier rdf:type owl:Class ;
               rdfs:subClassOf obo:BFO_0000031 ,
                               prov:Entity ;
               owl:disjointUnionOf ( pao:EpisodicMemory
                                     pao:ProceduralMemory
                                     pao:SemanticMemory
                                     pao:WorkingMemory
                                   ) ;
               obo:IAO_0000115 "A generically dependent continuant that defines a layer in the agent's memory architecture with specific storage and access characteristics."@en ;
               rdfs:label "memory tier"@en ;
               skos:definition "A generically dependent continuant that defines a layer in the agent's memory architecture with specific storage and access characteristics."@en .


###  https://purl.org/pao/Message
pao:Message rdf:type owl:Class ;
            rdfs:subClassOf obo:BFO_0000031 ,
                            prov:Entity ;
            obo:IAO_0000115 "A generically dependent continuant that is the textual or structured content of a conversational turn."@en ;
            rdfs:label "message"@en ;
            skos:definition "A generically dependent continuant that is the textual or structured content of a conversational turn."@en .


###  https://purl.org/pao/PermissionPolicy
pao:PermissionPolicy rdf:type owl:Class ;
                     rdfs:subClassOf obo:BFO_0000031 ,
                                     odrl:Policy ,
                                     prov:Entity ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty pao:appliesTo ;
                                       owl:someValuesFrom pao:Agent
                                     ] ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty pao:grantsPermission ;
                                       owl:someValuesFrom odrl:Permission
                                     ] ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty pao:restrictsToolUse ;
                                       owl:someValuesFrom pao:ToolDefinition
                                     ] ;
                     owl:disjointWith pao:SafetyConstraint ;
                     obo:IAO_0000115 "A generically dependent continuant that specifies rules governing what actions an agent is permitted or forbidden to perform."@en ;
                     rdfs:label "permission policy"@en ;
                     skos:definition "A generically dependent continuant that specifies rules governing what actions an agent is permitted or forbidden to perform."@en .


###  https://purl.org/pao/Plan
pao:Plan rdf:type owl:Class ;
         rdfs:subClassOf prov:Plan ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty pao:achievesGoal ;
                           owl:someValuesFrom pao:Goal
                         ] ;
         obo:IAO_0000115 "A generically dependent continuant that specifies an ordered sequence of intended actions to achieve a goal."@en ;
         rdfs:label "plan"@en ;
         skos:definition "A generically dependent continuant that specifies an ordered sequence of intended actions to achieve a goal."@en .


###  https://purl.org/pao/ProceduralMemory
pao:ProceduralMemory rdf:type owl:Class ;
                     rdfs:subClassOf pao:MemoryTier ;
                     obo:IAO_0000115 "A memory tier that stores learned action policies, skills, and behavioral patterns."@en ;
                     rdfs:label "procedural memory"@en ;
                     skos:definition "A memory tier that stores learned action policies, skills, and behavioral patterns."@en .


###  https://purl.org/pao/Retrieval
pao:Retrieval rdf:type owl:Class ;
              rdfs:subClassOf pao:MemoryOperation ;
              obo:IAO_0000115 "A memory operation that reads information from a memory tier."@en ;
              rdfs:label "retrieval"@en ;
              skos:definition "A memory operation that reads information from a memory tier."@en .


###  https://purl.org/pao/SafetyConstraint
pao:SafetyConstraint rdf:type owl:Class ;
                     rdfs:subClassOf obo:BFO_0000031 ,
                                     prov:Entity ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty pao:appliesTo ;
                                       owl:someValuesFrom pao:Agent
                                     ] ;
                     obo:IAO_0000115 "A generically dependent continuant that specifies a non-negotiable behavioral limit on an agent."@en ;
                     rdfs:label "safety constraint"@en ;
                     skos:definition "A generically dependent continuant that specifies a non-negotiable behavioral limit on an agent."@en .


###  https://purl.org/pao/SemanticMemory
pao:SemanticMemory rdf:type owl:Class ;
                   rdfs:subClassOf pao:MemoryTier ;
                   obo:IAO_0000115 "A memory tier that stores generalized facts, knowledge, and beliefs extracted from experience."@en ;
                   rdfs:label "semantic memory"@en ;
                   skos:definition "A memory tier that stores generalized facts, knowledge, and beliefs extracted from experience."@en .


###  https://purl.org/pao/Session
pao:Session rdf:type owl:Class ;
            rdfs:subClassOf pao:Event ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty pao:hasParticipant ;
                              owl:someValuesFrom pao:Agent
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty pao:hasStatus ;
                              owl:someValuesFrom pao:SessionStatus
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty pao:hasTemporalExtent ;
                              owl:someValuesFrom time:Interval
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty pao:partOfConversation ;
                              owl:someValuesFrom pao:Conversation
                            ] ;
            obo:IAO_0000115 "A process that is a bounded period of agent-user interaction within a conversation."@en ;
            rdfs:label "session"@en ;
            skos:definition "A process that is a bounded period of agent-user interaction within a conversation."@en .


###  https://purl.org/pao/SessionStatus
pao:SessionStatus rdf:type owl:Class ;
                  owl:equivalentClass [ rdf:type owl:Class ;
                                        owl:oneOf ( pao:Active
                                                    pao:Ended
                                                    pao:Interrupted
                                                  )
                                      ] ;
                  rdfs:subClassOf pao:Status ;
                  obo:IAO_0000115 "A status applicable to sessions indicating whether the session is active, ended, or interrupted."@en ;
                  rdfs:label "session status"@en ;
                  skos:definition "A status applicable to sessions indicating whether the session is active, ended, or interrupted."@en .


###  https://purl.org/pao/Status
pao:Status rdf:type owl:Class ;
           rdfs:subClassOf owl:Thing ;
           obo:IAO_0000115 "A class whose individuals represent the current state of an entity."@en ;
           rdfs:label "status"@en ;
           skos:definition "A class whose individuals represent the current state of an entity."@en .


###  https://purl.org/pao/SubAgent
pao:SubAgent rdf:type owl:Class ;
             rdfs:subClassOf pao:AIAgent ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty pao:delegatedTask ;
                               owl:someValuesFrom pao:Task
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty pao:spawnedBy ;
                               owl:someValuesFrom pao:AIAgent
                             ] ;
             obo:IAO_0000115 "An AI agent that was spawned by another agent to perform delegated work."@en ;
             rdfs:label "sub agent"@en ;
             skos:definition "An AI agent that was spawned by another agent to perform delegated work."@en .


###  https://purl.org/pao/Task
pao:Task rdf:type owl:Class ;
         rdfs:subClassOf obo:BFO_0000031 ,
                         prov:Entity ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty pao:hasStatus ;
                           owl:someValuesFrom pao:TaskStatus
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty pao:partOfPlan ;
                           owl:someValuesFrom pao:Plan
                         ] ;
         obo:IAO_0000115 "A generically dependent continuant that is a concrete actionable work item within a plan with status and dependencies."@en ;
         rdfs:label "task"@en ;
         skos:definition "A generically dependent continuant that is a concrete actionable work item within a plan with status and dependencies."@en .


###  https://purl.org/pao/TaskStatus
pao:TaskStatus rdf:type owl:Class ;
               owl:equivalentClass [ rdf:type owl:Class ;
                                     owl:oneOf ( pao:Blocked
                                                 pao:Completed
                                                 pao:InProgress
                                                 pao:Pending
                                               )
                                   ] ;
               rdfs:subClassOf pao:Status ;
               obo:IAO_0000115 "A status applicable to tasks indicating progress from pending through completion."@en ;
               rdfs:label "task status"@en ;
               skos:definition "A status applicable to tasks indicating progress from pending through completion."@en .


###  https://purl.org/pao/ToolDefinition
pao:ToolDefinition rdf:type owl:Class ;
                   rdfs:subClassOf obo:BFO_0000031 ,
                                   prov:Entity ;
                   obo:IAO_0000115 "A generically dependent continuant that specifies the interface, capabilities, and constraints of an available tool."@en ;
                   rdfs:label "tool definition"@en ;
                   skos:definition "A generically dependent continuant that specifies the interface, capabilities, and constraints of an available tool."@en .


###  https://purl.org/pao/ToolInvocation
pao:ToolInvocation rdf:type owl:Class ;
                   rdfs:subClassOf pao:Action ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty pao:hasComplianceStatus ;
                                     owl:someValuesFrom pao:ComplianceStatus
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty pao:hasInput ;
                                     owl:someValuesFrom prov:Entity
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty pao:hasOutput ;
                                     owl:someValuesFrom prov:Entity
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty pao:inSession ;
                                     owl:someValuesFrom pao:Session
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty pao:invokedBy ;
                                     owl:someValuesFrom pao:Agent
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty pao:invokesTool ;
                                     owl:someValuesFrom pao:ToolDefinition
                                   ] ;
                   obo:IAO_0000115 "A process in which an agent requests execution of a tool by providing inputs and receiving outputs."@en ;
                   rdfs:label "tool invocation"@en ;
                   skos:definition "A process in which an agent requests execution of a tool by providing inputs and receiving outputs."@en .


###  https://purl.org/pao/Turn
pao:Turn rdf:type owl:Class ;
         rdfs:subClassOf pao:Event ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty pao:hasParticipant ;
                           owl:someValuesFrom pao:Agent
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty pao:partOfConversation ;
                           owl:someValuesFrom pao:Conversation
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty pao:partOfSession ;
                           owl:someValuesFrom pao:Session
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty pao:hasParticipant ;
                           owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                           owl:onClass pao:Agent
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty pao:hasTurnIndex ;
                           owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                           owl:onDataRange xsd:nonNegativeInteger
                         ] ;
         obo:IAO_0000115 "A process that is a single contribution by one participant in a conversation."@en ;
         rdfs:label "turn"@en ;
         skos:definition "A process that is a single contribution by one participant in a conversation."@en .


###  https://purl.org/pao/WorkingMemory
pao:WorkingMemory rdf:type owl:Class ;
                  rdfs:subClassOf pao:MemoryTier ;
                  obo:IAO_0000115 "A memory tier that holds information currently active in the agent's context window."@en ;
                  rdfs:label "working memory"@en ;
                  skos:definition "A memory tier that holds information currently active in the agent's context window."@en .


#################################################################
#    Individuals
#################################################################

###  https://purl.org/pao/Active
pao:Active rdf:type owl:NamedIndividual ,
                    pao:SessionStatus ;
           rdfs:label "active"@en ;
           skos:definition "Status value: an entity is currently active."@en .


###  https://purl.org/pao/AssistantRole
pao:AssistantRole rdf:type owl:NamedIndividual ,
                           pao:AgentRole ;
                  owl:differentFrom pao:UserRole ;
                  rdfs:label "assistant role"@en ;
                  skos:definition "The role of the AI assistant in a conversation."@en .


###  https://purl.org/pao/Blocked
pao:Blocked rdf:type owl:NamedIndividual ,
                     pao:TaskStatus ;
            rdfs:label "blocked"@en ;
            skos:definition "Status value: a task cannot proceed because of unresolved dependencies."@en .


###  https://purl.org/pao/Completed
pao:Completed rdf:type owl:NamedIndividual ,
                       pao:TaskStatus ;
              rdfs:label "completed"@en ;
              skos:definition "Status value: a task or process has finished successfully."@en .


###  https://purl.org/pao/Compliant
pao:Compliant rdf:type owl:NamedIndividual ,
                       pao:ComplianceStatus ;
              owl:differentFrom pao:NonCompliant ;
              rdfs:label "compliant"@en ;
              skos:definition "Compliance status: a tool invocation followed all applicable policies."@en .


###  https://purl.org/pao/Ended
pao:Ended rdf:type owl:NamedIndividual ,
                   pao:SessionStatus ;
          rdfs:label "ended"@en ;
          skos:definition "Status value: a session has ended normally."@en .


###  https://purl.org/pao/InProgress
pao:InProgress rdf:type owl:NamedIndividual ,
                        pao:TaskStatus ;
               rdfs:label "in progress"@en ;
               skos:definition "Status value: a task is currently being worked on."@en .


###  https://purl.org/pao/Interrupted
pao:Interrupted rdf:type owl:NamedIndividual ,
                         pao:SessionStatus ;
                rdfs:label "interrupted"@en ;
                skos:definition "Status value: a session ended abnormally."@en .


###  https://purl.org/pao/NonCompliant
pao:NonCompliant rdf:type owl:NamedIndividual ,
                          pao:ComplianceStatus ;
                 rdfs:label "non compliant"@en ;
                 skos:definition "Compliance status: a tool invocation violated one or more policies."@en .


###  https://purl.org/pao/Pending
pao:Pending rdf:type owl:NamedIndividual ,
                     pao:TaskStatus ;
            rdfs:label "pending"@en ;
            skos:definition "Status value: a task has not yet started."@en .


###  https://purl.org/pao/PersonalData
pao:PersonalData rdf:type owl:NamedIndividual ;
                 rdfs:label "personal data"@en ;
                 skos:definition "A sensitivity level indicating the memory item contains personal data."@en .


###  https://purl.org/pao/UserPreference
pao:UserPreference rdf:type owl:NamedIndividual ;
                   rdfs:label "user preference"@en ;
                   skos:definition "A claim type indicating the claim records a user preference."@en .


###  https://purl.org/pao/UserRole
pao:UserRole rdf:type owl:NamedIndividual ,
                      pao:AgentRole ;
             rdfs:label "user role"@en ;
             skos:definition "The role of the human user in a conversation."@en .


#################################################################
#    General axioms
#################################################################

[ rdf:type owl:AllDisjointClasses ;
  owl:members ( pao:Action
                pao:CompactionEvent
                pao:Conversation
                pao:ErasureEvent
                pao:MemoryOperation
                pao:Session
                pao:Turn
              )
] .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( pao:ComplianceStatus
                pao:SessionStatus
                pao:TaskStatus
              )
] .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( pao:Consolidation
                pao:Encoding
                pao:Forgetting
                pao:Retrieval
              )
] .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( pao:EpisodicMemory
                pao:ProceduralMemory
                pao:SemanticMemory
                pao:WorkingMemory
              )
] .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( pao:Goal
                pao:MemoryItem
                pao:MemoryTier
                pao:Message
                pao:PermissionPolicy
                pao:Plan
                pao:SafetyConstraint
                pao:Task
                pao:ToolDefinition
              )
] .


[ rdf:type owl:AllDifferent ;
  owl:distinctMembers ( pao:Active
                        pao:Ended
                        pao:Interrupted
                      )
] .


[ rdf:type owl:AllDifferent ;
  owl:distinctMembers ( pao:Blocked
                        pao:Completed
                        pao:InProgress
                        pao:Pending
                      )
] .


