@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pao: <https://purl.org/pao/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

pao:reference-individuals a owl:Ontology ;
    dcterms:created "2026-02-20" ;
    dcterms:creator "ontology-architect skill" ;
    dcterms:description "Named individuals for status values, agent roles, and classifiers."@en ;
    dcterms:license <https://spdx.org/licenses/MIT> ;
    dcterms:title "Personal Agent Ontology — Reference Individuals"@en ;
    owl:priorVersion <https://purl.org/pao/reference-individuals/0.6.0> ;
    owl:versionIRI <https://purl.org/pao/reference-individuals/0.7.0> ;
    owl:versionInfo "0.7.0" .

pao:ClaimType owl:equivalentClass [ owl:oneOf ( pao:UserPreference ) ] .

pao:APIChannel a owl:NamedIndividual,
        pao:ChannelType ;
    rdfs:label "api channel"@en ;
    skos:definition "Channel type: programmatic API access."@en .

pao:Accept a owl:NamedIndividual,
        pao:CommunicativeFunction ;
    rdfs:label "accept"@en ;
    skos:definition "Communicative function: accepting a proposition into common ground."@en .

pao:Active a owl:NamedIndividual,
        pao:SessionStatus ;
    rdfs:label "active"@en ;
    skos:definition "Status value: an entity is currently active."@en .

pao:AgentRole owl:equivalentClass [ owl:oneOf ( pao:AssistantRole pao:UserRole ) ] .

pao:AgentSource a owl:NamedIndividual,
        pao:MemorySource ;
    rdfs:label "agent source"@en ;
    skos:definition "Memory source: originated from agent reasoning."@en .

pao:Allow a owl:NamedIndividual,
        pao:AuthorizationDecision ;
    rdfs:label "allow"@en ;
    skos:definition "Authorization decision: the operation was permitted."@en .

pao:Approved a owl:NamedIndividual,
        pao:CheckpointDecision ;
    rdfs:label "approved"@en ;
    skos:definition "Checkpoint decision: the task was approved to continue."@en .

pao:Archived a owl:NamedIndividual,
        pao:ItemFate ;
    rdfs:label "archived"@en ;
    skos:definition "Item fate: moved to long-term storage."@en .

pao:AssistantRole a owl:NamedIndividual,
        pao:AgentRole ;
    rdfs:label "assistant role"@en ;
    skos:definition "The role of the AI assistant in a conversation."@en .

pao:AuthenticationFailure a owl:NamedIndividual,
        pao:FailureType ;
    rdfs:label "authentication failure"@en ;
    skos:definition "Failure type: authentication or authorization was rejected."@en .

pao:Blocked a owl:NamedIndividual,
        pao:TaskStatus ;
    rdfs:label "blocked"@en ;
    skos:definition "Status value: a task cannot proceed because of unresolved dependencies."@en .

pao:CLI a owl:NamedIndividual,
        pao:ChannelType ;
    rdfs:label "cli"@en ;
    skos:definition "Channel type: command-line interface interaction."@en .

pao:Clarify a owl:NamedIndividual,
        pao:CommunicativeFunction ;
    rdfs:label "clarify"@en ;
    skos:definition "Communicative function: seeking to resolve ambiguity."@en .

pao:Closed a owl:NamedIndividual,
        pao:ConnectionStatus ;
    rdfs:label "closed"@en ;
    skos:definition "Connection status: the connection is closed."@en .

pao:Completed a owl:NamedIndividual,
        pao:TaskStatus ;
    rdfs:label "completed"@en ;
    skos:definition "Status value: a task or process has finished successfully."@en .

pao:ComplianceStatus owl:equivalentClass [ owl:oneOf ( pao:Compliant pao:NonCompliant ) ] .

pao:Compliant a owl:NamedIndividual,
        pao:ComplianceStatus ;
    rdfs:label "compliant"@en ;
    skos:definition "Compliance status: a tool invocation followed all applicable policies."@en .

pao:Confidential a owl:NamedIndividual,
        pao:SensitivityLevel ;
    rdfs:label "confidential"@en ;
    skos:definition "Sensitivity level: restricted personal data."@en .

pao:ConfigurationError a owl:NamedIndividual,
        pao:FailureType ;
    rdfs:label "configuration error"@en ;
    skos:definition "Failure type: the system was misconfigured."@en .

pao:Confirm a owl:NamedIndividual,
        pao:CommunicativeFunction ;
    rdfs:label "confirm"@en ;
    skos:definition "Communicative function: confirming understanding or agreement."@en .

pao:Connected a owl:NamedIndividual,
        pao:IntegrationStatus ;
    rdfs:label "connected"@en ;
    skos:definition "Integration status: the integration is connected and operational."@en .

pao:Deferred a owl:NamedIndividual,
        pao:CheckpointDecision ;
    rdfs:label "deferred"@en ;
    skos:definition "Checkpoint decision: the decision was deferred for later."@en .

pao:Deny a owl:NamedIndividual,
        pao:AuthorizationDecision ;
    rdfs:label "deny"@en ;
    skos:definition "Authorization decision: the operation was denied."@en .

pao:DependencyFailure a owl:NamedIndividual,
        pao:FailureType ;
    rdfs:label "dependency failure"@en ;
    skos:definition "Failure type: a required upstream dependency was unavailable."@en .

pao:Disconnected a owl:NamedIndividual,
        pao:IntegrationStatus ;
    rdfs:label "disconnected"@en ;
    skos:definition "Integration status: the integration is not currently connected."@en .

pao:Dropped a owl:NamedIndividual,
        pao:ItemFate ;
    rdfs:label "dropped"@en ;
    skos:definition "Item fate: excluded from summary."@en .

pao:EmailChannel a owl:NamedIndividual,
        pao:ChannelType ;
    rdfs:label "email channel"@en ;
    skos:definition "Channel type: email-based interaction."@en .

pao:Ended a owl:NamedIndividual,
        pao:SessionStatus ;
    rdfs:label "ended"@en ;
    skos:definition "Status value: a session has ended normally."@en .

pao:Error a owl:NamedIndividual,
        pao:IntegrationStatus ;
    rdfs:label "error"@en ;
    skos:definition "Integration status: the integration has encountered an error."@en .

pao:Failed a owl:NamedIndividual,
        pao:ConnectionStatus ;
    rdfs:label "failed"@en ;
    skos:definition "Connection status: the connection has failed."@en .

pao:GlobalScope a owl:NamedIndividual,
        pao:MemoryScope ;
    rdfs:label "global scope"@en ;
    skos:definition "Memory scope: visible across all projects and sessions."@en .

pao:ImageBlock a owl:NamedIndividual,
        pao:ContentBlockType ;
    rdfs:label "image block"@en ;
    skos:definition "Content block type: an image or visual content."@en .

pao:InProgress a owl:NamedIndividual,
        pao:TaskStatus ;
    rdfs:label "in progress"@en ;
    skos:definition "Status value: a task is currently being worked on."@en .

pao:Inform a owl:NamedIndividual,
        pao:CommunicativeFunction ;
    rdfs:label "inform"@en ;
    skos:definition "Communicative function: conveying information."@en .

pao:Initializing a owl:NamedIndividual,
        pao:IntegrationStatus ;
    rdfs:label "initializing"@en ;
    skos:definition "Integration status: the integration is being set up."@en .

pao:Internal a owl:NamedIndividual,
        pao:SensitivityLevel ;
    rdfs:label "internal"@en ;
    skos:definition "Sensitivity level: organization-internal data."@en .

pao:Interrupted a owl:NamedIndividual,
        pao:SessionStatus ;
    rdfs:label "interrupted"@en ;
    skos:definition "Status value: a session ended abnormally."@en .

pao:Messaging a owl:NamedIndividual,
        pao:ChannelType ;
    rdfs:label "messaging"@en ;
    skos:definition "Channel type: messaging platform interaction."@en .

pao:NetworkError a owl:NamedIndividual,
        pao:FailureType ;
    rdfs:label "network error"@en ;
    skos:definition "Failure type: a network connectivity issue occurred."@en .

pao:NonCompliant a owl:NamedIndividual,
        pao:ComplianceStatus ;
    rdfs:label "non compliant"@en ;
    skos:definition "Compliance status: a tool invocation violated one or more policies."@en .

pao:Open a owl:NamedIndividual,
        pao:ConnectionStatus ;
    rdfs:label "open"@en ;
    skos:definition "Connection status: the connection is open and active."@en .

pao:Pending a owl:NamedIndividual,
        pao:TaskStatus ;
    rdfs:label "pending"@en ;
    skos:definition "Status value: a task has not yet started."@en .

pao:Permissive a owl:NamedIndividual,
        pao:PermissionMode ;
    rdfs:label "permissive"@en ;
    skos:definition "Permission mode: tools are approved automatically."@en .

pao:Preserved a owl:NamedIndividual,
        pao:ItemFate ;
    rdfs:label "preserved"@en ;
    skos:definition "Item fate: content incorporated into summary."@en .

pao:ProjectScope a owl:NamedIndividual,
        pao:MemoryScope ;
    rdfs:label "project scope"@en ;
    skos:definition "Memory scope: visible across sessions within a project."@en .

pao:Public a owl:NamedIndividual,
        pao:SensitivityLevel ;
    rdfs:label "public"@en ;
    skos:definition "Sensitivity level: unrestricted data."@en .

pao:RateLimited a owl:NamedIndividual,
        pao:FailureType ;
    rdfs:label "rate limited"@en ;
    skos:definition "Failure type: the request was rejected due to rate limiting."@en .

pao:Reconnecting a owl:NamedIndividual,
        pao:ConnectionStatus ;
    rdfs:label "reconnecting"@en ;
    skos:definition "Connection status: the connection is attempting to reconnect."@en .

pao:Reject a owl:NamedIndividual,
        pao:CommunicativeFunction ;
    rdfs:label "reject"@en ;
    skos:definition "Communicative function: rejecting a proposition."@en .

pao:Rejected a owl:NamedIndividual,
        pao:CheckpointDecision ;
    rdfs:label "rejected"@en ;
    skos:definition "Checkpoint decision: the task was rejected."@en .

pao:Request a owl:NamedIndividual,
        pao:CommunicativeFunction ;
    rdfs:label "request"@en ;
    skos:definition "Communicative function: requesting action or information."@en .

pao:RequireApproval a owl:NamedIndividual,
        pao:AuthorizationDecision ;
    rdfs:label "require approval"@en ;
    skos:definition "Authorization decision: the operation requires human approval."@en .

pao:Restricted a owl:NamedIndividual,
        pao:SensitivityLevel ;
    rdfs:label "restricted"@en ;
    skos:definition "Sensitivity level: highly sensitive data requiring special controls."@en .

pao:Restrictive a owl:NamedIndividual,
        pao:PermissionMode ;
    rdfs:label "restrictive"@en ;
    skos:definition "Permission mode: tools are denied unless explicitly allowed."@en .

pao:SessionScope a owl:NamedIndividual,
        pao:MemoryScope ;
    rdfs:label "session scope"@en ;
    skos:definition "Memory scope: visible only within a single session."@en .

pao:Standard a owl:NamedIndividual,
        pao:PermissionMode ;
    rdfs:label "standard"@en ;
    skos:definition "Permission mode: tools require explicit approval."@en .

pao:Summarized a owl:NamedIndividual,
        pao:ItemFate ;
    rdfs:label "summarized"@en ;
    skos:definition "Item fate: partially represented in summary."@en .

pao:SystemSource a owl:NamedIndividual,
        pao:MemorySource ;
    rdfs:label "system source"@en ;
    skos:definition "Memory source: originated from system processes."@en .

pao:TextBlock a owl:NamedIndividual,
        pao:ContentBlockType ;
    rdfs:label "text block"@en ;
    skos:definition "Content block type: plain text content."@en .

pao:Timeout a owl:NamedIndividual,
        pao:FailureType ;
    rdfs:label "timeout"@en ;
    skos:definition "Failure type: the operation exceeded its allowed time limit."@en .

pao:ToolResultBlock a owl:NamedIndividual,
        pao:ContentBlockType ;
    rdfs:label "tool result block"@en ;
    skos:definition "Content block type: tool invocation result output."@en .

pao:ToolUseBlock a owl:NamedIndividual,
        pao:ContentBlockType ;
    rdfs:label "tool use block"@en ;
    skos:definition "Content block type: a tool invocation request."@en .

pao:UserPreference a owl:NamedIndividual,
        pao:ClaimType ;
    rdfs:label "user preference"@en ;
    skos:definition "A claim type indicating the claim records a user preference."@en .

pao:UserRole a owl:NamedIndividual,
        pao:AgentRole ;
    rdfs:label "user role"@en ;
    skos:definition "The role of the human user in a conversation."@en .

pao:UserSource a owl:NamedIndividual,
        pao:MemorySource ;
    rdfs:label "user source"@en ;
    skos:definition "Memory source: originated from user input."@en .

pao:VoiceChannel a owl:NamedIndividual,
        pao:ChannelType ;
    rdfs:label "voice channel"@en ;
    skos:definition "Channel type: voice-based interaction."@en .

pao:WebChat a owl:NamedIndividual,
        pao:ChannelType ;
    rdfs:label "web chat"@en ;
    skos:definition "Channel type: web-based chat interface."@en .

pao:AuthorizationDecision owl:equivalentClass [ owl:oneOf ( pao:Allow pao:Deny pao:RequireApproval ) ] .

pao:CheckpointDecision owl:equivalentClass [ owl:oneOf ( pao:Approved pao:Rejected pao:Deferred ) ] .

pao:MemoryScope owl:equivalentClass [ owl:oneOf ( pao:SessionScope pao:ProjectScope pao:GlobalScope ) ] .

pao:MemorySource owl:equivalentClass [ owl:oneOf ( pao:UserSource pao:SystemSource pao:AgentSource ) ] .

pao:PermissionMode owl:equivalentClass [ owl:oneOf ( pao:Permissive pao:Standard pao:Restrictive ) ] .

pao:SessionStatus owl:equivalentClass [ owl:oneOf ( pao:Active pao:Ended pao:Interrupted ) ] .

pao:ConnectionStatus owl:equivalentClass [ owl:oneOf ( pao:Open pao:Closed pao:Reconnecting pao:Failed ) ] .

pao:ContentBlockType owl:equivalentClass [ owl:oneOf ( pao:TextBlock pao:ToolUseBlock pao:ToolResultBlock pao:ImageBlock ) ] .

pao:IntegrationStatus owl:equivalentClass [ owl:oneOf ( pao:Connected pao:Disconnected pao:Error pao:Initializing ) ] .

pao:ItemFate owl:equivalentClass [ owl:oneOf ( pao:Preserved pao:Dropped pao:Summarized pao:Archived ) ] .

pao:SensitivityLevel owl:equivalentClass [ owl:oneOf ( pao:Public pao:Internal pao:Confidential pao:Restricted ) ] .

pao:TaskStatus owl:equivalentClass [ owl:oneOf ( pao:Pending pao:InProgress pao:Completed pao:Blocked ) ] .

pao:ChannelType owl:equivalentClass [ owl:oneOf ( pao:CLI pao:Messaging pao:WebChat pao:APIChannel pao:VoiceChannel pao:EmailChannel ) ] .

pao:CommunicativeFunction owl:equivalentClass [ owl:oneOf ( pao:Inform pao:Request pao:Confirm pao:Clarify pao:Accept pao:Reject ) ] .

pao:FailureType owl:equivalentClass [ owl:oneOf ( pao:Timeout pao:AuthenticationFailure pao:RateLimited pao:DependencyFailure pao:ConfigurationError pao:NetworkError ) ] .

[] a owl:AllDifferent ;
    owl:distinctMembers ( pao:Pending pao:InProgress pao:Completed pao:Blocked ) .

[] a owl:AllDifferent ;
    owl:distinctMembers ( pao:UserSource pao:SystemSource pao:AgentSource ) .

[] a owl:AllDifferent ;
    owl:distinctMembers ( pao:Connected pao:Disconnected pao:Error pao:Initializing ) .

[] a owl:AllDifferent ;
    owl:distinctMembers ( pao:Timeout pao:AuthenticationFailure pao:RateLimited pao:DependencyFailure pao:ConfigurationError pao:NetworkError ) .

[] a owl:AllDifferent ;
    owl:distinctMembers ( pao:CLI pao:Messaging pao:WebChat pao:APIChannel pao:VoiceChannel pao:EmailChannel ) .

[] a owl:AllDifferent ;
    owl:distinctMembers ( pao:Open pao:Closed pao:Reconnecting pao:Failed ) .

[] a owl:AllDifferent ;
    owl:distinctMembers ( pao:TextBlock pao:ToolUseBlock pao:ToolResultBlock pao:ImageBlock ) .

[] a owl:AllDifferent ;
    owl:distinctMembers ( pao:Public pao:Internal pao:Confidential pao:Restricted ) .

[] a owl:AllDifferent ;
    owl:distinctMembers ( pao:Allow pao:Deny pao:RequireApproval ) .

[] a owl:AllDifferent ;
    owl:distinctMembers ( pao:Preserved pao:Dropped pao:Summarized pao:Archived ) .

[] a owl:AllDifferent ;
    owl:distinctMembers ( pao:Approved pao:Rejected pao:Deferred ) .

[] a owl:AllDifferent ;
    owl:distinctMembers ( pao:Compliant pao:NonCompliant ) .

[] a owl:AllDifferent ;
    owl:distinctMembers ( pao:UserPreference ) .

[] a owl:AllDifferent ;
    owl:distinctMembers ( pao:SessionScope pao:ProjectScope pao:GlobalScope ) .

[] a owl:AllDifferent ;
    owl:distinctMembers ( pao:AssistantRole pao:UserRole ) .

[] a owl:AllDifferent ;
    owl:distinctMembers ( pao:Active pao:Ended pao:Interrupted ) .

[] a owl:AllDifferent ;
    owl:distinctMembers ( pao:Inform pao:Request pao:Confirm pao:Clarify pao:Accept pao:Reject ) .

[] a owl:AllDifferent ;
    owl:distinctMembers ( pao:Permissive pao:Standard pao:Restrictive ) .
