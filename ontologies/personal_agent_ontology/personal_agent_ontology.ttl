    rdfs:subClassOf pao:Status ;
    skos:definition "A status class whose individuals classify the type of a claim."@en .

pao:ClarificationRequest a owl:Class ;
    rdfs:label "clarification request"@en ;
    obo:IAO_0000115 "A prov:Entity that records a request for additional information to resolve ambiguity."@en ;
