pao:ServiceResourceCapability a owl:Class ;
    rdfs:label "service resource capability"@en ;
    obo:IAO_0000115 "A service capability that provides a data resource for agent access."@en ;
    rdfs:subClassOf pao:ServiceCapability ;
    skos:definition "A service capability that provides a data resource for agent access."@en .

pao:ServiceToolCapability a owl:Class ;
    rdfs:label "service tool capability"@en ;
    obo:IAO_0000115 "A service capability that provides a tool for agent invocation."@en ;
    rdfs:subClassOf pao:ServiceCapability ;
    skos:definition "A service capability that provides a tool for agent invocation."@en .

pao:SessionStatus a owl:Class ;
    rdfs:label "session status"@en ;
    obo:IAO_0000115 "A status applicable to sessions indicating whether the session is active, ended, or interrupted."@en ;
    rdfs:subClassOf pao:Status ;
    skos:definition "A status applicable to sessions indicating whether the session is active, ended, or interrupted."@en .

pao:WorkingMemory a owl:Class ;
    rdfs:label "working memory"@en ;
    obo:IAO_0000115 "A memory tier that holds information currently active in the agent's context window."@en ;
    rdfs:subClassOf pao:MemoryTier ;
    skos:definition "A memory tier that holds information currently active in the agent's context window."@en .

pao:appliesTo a owl:ObjectProperty ;
    rdfs:label "applies to"@en ;
    obo:IAO_0000115 "Links a policy or constraint to the agent it governs."@en ;
    rdfs:domain prov:Entity ;
    rdfs:range pao:Agent ;
    skos:definition "Links a policy or constraint to the agent it governs."@en .

pao:hasMember a owl:ObjectProperty ;
    rdfs:label "has member"@en ;
    obo:IAO_0000115 "Links an organization to its member agents."@en ;
    rdfs:domain pao:Organization ;
    rdfs:range pao:Agent ;
    skos:definition "Links an organization to its member agents."@en .

pao:hasPart a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "has part"@en ;
    obo:IAO_0000115 "A transitive relation linking a whole to one of its parts."@en ;
    rdfs:domain owl:Thing ;
    rdfs:range owl:Thing ;
    skos:definition "A transitive relation linking a whole to one of its parts."@en .

pao:inSession a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "in session"@en ;
    obo:IAO_0000115 "Links an event to its containing session."@en ;
    rdfs:domain pao:Event ;
    rdfs:range pao:Session ;
    skos:definition "Links an event to its containing session."@en .

pao:partOfConversation a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "part of conversation"@en ;
    obo:IAO_0000115 "Links a session to the conversation it is a temporal part of."@en ;
    rdfs:domain pao:Event ;
    rdfs:range pao:Conversation ;
    rdfs:subPropertyOf pao:partOf ;
    skos:definition "Links a session to the conversation it is a temporal part of."@en .

pao:performedBy a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "performed by"@en ;
    obo:IAO_0000115 "Links an action to the agent that intentionally performed it."@en ;
    rdfs:domain pao:Action ;
    rdfs:range pao:Agent ;
    rdfs:subPropertyOf pao:hasParticipant ;
    skos:definition "Links an action to the agent that intentionally performed it."@en .

pao:sharedAcrossAgents a owl:ObjectProperty ;
    rdfs:label "shared across agents"@en ;
    obo:IAO_0000115 "Links a shared memory artifact to an agent that has access to it."@en ;
    rdfs:domain pao:SharedMemoryArtifact ;
    rdfs:range pao:Agent ;
    skos:definition "Links a shared memory artifact to an agent that has access to it."@en .

pao:writesByAgent a owl:ObjectProperty ;
    rdfs:label "writes by agent"@en ;
    obo:IAO_0000115 "Links a memory write conflict to an agent involved in the concurrent write."@en ;
    rdfs:domain pao:MemoryWriteConflict ;
    rdfs:range pao:Agent ;
    skos:definition "Links a memory write conflict to an agent involved in the concurrent write."@en .

pao:Action a owl:Class ;
    rdfs:label "action"@en ;
    obo:IAO_0000115 "An event that is intentionally caused by an agent to affect the environment or internal state."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty pao:performedBy ;
            owl:someValuesFrom pao:Agent ],
        pao:Event ;
    skos:definition "An event that is intentionally caused by an agent to affect the environment or internal state."@en .

pao:AuthorizationDecision a owl:Class ;
    rdfs:label "authorization decision"@en ;
    obo:IAO_0000115 "A status class whose individuals classify authorization outcomes."@en ;
    rdfs:subClassOf pao:Status ;
    skos:definition "A status class whose individuals classify authorization outcomes."@en .

pao:CapabilityDiscoveryEvent a owl:Class ;
    rdfs:label "capability discovery event"@en ;
    obo:IAO_0000115 "An event in which an agent discovers what capabilities an external service exposes."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty pao:discoveredCapability ;
            owl:someValuesFrom pao:ServiceCapability ],
        [ a owl:Restriction ;
            owl:onProperty pao:discoveryAgainstService ;
            owl:someValuesFrom pao:ExternalService ],
        pao:Event ;
    skos:definition "An event in which an agent discovers what capabilities an external service exposes."@en .

pao:ChannelType a owl:Class ;
    rdfs:label "channel type"@en ;
    obo:IAO_0000115 "A status class whose individuals classify the type of communication channel."@en ;
    rdfs:subClassOf pao:Status ;
    skos:definition "A status class whose individuals classify the type of communication channel."@en .

pao:Checkpoint a owl:Class ;
    rdfs:label "checkpoint"@en ;
    obo:IAO_0000115 "A GDC marking a task decision point where human approval may be required."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty pao:checkpointDecision ;
            owl:someValuesFrom pao:CheckpointDecision ],
        [ a owl:Restriction ;
            owl:onProperty pao:checkpointForTask ;
            owl:someValuesFrom pao:Task ],
        obo:BFO_0000031,
        prov:Entity ;
    skos:definition "A GDC marking a task decision point where human approval may be required."@en .

pao:CheckpointDecision a owl:Class ;
    rdfs:label "checkpoint decision"@en ;
    obo:IAO_0000115 "A status class whose individuals classify checkpoint decision outcomes."@en ;
    rdfs:subClassOf pao:Status ;
    skos:definition "A status class whose individuals classify checkpoint decision outcomes."@en .

pao:CommonGround a owl:Class ;
    rdfs:label "common ground"@en ;
    obo:IAO_0000115 "A prov:Entity that represents the accumulated shared knowledge state between conversation participants."@en ;
    rdfs:subClassOf obo:BFO_0000031,
        prov:Entity ;
    skos:definition "A prov:Entity that represents the accumulated shared knowledge state between conversation participants."@en .

pao:CommunicativeFunction a owl:Class ;
    rdfs:label "communicative function"@en ;
    obo:IAO_0000115 "A status class whose individuals classify the communicative purpose of a dialog act."@en ;
    rdfs:subClassOf pao:Status ;
    skos:definition "A status class whose individuals classify the communicative purpose of a dialog act."@en .

pao:ComplianceStatus a owl:Class ;
    rdfs:label "compliance status"@en ;
    obo:IAO_0000115 "A status indicating whether a tool invocation complied with applicable permission policies."@en ;
    rdfs:subClassOf pao:Status ;
    skos:definition "A status indicating whether a tool invocation complied with applicable permission policies."@en .

pao:ConnectionStatus a owl:Class ;
    rdfs:label "connection status"@en ;
    obo:IAO_0000115 "A status class whose individuals classify runtime connection state."@en ;
    rdfs:subClassOf pao:Status ;
    skos:definition "A status class whose individuals classify runtime connection state."@en .

pao:ContentBlockType a owl:Class ;
    rdfs:label "content block type"@en ;
    obo:IAO_0000115 "A status class whose individuals classify the type of a content block."@en ;
    rdfs:subClassOf pao:Status ;
    skos:definition "A status class whose individuals classify the type of a content block."@en .

pao:DialogAct a owl:Class ;
    rdfs:label "dialog act"@en ;
    obo:IAO_0000115 "A prov:Entity that represents the pragmatic classification of a turn's communicative intent."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty pao:hasCommunicativeFunction ;
            owl:someValuesFrom pao:CommunicativeFunction ],
        obo:BFO_0000031,
        prov:Entity ;
    skos:definition "A prov:Entity that represents the pragmatic classification of a turn's communicative intent."@en .

pao:Episode a owl:Class ;
    rdfs:label "episode"@en ;
    obo:IAO_0000115 "A memory item that records a temporally bounded cluster of related events."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty pao:storedIn ;
            owl:someValuesFrom pao:MemoryTier ],
        [ a owl:Restriction ;
            owl:onProperty pao:hasTemporalExtent ;
            owl:someValuesFrom time:Interval ],
        [ a owl:Restriction ;
            owl:allValuesFrom pao:EpisodicMemory ;
            owl:onProperty pao:storedIn ],
        [ a owl:Restriction ;
            owl:onProperty pao:hasTopic ;
            owl:someValuesFrom skos:Concept ],
        pao:MemoryItem ;
    skos:definition "A memory item that records a temporally bounded cluster of related events."@en .

pao:EpisodicMemory a owl:Class ;
    rdfs:label "episodic memory"@en ;
    obo:IAO_0000115 "A memory tier that stores time-situated experiences and interaction histories."@en ;
    rdfs:subClassOf pao:MemoryTier ;
    skos:definition "A memory tier that stores time-situated experiences and interaction histories."@en .

pao:GroundingAct a owl:Class ;
    rdfs:label "grounding act"@en ;
    obo:IAO_0000115 "An event in which a participant contributes evidence to the common ground of a conversation."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty pao:contributesToCommonGround ;
            owl:someValuesFrom pao:CommonGround ],
        pao:Event ;
    skos:definition "An event in which a participant contributes evidence to the common ground of a conversation."@en .

pao:HookExecution a owl:Class ;
    rdfs:label "hook execution"@en ;
    obo:IAO_0000115 "An event in which a hook intercepts and processes a tool invocation."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty pao:interceptsInvocation ;
            owl:someValuesFrom pao:ToolInvocation ],
        pao:Event ;
    skos:definition "An event in which a hook intercepts and processes a tool invocation."@en .

pao:IntegrationStatus a owl:Class ;
    rdfs:label "integration status"@en ;
    obo:IAO_0000115 "A status class whose individuals classify the operational state of an integration."@en ;
    rdfs:subClassOf pao:Status ;
    skos:definition "A status class whose individuals classify the operational state of an integration."@en .

pao:Intention a owl:Class ;
    rdfs:label "intention"@en ;
    obo:IAO_0000115 "A GDC representing an agent's commitment to execute a plan (BDI model)."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty pao:derivedFromGoal ;
            owl:someValuesFrom pao:Goal ],
        [ a owl:Restriction ;
            owl:onProperty pao:intendedBy ;
            owl:someValuesFrom pao:Agent ],
        obo:BFO_0000031,
        prov:Entity ;
    skos:definition "A GDC representing an agent's commitment to execute a plan (BDI model)."@en .

pao:ItemFate a owl:Class ;
    rdfs:label "item fate"@en ;
    obo:IAO_0000115 "A status class whose individuals classify what happened to an item during compaction."@en ;
    rdfs:subClassOf pao:Status ;
    skos:definition "A status class whose individuals classify what happened to an item during compaction."@en .

pao:MemoryBlock a owl:Class ;
    rdfs:label "memory block"@en ;
    obo:IAO_0000115 "A memory item that stores structured key-value data (Letta core memory pattern)."@en ;
    rdfs:subClassOf pao:MemoryItem ;
    skos:definition "A memory item that stores structured key-value data (Letta core memory pattern)."@en .

pao:Message a owl:Class ;
    rdfs:label "message"@en ;
    obo:IAO_0000115 "A generically dependent continuant that is the textual or structured content of a conversational turn."@en ;
    rdfs:subClassOf obo:BFO_0000031,
        prov:Entity ;
    skos:definition "A generically dependent continuant that is the textual or structured content of a conversational turn."@en .

pao:Organization a owl:Class ;
    rdfs:label "organization"@en ;
    obo:IAO_0000115 "An agent that is a formal body or group of people."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty pao:hasMember ;
            owl:someValuesFrom pao:Agent ],
        obo:BFO_0000030,
        pao:Agent ;
    skos:definition "An agent that is a formal body or group of people."@en .

pao:PermissionMode a owl:Class ;
    rdfs:label "permission mode"@en ;
    obo:IAO_0000115 "A GDC specifying the permission enforcement level under which an agent operates."@en ;
    rdfs:subClassOf pao:Status ;
    skos:definition "A GDC specifying the permission enforcement level under which an agent operates."@en .

pao:Persona a owl:Class ;
    rdfs:label "persona"@en ;
    obo:IAO_0000115 "A GDC that specifies an agent's configured identity behavior and system prompt."@en ;
    rdfs:subClassOf obo:BFO_0000031,
        prov:Entity ;
    skos:definition "A GDC that specifies an agent's configured identity behavior and system prompt."@en .

pao:ReplanEvent a owl:Class ;
    rdfs:label "replan event"@en ;
    obo:IAO_0000115 "An event in which an agent generates a new plan after a failure."@en ;
    rdfs:subClassOf pao:Event ;
    skos:definition "An event in which an agent generates a new plan after a failure."@en .

pao:RetryAttempt a owl:Class ;
    rdfs:label "retry attempt"@en ;
    obo:IAO_0000115 "An event representing a retry of a failed operation."@en ;
    rdfs:subClassOf pao:Event ;
    skos:definition "An event representing a retry of a failed operation."@en .

pao:RollbackEvent a owl:Class ;
    rdfs:label "rollback event"@en ;
    obo:IAO_0000115 "An event in which an agent reverts changes made by a failed operation."@en ;
    rdfs:subClassOf pao:Event ;
    skos:definition "An event in which an agent reverts changes made by a failed operation."@en .

pao:SandboxPolicy a owl:Class ;
    rdfs:label "sandbox policy"@en ;
    obo:IAO_0000115 "A GDC specifying filesystem and network restrictions imposed on an agent."@en ;
    rdfs:subClassOf obo:BFO_0000031,
        prov:Entity ;
    skos:definition "A GDC specifying filesystem and network restrictions imposed on an agent."@en .

pao:SensitivityLevel a owl:Class ;
    rdfs:label "sensitivity level"@en ;
    obo:IAO_0000115 "A status class whose individuals classify privacy sensitivity."@en ;
    rdfs:subClassOf pao:Status ;
    skos:definition "A status class whose individuals classify privacy sensitivity."@en .

pao:TaskStatus a owl:Class ;
    rdfs:label "task status"@en ;
    obo:IAO_0000115 "A status applicable to tasks indicating progress from pending through completion."@en ;
    rdfs:subClassOf pao:Status ;
    skos:definition "A status applicable to tasks indicating progress from pending through completion."@en .

pao:ToolInvocationGroup a owl:Class ;
    rdfs:label "tool invocation group"@en ;
    obo:IAO_0000115 "A prov:Entity that groups tool invocations executed in parallel within a single turn."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty pao:groupedInTurn ;
            owl:someValuesFrom pao:Turn ],
        obo:BFO_0000031,
        prov:Entity ;
    skos:definition "A prov:Entity that groups tool invocations executed in parallel within a single turn."@en .

pao:ToolResult a owl:Class ;
    rdfs:label "tool result"@en ;
    obo:IAO_0000115 "A prov:Entity that represents the typed output artifact produced by a tool invocation."@en ;
    rdfs:subClassOf obo:BFO_0000031,
        prov:Entity ;
    skos:definition "A prov:Entity that represents the typed output artifact produced by a tool invocation."@en .

pao:hasTemporalExtent a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "has temporal extent"@en ;
    obo:IAO_0000115 "Links an event to its temporal extent."@en ;
    rdfs:range time:TemporalEntity ;
    skos:definition "Links an event to its temporal extent."@en .

pao:partOf a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "part of"@en ;
    obo:IAO_0000115 "A transitive relation linking an entity to a whole it is part of."@en ;
    rdfs:domain owl:Thing ;
    rdfs:range owl:Thing ;
    owl:inverseOf pao:hasPart ;
    skos:definition "A transitive relation linking an entity to a whole it is part of."@en .

pao:AuditLog a owl:Class ;
    rdfs:label "audit log"@en ;
    obo:IAO_0000115 "A GDC that serves as a container for audit entries."@en ;
    rdfs:subClassOf obo:BFO_0000031,
        prov:Entity ;
    skos:definition "A GDC that serves as a container for audit entries."@en .

pao:Claim a owl:Class ;
    rdfs:label "claim"@en ;
    obo:IAO_0000115 "A memory item that represents an agent-held proposition with associated confidence, evidence, and provenance metadata."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty pao:storedIn ;
            owl:someValuesFrom pao:MemoryTier ],
        [ a owl:Restriction ;
            owl:onProperty pao:aboutAgent ;
            owl:someValuesFrom pao:Agent ],
        pao:MemoryItem ;
    skos:definition "A memory item that represents an agent-held proposition with associated confidence, evidence, and provenance metadata."@en .

pao:CommunicationChannel a owl:Class ;
    rdfs:label "communication channel"@en ;
    obo:IAO_0000115 "A GDC that specifies a configured communication endpoint through which agent-user dialogue occurs."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty pao:hasChannelType ;
            owl:someValuesFrom pao:ChannelType ],
        obo:BFO_0000031,
        prov:Entity ;
    skos:definition "A GDC that specifies a configured communication endpoint through which agent-user dialogue occurs."@en .

pao:ConsentRecord a owl:Class ;
    rdfs:label "consent record"@en ;
    obo:IAO_0000115 "A GDC that records a data subject's consent for a specific purpose."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty pao:consentSubject ;
            owl:someValuesFrom pao:Agent ],
        obo:BFO_0000031,
        prov:Entity ;
    skos:definition "A GDC that records a data subject's consent for a specific purpose."@en .

pao:ContentBlock a owl:Class ;
    rdfs:label "content block"@en ;
    obo:IAO_0000115 "A prov:Entity that represents a typed segment of a message's content."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty pao:hasContentBlockType ;
            owl:someValuesFrom pao:ContentBlockType ],
        obo:BFO_0000031,
        prov:Entity ;
    skos:definition "A prov:Entity that represents a typed segment of a message's content."@en .

pao:MemoryWriteConflict a owl:Class ;
    rdfs:label "memory write conflict"@en ;
    obo:IAO_0000115 "An event in which multiple agents attempt concurrent writes to the same shared memory artifact."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty pao:conflictOnArtifact ;
            owl:someValuesFrom pao:SharedMemoryArtifact ],
        [ a owl:Restriction ;
            owl:onProperty pao:writesByAgent ;
            owl:someValuesFrom pao:Agent ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
            owl:onClass pao:Agent ;
            owl:onProperty pao:writesByAgent ],
        pao:Event ;
    skos:definition "An event in which multiple agents attempt concurrent writes to the same shared memory artifact."@en .

pao:ServiceConnection a owl:Class ;
    rdfs:label "service connection"@en ;
    obo:IAO_0000115 "A GDC representing the runtime connection between an agent and an external service."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty pao:hasConnectionStatus ;
            owl:someValuesFrom pao:ConnectionStatus ],
        [ a owl:Restriction ;
            owl:onProperty pao:connectsToService ;
            owl:someValuesFrom pao:ExternalService ],
        obo:BFO_0000031,
        prov:Entity ;
    skos:definition "A GDC representing the runtime connection between an agent and an external service."@en .

pao:SharedMemoryArtifact a owl:Class ;
    rdfs:label "shared memory artifact"@en ;
    obo:IAO_0000115 "A prov:Entity that represents a memory artifact accessible to multiple agents for shared read/write."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty pao:sharedAcrossAgents ;
            owl:someValuesFrom pao:Agent ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
            owl:onClass pao:Agent ;
            owl:onProperty pao:sharedAcrossAgents ],
        obo:BFO_0000031,
        prov:Entity ;
    skos:definition "A prov:Entity that represents a memory artifact accessible to multiple agents for shared read/write."@en .

pao:hasParticipant a owl:ObjectProperty ;
    rdfs:label "has participant"@en ;
    obo:IAO_0000115 "Links an event to an agent that participates in it."@en ;
    rdfs:domain pao:Event ;
    rdfs:range pao:Agent ;
    owl:inverseOf pao:participatesIn ;
    skos:definition "Links an event to an agent that participates in it."@en .

pao:AuditEntry a owl:Class ;
    rdfs:label "audit entry"@en ;
    obo:IAO_0000115 "A GDC recording an authorization decision for a tool invocation with rationale."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty pao:recordsDecision ;
            owl:someValuesFrom pao:AuthorizationDecision ],
        [ a owl:Restriction ;
            owl:onProperty pao:auditForInvocation ;
            owl:someValuesFrom pao:ToolInvocation ],
        [ a owl:Restriction ;
            owl:onProperty pao:writtenToAuditLog ;
            owl:someValuesFrom pao:AuditLog ],
        obo:BFO_0000031,
        prov:Entity ;
    skos:definition "A GDC recording an authorization decision for a tool invocation with rationale."@en .

pao:CompactionDisposition a owl:Class ;
    rdfs:label "compaction disposition"@en ;
    obo:IAO_0000115 "An information artifact recording the fate of an individual item during a compaction event."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty pao:hasItemFate ;
            owl:someValuesFrom pao:ItemFate ],
        [ a owl:Restriction ;
            owl:onProperty pao:dispositionOf ;
            owl:someValuesFrom prov:Entity ],
        obo:BFO_0000031,
        prov:Entity ;
    skos:definition "An information artifact recording the fate of an individual item during a compaction event."@en .

pao:CompactionEvent a owl:Class ;
    rdfs:label "compaction event"@en ;
    obo:IAO_0000115 "A process in which an agent's context window is compressed by summarizing prior turns."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty pao:inConversation ;
            owl:someValuesFrom pao:Conversation ],
        [ a owl:Restriction ;
            owl:onProperty pao:producedSummary ;
            owl:someValuesFrom pao:MemoryItem ],
        [ a owl:Restriction ;
            owl:onProperty pao:compactedItem ;
            owl:someValuesFrom prov:Entity ],
        pao:Event ;
    skos:definition "A process in which an agent's context window is compressed by summarizing prior turns."@en .

pao:ContextWindow a owl:Class ;
    rdfs:label "context window"@en ;
    obo:IAO_0000115 "A GDC representing the finite attention resource of an AI agent session with token capacity and usage tracking."@en ;
    rdfs:subClassOf obo:BFO_0000031,
        prov:Entity ;
    skos:definition "A GDC representing the finite attention resource of an AI agent session with token capacity and usage tracking."@en .

pao:Hook a owl:Class ;
    rdfs:label "hook"@en ;
    obo:IAO_0000115 "A GDC representing a configured interceptor that can modify or block tool invocations."@en ;
    rdfs:subClassOf obo:BFO_0000031,
        prov:Entity ;
    skos:definition "A GDC representing a configured interceptor that can modify or block tool invocations."@en .

pao:Plan a owl:Class ;
    rdfs:label "plan"@en ;
    obo:IAO_0000115 "A generically dependent continuant that specifies an ordered sequence of intended actions to achieve a goal."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty pao:achievesGoal ;
            owl:someValuesFrom pao:Goal ],
        prov:Plan ;
    skos:definition "A generically dependent continuant that specifies an ordered sequence of intended actions to achieve a goal."@en .

pao:RetentionPolicy a owl:Class ;
    rdfs:label "retention policy"@en ;
    obo:IAO_0000115 "A GDC specifying how long memory items should be retained before deletion."@en ;
    rdfs:subClassOf obo:BFO_0000031,
        prov:Entity ;
    skos:definition "A GDC specifying how long memory items should be retained before deletion."@en .

pao:storedIn a owl:ObjectProperty ;
    rdfs:label "stored in"@en ;
    obo:IAO_0000115 "Links a memory item to the memory tier where it is stored."@en ;
    rdfs:range pao:MemoryTier ;
    owl:inverseOf pao:stores ;
    skos:definition "Links a memory item to the memory tier where it is stored."@en .

pao:Conversation a owl:Class ;
    rdfs:label "conversation"@en ;
    obo:IAO_0000115 "A process consisting of a coherent thread of dialogue between participants that may span multiple sessions."@en ;
    rdfs:subClassOf pao:Event ;
    owl:hasKey ( pao:hasConversationId ) ;
    skos:definition "A process consisting of a coherent thread of dialogue between participants that may span multiple sessions."@en .

pao:ErrorRecoveryEvent a owl:Class ;
    rdfs:label "error recovery event"@en ;
    obo:IAO_0000115 "An event in which an agent initiates recovery after a failure."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty pao:recoveringFrom ;
            owl:someValuesFrom pao:ToolInvocation ],
        pao:Event ;
    skos:definition "An event in which an agent initiates recovery after a failure."@en .

pao:Goal a owl:Class ;
    rdfs:label "goal"@en ;
    obo:IAO_0000115 "A generically dependent continuant that specifies a desired state an agent works toward."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty pao:pursuedBy ;
            owl:someValuesFrom pao:Agent ],
        [ a owl:Restriction ;
            owl:onProperty pao:hasStatus ;
            owl:someValuesFrom pao:TaskStatus ],
        obo:BFO_0000031,
        prov:Entity ;
    skos:definition "A generically dependent continuant that specifies a desired state an agent works toward."@en .

pao:Integration a owl:Class ;
    rdfs:label "integration"@en ;
    obo:IAO_0000115 "A GDC that represents a configured connection to an external service that provides one or more tools."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty pao:hasIntegrationStatus ;
            owl:someValuesFrom pao:IntegrationStatus ],
        [ a owl:Restriction ;
            owl:onProperty pao:providesTool ;
            owl:someValuesFrom pao:ToolDefinition ],
        obo:BFO_0000031,
        prov:Entity ;
    skos:definition "A GDC that represents a configured connection to an external service that provides one or more tools."@en .

pao:MemoryOperation a owl:Class ;
    rdfs:label "memory operation"@en ;
    obo:IAO_0000115 "A process that acts on memory items to encode, retrieve, consolidate, or remove them."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty pao:operatesOn ;
            owl:someValuesFrom pao:MemoryItem ],
        pao:Event ;
    owl:disjointUnionOf ( pao:Encoding pao:Retrieval pao:Consolidation pao:Forgetting pao:Rehearsal ) ;
    skos:definition "A process that acts on memory items to encode, retrieve, consolidate, or remove them."@en .

pao:PermissionPolicy a owl:Class ;
    rdfs:label "permission policy"@en ;
    obo:IAO_0000115 "A generically dependent continuant that specifies rules governing what actions an agent is permitted or forbidden to perform."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty pao:grantsPermission ;
            owl:someValuesFrom odrl:Permission ],
        [ a owl:Restriction ;
            owl:onProperty pao:restrictsToolUse ;
            owl:someValuesFrom pao:ToolDefinition ],
        [ a owl:Restriction ;
            owl:onProperty pao:appliesTo ;
            owl:someValuesFrom pao:Agent ],
        obo:BFO_0000031,
        odrl:Policy ;
    skos:definition "A generically dependent continuant that specifies rules governing what actions an agent is permitted or forbidden to perform."@en .

pao:Turn a owl:Class ;
    rdfs:label "turn"@en ;
    obo:IAO_0000115 "A process that is a single contribution by one participant in a conversation."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty pao:partOfConversation ;
            owl:someValuesFrom pao:Conversation ],
        [ a owl:Restriction ;
            owl:onProperty pao:partOfSession ;
            owl:someValuesFrom pao:Session ],
        [ a owl:Restriction ;
            owl:onProperty pao:hasParticipant ;
            owl:someValuesFrom pao:Agent ],
        [ a owl:Restriction ;
            owl:onClass pao:Agent ;
            owl:onProperty pao:hasParticipant ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:nonNegativeInteger ;
            owl:onProperty pao:hasTurnIndex ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        pao:Event ;
    skos:definition "A process that is a single contribution by one participant in a conversation."@en .

pao:hasStatus a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "has status"@en ;
    obo:IAO_0000115 "Links an entity to its current status value."@en ;
    rdfs:domain owl:Thing ;
    rdfs:range pao:Status ;
    skos:definition "Links an entity to its current status value."@en .

pao:AIAgent a owl:Class ;
    rdfs:label "ai agent"@en ;
    obo:IAO_0000115 "An agent that is a software system capable of autonomous decision-making and tool use."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty pao:hasPersona ;
            owl:someValuesFrom pao:Persona ],
        [ a owl:Restriction ;
            owl:onProperty pao:hasExternalService ;
            owl:someValuesFrom pao:ExternalService ],
        [ a owl:Restriction ;
            owl:onProperty pao:hasIntegration ;
            owl:someValuesFrom pao:Integration ],
        [ a owl:Restriction ;
            owl:onProperty pao:hasAvailableTool ;
            owl:someValuesFrom pao:ToolDefinition ],
        [ a owl:Restriction ;
            owl:onProperty pao:operatesInMode ;
            owl:someValuesFrom pao:PermissionMode ],
        [ a owl:Restriction ;
            owl:onProperty pao:hasHook ;
            owl:someValuesFrom pao:Hook ],
        obo:BFO_0000031,
        prov:SoftwareAgent,
        pao:Agent ;
    owl:hasKey ( pao:hasAgentId ) ;
    skos:definition "An agent that is a software system capable of autonomous decision-making and tool use."@en .

pao:ServiceCapability a owl:Class ;
    rdfs:label "service capability"@en ;
    obo:IAO_0000115 "A GDC representing a capability that an external service exposes (abstract parent)."@en ;
    rdfs:subClassOf obo:BFO_0000031,
        prov:Entity ;
    owl:disjointUnionOf ( pao:ServiceToolCapability pao:ServiceResourceCapability pao:ServicePromptCapability ) ;
    skos:definition "A GDC representing a capability that an external service exposes (abstract parent)."@en .

pao:ExternalService a owl:Class ;
    rdfs:label "external service"@en ;
    obo:IAO_0000115 "A GDC that describes a configured external service with identity and transport metadata."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty pao:exposesCapability ;
            owl:someValuesFrom pao:ServiceCapability ],
        obo:BFO_0000031,
        prov:Entity ;
    skos:definition "A GDC that describes a configured external service with identity and transport metadata."@en .

pao:MemoryTier a owl:Class ;
    rdfs:label "memory tier"@en ;
    obo:IAO_0000115 "A generically dependent continuant that defines a layer in the agent's memory architecture with specific storage and access characteristics."@en ;
    rdfs:subClassOf obo:BFO_0000031,
        prov:Entity ;
    owl:disjointUnionOf ( pao:WorkingMemory pao:EpisodicMemory pao:SemanticMemory pao:ProceduralMemory ) ;
    skos:definition "A generically dependent continuant that defines a layer in the agent's memory architecture with specific storage and access characteristics."@en .

pao:StatusTransition a owl:Class ;
    rdfs:label "status transition"@en ;
    obo:IAO_0000115 "A process in which an entity's status changes from one value to another."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty pao:toStatus ;
            owl:someValuesFrom pao:Status ],
        [ a owl:Restriction ;
            owl:onProperty pao:transitionSubject ;
            owl:someValuesFrom owl:Thing ],
        [ a owl:Restriction ;
            owl:onProperty pao:fromStatus ;
            owl:someValuesFrom pao:Status ],
        pao:Event ;
    skos:definition "A process in which an entity's status changes from one value to another."@en .

pao:Task a owl:Class ;
    rdfs:label "task"@en ;
    obo:IAO_0000115 "A generically dependent continuant that is a concrete actionable work item within a plan with status and dependencies."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty pao:partOfPlan ;
            owl:someValuesFrom pao:Plan ],
        [ a owl:Restriction ;
            owl:onProperty pao:hasStatus ;
            owl:someValuesFrom pao:TaskStatus ],
        obo:BFO_0000031,
        prov:Entity ;
    skos:definition "A generically dependent continuant that is a concrete actionable work item within a plan with status and dependencies."@en .

pao:ToolDefinition a owl:Class ;
    rdfs:label "tool definition"@en ;
    obo:IAO_0000115 "A generically dependent continuant that specifies the interface, capabilities, and constraints of an available tool."@en ;
    rdfs:subClassOf obo:BFO_0000031,
        prov:Entity ;
    skos:definition "A generically dependent continuant that specifies the interface, capabilities, and constraints of an available tool."@en .

pao:Session a owl:Class ;
    rdfs:label "session"@en ;
    obo:IAO_0000115 "A process that is a bounded period of agent-user interaction within a conversation."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty pao:hasTemporalExtent ;
            owl:someValuesFrom time:Interval ],
        [ a owl:Restriction ;
            owl:onProperty pao:hasStatus ;
            owl:someValuesFrom pao:SessionStatus ],
        [ a owl:Restriction ;
            owl:onProperty pao:partOfConversation ;
            owl:someValuesFrom pao:Conversation ],
        [ a owl:Restriction ;
            owl:onProperty pao:hasParticipant ;
            owl:someValuesFrom pao:Agent ],
        pao:Event ;
    owl:hasKey ( pao:hasSessionId ) ;
    skos:definition "A process that is a bounded period of agent-user interaction within a conversation."@en .

pao:ToolInvocation a owl:Class ;
    rdfs:label "tool invocation"@en ;
    obo:IAO_0000115 "A process in which an agent requests execution of a tool by providing inputs and receiving outputs."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty pao:hasInput ;
            owl:someValuesFrom prov:Entity ],
        [ a owl:Restriction ;
            owl:onProperty pao:invokedBy ;
            owl:someValuesFrom pao:Agent ],
        [ a owl:Restriction ;
            owl:onProperty pao:governedByPolicy ;
            owl:someValuesFrom pao:PermissionPolicy ],
        [ a owl:Restriction ;
            owl:onProperty pao:hasOutput ;
            owl:someValuesFrom prov:Entity ],
        [ a owl:Restriction ;
            owl:onProperty pao:producedToolResult ;
            owl:someValuesFrom pao:ToolResult ],
        [ a owl:Restriction ;
            owl:onProperty pao:inSession ;
            owl:someValuesFrom pao:Session ],
        [ a owl:Restriction ;
            owl:onProperty pao:hasComplianceStatus ;
            owl:someValuesFrom pao:ComplianceStatus ],
        [ a owl:Restriction ;
            owl:onProperty pao:invokesTool ;
            owl:someValuesFrom pao:ToolDefinition ],
        pao:Action ;
    skos:definition "A process in which an agent requests execution of a tool by providing inputs and receiving outputs."@en .

pao:MemoryItem a owl:Class ;
    rdfs:label "memory item"@en ;
    obo:IAO_0000115 "A generically dependent continuant that is an information artifact persisted in an agent's memory system."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass pao:MemoryTier ;
            owl:onProperty pao:storedIn ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onProperty pao:storedIn ;
            owl:someValuesFrom pao:MemoryTier ],
        [ a owl:Restriction ;
            owl:onProperty prov:wasAttributedTo ;
            owl:someValuesFrom pao:Agent ],
        [ a owl:Restriction ;
            owl:onProperty pao:hasSensitivityLevel ;
            owl:someValuesFrom pao:SensitivityLevel ],
        [ a owl:Restriction ;
            owl:onProperty pao:governedByRetention ;
            owl:someValuesFrom pao:RetentionPolicy ],
        [ a owl:Restriction ;
            owl:onProperty prov:wasGeneratedBy ;
            owl:someValuesFrom prov:Activity ],
        obo:BFO_0000031,
        prov:Entity ;
    skos:definition "A generically dependent continuant that is an information artifact persisted in an agent's memory system."@en .

pao:Status a owl:Class ;
    rdfs:label "status"@en ;
    obo:IAO_0000115 "A class whose individuals represent the current state of an entity."@en ;
    rdfs:subClassOf obo:BFO_0000031,
        prov:Entity ;
    skos:definition "A class whose individuals represent the current state of an entity."@en .

pao:Event a owl:Class ;
    rdfs:label "event"@en ;
    obo:IAO_0000115 "A process that is an occurrence situated in time within the agent system."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty pao:hasTemporalExtent ;
            owl:someValuesFrom time:TemporalEntity ],
        obo:BFO_0000015,
        prov:Activity ;
    skos:definition "A process that is an occurrence situated in time within the agent system."@en .

pao:Agent a owl:Class ;
    rdfs:label "agent"@en ;
    obo:IAO_0000115 "An entity that bears responsibility for activities and can act on behalf of itself or others."@en ;
    rdfs:subClassOf prov:Agent ;
    skos:definition "An entity that bears responsibility for activities and can act on behalf of itself or others."@en .

[] a owl:AllDisjointClasses ;
    owl:members ( pao:Encoding pao:Retrieval pao:Consolidation pao:Forgetting pao:Rehearsal ) .

[] a owl:AllDisjointClasses ;
    owl:members ( pao:Action pao:Conversation pao:Session pao:Turn pao:CompactionEvent pao:ErasureEvent pao:MemoryOperation pao:Observation pao:StatusTransition pao:CapabilityDiscoveryEvent pao:HookExecution pao:ErrorRecoveryEvent pao:RetryAttempt pao:ReplanEvent pao:RollbackEvent pao:MemoryWriteConflict pao:GroundingAct ) .

[] a owl:AllDisjointClasses ;
    owl:members ( pao:ServiceToolCapability pao:ServiceResourceCapability pao:ServicePromptCapability ) .

[] a owl:AllDisjointClasses ;
    owl:members ( pao:Message pao:ToolDefinition pao:MemoryItem pao:MemoryTier pao:Goal pao:Plan pao:Task pao:PermissionPolicy pao:SafetyConstraint pao:Persona pao:Intention pao:ConsentRecord pao:RetentionPolicy pao:CompactionDisposition pao:ContextWindow pao:CommunicationChannel pao:Integration pao:ExternalService pao:ServiceConnection pao:ServiceCapability pao:SandboxPolicy pao:Hook pao:AuditLog pao:AuditEntry pao:Checkpoint pao:ToolResult pao:ToolInvocationGroup pao:ContentBlock pao:SharedMemoryArtifact pao:DialogAct pao:CommonGround pao:ClarificationRequest pao:AcceptanceEvidence ) .

[] a owl:AllDisjointClasses ;
    owl:members ( pao:SessionStatusTransition pao:TaskStatusTransition ) .

[] a owl:AllDisjointClasses ;
    owl:members ( pao:PermissionPolicy pao:SafetyConstraint pao:ConsentRecord pao:RetentionPolicy pao:SandboxPolicy pao:Hook pao:AuditLog ) .

[] a owl:AllDisjointClasses ;
    owl:members ( pao:RetryAttempt pao:ReplanEvent pao:RollbackEvent ) .

[] a owl:AllDisjointClasses ;
    owl:members ( pao:WorkingMemory pao:EpisodicMemory pao:SemanticMemory pao:ProceduralMemory ) .

[] a owl:AllDisjointClasses ;
    owl:members ( pao:SessionStatus pao:TaskStatus pao:ComplianceStatus pao:SensitivityLevel pao:ItemFate pao:ChannelType pao:IntegrationStatus pao:ConnectionStatus pao:PermissionMode pao:AuthorizationDecision pao:CheckpointDecision pao:ContentBlockType pao:MemorySource pao:MemoryScope pao:CommunicativeFunction pao:ClaimType ) .

[] a owl:AllDisjointClasses ;
    owl:members ( pao:AIAgent pao:HumanUser pao:Organization ) .

[] a owl:AllDisjointClasses ;
    owl:members ( pao:Episode pao:Claim pao:MemoryBlock ) .
