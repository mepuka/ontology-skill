            owl:onProperty pao:clarifiesTurn ;
            owl:someValuesFrom pao:Turn ],
        obo:BFO_0000031,
        prov:Entity ;
    skos:definition "A prov:Entity that records a request for additional information to resolve ambiguity."@en .

pao:Consolidation a owl:Class ;
    rdfs:label "consolidation"@en ;
