    obo:IAO_0000115 "A prov:Entity that records evidence that a participant has accepted or understood a proposition."@en ;
    rdfs:subClassOf obo:BFO_0000031,
        prov:Entity ;
    skos:definition "A prov:Entity that records evidence that a participant has accepted or understood a proposition."@en .

pao:ClaimType a owl:Class ;
    rdfs:label "claim type"@en ;
