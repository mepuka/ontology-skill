    skos:definition "A memory operation that writes new information into a memory tier."@en .

pao:ErasureEvent a owl:Class ;
    rdfs:label "erasure event"@en ;
    obo:IAO_0000115 "A process in which memory items are identified and deleted to comply with privacy requirements."@en ;
