@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix obo: <http://purl.obolibrary.org/obo/> .
@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pao: <https://purl.org/pao/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

pao: a owl:Ontology ;
    dcterms:created "2026-02-20" ;
    dcterms:creator "ontology-architect skill" ;
    dcterms:description "An OWL 2 DL ontology modeling AI agent architecture including conversations, memory systems, goals, plans, and governance."@en ;
    dcterms:license <https://spdx.org/licenses/MIT> ;
    dcterms:rights "MIT License" ;
    dcterms:title "Personal Agent Ontology"@en ;
    owl:imports pao:bfo-declarations,
        pao:foaf-declarations,
        pao:odrl-declarations,
        pao:prov-declarations,
        pao:reference-individuals,
        pao:time-declarations ;
    owl:versionIRI pao:0.6.0 ;
    owl:versionInfo "0.6.0" ;
    prov:generatedAtTime "2026-02-18T00:00:00+00:00"^^xsd:dateTime .

pao:SubAgent a owl:Class ;
    rdfs:label "sub agent"@en ;
    obo:IAO_0000115 "An AI agent that was spawned by another agent to perform delegated work."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty pao:delegatedTask ;
            owl:someValuesFrom pao:Task ],
        [ a owl:Restriction ;
            owl:onProperty pao:spawnedBy ;
            owl:someValuesFrom pao:AIAgent ],
        pao:AIAgent ;
    skos:definition "An AI agent that was spawned by another agent to perform delegated work."@en .

pao:attemptedRetry a owl:ObjectProperty ;
    rdfs:label "attempted retry"@en ;
    obo:IAO_0000115 "Links an error recovery event to a retry attempt it initiated."@en ;
    rdfs:domain pao:ErrorRecoveryEvent ;
    rdfs:range pao:RetryAttempt ;
    skos:definition "Links an error recovery event to a retry attempt it initiated."@en .

pao:belongsTo a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "belongs to"@en ;
    obo:IAO_0000115 "Links an agent to the organization it belongs to."@en ;
    rdfs:domain pao:Agent ;
    rdfs:range pao:Organization ;
    owl:inverseOf pao:hasMember ;
    skos:definition "Links an agent to the organization it belongs to."@en .

pao:blockSequenceIndex a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "block sequence index"@en ;
    obo:IAO_0000115 "The zero-based ordinal position of a content block within its message."@en ;
    rdfs:domain pao:ContentBlock ;
    rdfs:range xsd:nonNegativeInteger ;
    skos:definition "The zero-based ordinal position of a content block within its message."@en .

pao:blockedBy a owl:ObjectProperty ;
    rdfs:label "blocked by"@en ;
    obo:IAO_0000115 "Links a task to another task that must complete before it can proceed."@en ;
    rdfs:domain pao:Task ;
    rdfs:range pao:Task ;
    owl:inverseOf pao:blocks ;
    skos:definition "Links a task to another task that must complete before it can proceed."@en .

pao:claimType a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "claim type"@en ;
    obo:IAO_0000115 "Links a claim to its type classifier."@en ;
    rdfs:domain pao:Claim ;
    rdfs:range pao:ClaimType ;
    skos:definition "Links a claim to its type classifier."@en .

pao:compactedContextOf a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "compacted context of"@en ;
    obo:IAO_0000115 "Links a compaction event to the context window that triggered it."@en ;
    rdfs:domain pao:CompactionEvent ;
    rdfs:range pao:ContextWindow ;
    skos:definition "Links a compaction event to the context window that triggered it."@en .

pao:consentPurpose a owl:ObjectProperty ;
    rdfs:label "consent purpose"@en ;
    obo:IAO_0000115 "Links a consent record to the entity describing the purpose."@en ;
    rdfs:domain pao:ConsentRecord ;
    rdfs:range prov:Entity ;
    skos:definition "Links a consent record to the entity describing the purpose."@en .

pao:continuedFrom a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "continued from"@en ;
    obo:IAO_0000115 "Links a session to the prior session it continues."@en ;
    rdfs:domain pao:Session ;
    rdfs:range pao:Session ;
    owl:inverseOf pao:continuedBy ;
    skos:definition "Links a session to the prior session it continues."@en .

pao:enforcedBySandboxPolicy a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "enforced by sandbox policy"@en ;
    obo:IAO_0000115 "Links an AI agent to the sandbox policy that constrains its execution."@en ;
    rdfs:domain pao:AIAgent ;
    rdfs:range pao:SandboxPolicy ;
    skos:definition "Links an AI agent to the sandbox policy that constrains its execution."@en .

pao:fateReason a owl:DatatypeProperty ;
    rdfs:label "fate reason"@en ;
    obo:IAO_0000115 "A textual reason for the compaction disposition decision."@en ;
    rdfs:domain pao:CompactionDisposition ;
    rdfs:range xsd:string ;
    skos:definition "A textual reason for the compaction disposition decision."@en .

pao:hasAttemptCount a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "has attempt count"@en ;
    obo:IAO_0000115 "The number of retry attempts made during an error recovery event."@en ;
    rdfs:domain pao:ErrorRecoveryEvent ;
    rdfs:range xsd:nonNegativeInteger ;
    skos:definition "The number of retry attempts made during an error recovery event."@en .

pao:hasBlockKey a owl:DatatypeProperty ;
    rdfs:label "has block key"@en ;
    obo:IAO_0000115 "A key in a memory block's key-value store."@en ;
    rdfs:domain pao:MemoryBlock ;
    rdfs:range xsd:string ;
    skos:definition "A key in a memory block's key-value store."@en .

pao:hasBlockValue a owl:DatatypeProperty ;
    rdfs:label "has block value"@en ;
    obo:IAO_0000115 "A value in a memory block's key-value store."@en ;
    rdfs:domain pao:MemoryBlock ;
    rdfs:range xsd:string ;
    skos:definition "A value in a memory block's key-value store."@en .

pao:hasCompactionDisposition a owl:ObjectProperty ;
    rdfs:label "has compaction disposition"@en ;
    obo:IAO_0000115 "Links a compaction event to a disposition record for one of its items."@en ;
    rdfs:domain pao:CompactionEvent ;
    rdfs:range pao:CompactionDisposition ;
    skos:definition "Links a compaction event to a disposition record for one of its items."@en .

pao:hasConfidence a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "has confidence"@en ;
    obo:IAO_0000115 "The confidence level of a claim, between 0.0 and 1.0."@en ;
    rdfs:domain pao:Claim ;
    rdfs:range xsd:decimal ;
    skos:definition "The confidence level of a claim, between 0.0 and 1.0."@en .

pao:hasContent a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "has content"@en ;
    obo:IAO_0000115 "The textual or structured content of an information artifact."@en ;
    rdfs:domain prov:Entity ;
    rdfs:range xsd:string ;
    skos:definition "The textual or structured content of an information artifact."@en .

pao:hasContentBlock a owl:ObjectProperty ;
    rdfs:label "has content block"@en ;
    obo:IAO_0000115 "Links a message to one of its typed content blocks."@en ;
    rdfs:domain pao:Message ;
    rdfs:range pao:ContentBlock ;
    skos:definition "Links a message to one of its typed content blocks."@en .

pao:hasContextWindow a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "has context window"@en ;
    obo:IAO_0000115 "Links a session to its context window resource."@en ;
    rdfs:domain pao:Session ;
    rdfs:range pao:ContextWindow ;
    skos:definition "Links a session to its context window resource."@en .

pao:hasDecisionReason a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "has decision reason"@en ;
    obo:IAO_0000115 "A textual justification for the authorization decision in an audit entry."@en ;
    rdfs:domain pao:AuditEntry ;
    rdfs:range xsd:string ;
    skos:definition "A textual justification for the authorization decision in an audit entry."@en .

pao:hasDialogAct a owl:ObjectProperty ;
    rdfs:label "has dialog act"@en ;
    obo:IAO_0000115 "Links a turn to a dialog act it performs."@en ;
    rdfs:domain pao:Turn ;
    rdfs:range pao:DialogAct ;
    skos:definition "Links a turn to a dialog act it performs."@en .

pao:hasEndpoint a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "has endpoint"@en ;
    obo:IAO_0000115 "The endpoint URI of the external service an integration connects to."@en ;
    rdfs:domain pao:Integration ;
    rdfs:range xsd:anyURI ;
    skos:definition "The endpoint URI of the external service an integration connects to."@en .

pao:hasEvidence a owl:ObjectProperty ;
    rdfs:label "has evidence"@en ;
    obo:IAO_0000115 "Links a claim to the evidence entities that support it."@en ;
    rdfs:domain pao:Claim ;
    rdfs:range prov:Entity ;
    skos:definition "Links a claim to the evidence entities that support it."@en .

pao:hasLastAccessTime a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "has last access time"@en ;
    obo:IAO_0000115 "The timestamp of the most recent access to this memory item."@en ;
    rdfs:domain pao:MemoryItem ;
    rdfs:range xsd:dateTime ;
    skos:definition "The timestamp of the most recent access to this memory item."@en .

pao:hasMemoryScope a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "has memory scope"@en ;
    obo:IAO_0000115 "Links a memory item to its visibility scope."@en ;
    rdfs:domain pao:MemoryItem ;
    rdfs:range pao:MemoryScope ;
    skos:definition "Links a memory item to its visibility scope."@en .

pao:hasMemorySource a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "has memory source"@en ;
    obo:IAO_0000115 "Links a memory item to its origination source."@en ;
    rdfs:domain pao:MemoryItem ;
    rdfs:range pao:MemorySource ;
    skos:definition "Links a memory item to its origination source."@en .

pao:hasRecoveryOutcome a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "has recovery outcome"@en ;
    obo:IAO_0000115 "The outcome of an error recovery event (e.g. resolved, escalated, abandoned)."@en ;
    rdfs:domain pao:ErrorRecoveryEvent ;
    rdfs:range xsd:string ;
    skos:definition "The outcome of an error recovery event (e.g. resolved, escalated, abandoned)."@en .

pao:hasRole a owl:ObjectProperty ;
    rdfs:label "has role"@en ;
    obo:IAO_0000115 "Links an agent to a role it bears in some context."@en ;
    rdfs:domain pao:Agent ;
    rdfs:range pao:AgentRole ;
    skos:definition "Links an agent to a role it bears in some context."@en .

pao:hasServiceConnection a owl:ObjectProperty ;
    rdfs:label "has service connection"@en ;
    obo:IAO_0000115 "Links an agent to a runtime connection to an external service."@en ;
    rdfs:domain pao:Agent ;
    rdfs:range pao:ServiceConnection ;
    skos:definition "Links an agent to a runtime connection to an external service."@en .

pao:hasServiceIdentifier a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "has service identifier"@en ;
    obo:IAO_0000115 "A unique string identifier for an external service configuration."@en ;
    rdfs:domain pao:ExternalService ;
    rdfs:range xsd:string ;
    skos:definition "A unique string identifier for an external service configuration."@en .

pao:hasServiceName a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "has service name"@en ;
    obo:IAO_0000115 "The display name of the external service an integration connects to."@en ;
    rdfs:domain pao:Integration ;
    rdfs:range xsd:string ;
    skos:definition "The display name of the external service an integration connects to."@en .

pao:hasServiceTransport a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "has service transport"@en ;
    obo:IAO_0000115 "The transport protocol of an external service (e.g. stdio, sse, http)."@en ;
    rdfs:domain pao:ExternalService ;
    rdfs:range xsd:string ;
    skos:definition "The transport protocol of an external service (e.g. stdio, sse, http)."@en .

pao:hasTimestamp a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "has timestamp"@en ;
    obo:IAO_0000115 "A convenience timestamp for point-in-time events."@en ;
    rdfs:range xsd:dateTime ;
    skos:definition "A convenience timestamp for point-in-time events."@en .

pao:hasTokenCapacity a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "has token capacity"@en ;
    obo:IAO_0000115 "The maximum number of tokens the context window can hold."@en ;
    rdfs:domain pao:ContextWindow ;
    rdfs:range xsd:nonNegativeInteger ;
    skos:definition "The maximum number of tokens the context window can hold."@en .

pao:hasTokensUsed a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "has tokens used"@en ;
    obo:IAO_0000115 "The number of tokens currently used in the context window."@en ;
    rdfs:domain pao:ContextWindow ;
    rdfs:range xsd:nonNegativeInteger ;
    skos:definition "The number of tokens currently used in the context window."@en .

pao:hookTriggeredExecution a owl:ObjectProperty ;
    rdfs:label "hook triggered execution"@en ;
    obo:IAO_0000115 "Links a hook to an execution instance it triggered."@en ;
    rdfs:domain pao:Hook ;
    rdfs:range pao:HookExecution ;
    skos:definition "Links a hook to an execution instance it triggered."@en .

pao:isEvictionCandidate a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "is eviction candidate"@en ;
    obo:IAO_0000115 "Whether this memory item is eligible for eviction from its tier."@en ;
    rdfs:domain pao:MemoryItem ;
    rdfs:range xsd:boolean ;
    skos:definition "Whether this memory item is eligible for eviction from its tier."@en .

pao:partOfInvocationGroup a owl:ObjectProperty ;
    rdfs:label "part of invocation group"@en ;
    obo:IAO_0000115 "Links a tool invocation to the parallel invocation group it belongs to."@en ;
    rdfs:domain pao:ToolInvocation ;
    rdfs:range pao:ToolInvocationGroup ;
    skos:definition "Links a tool invocation to the parallel invocation group it belongs to."@en .

pao:previousTransition a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "previous transition"@en ;
    obo:IAO_0000115 "Links to the preceding status transition for the same subject."@en ;
    rdfs:domain pao:StatusTransition ;
    rdfs:range pao:StatusTransition ;
    owl:inverseOf pao:nextTransition ;
    skos:definition "Links to the preceding status transition for the same subject."@en .

pao:providesAcceptanceEvidence a owl:ObjectProperty ;
    rdfs:label "provides acceptance evidence"@en ;
    obo:IAO_0000115 "Links a grounding act to evidence of acceptance or understanding."@en ;
    rdfs:domain pao:GroundingAct ;
    rdfs:range pao:AcceptanceEvidence ;
    skos:definition "Links a grounding act to evidence of acceptance or understanding."@en .

pao:recordedInEpisode a owl:ObjectProperty ;
    rdfs:label "recorded in episode"@en ;
    obo:IAO_0000115 "Links an event to the episode that records it."@en ;
    rdfs:domain pao:Event ;
    rdfs:range pao:Episode ;
    owl:inverseOf pao:recordsEvent ;
    skos:definition "Links an event to the episode that records it."@en .

pao:resolvedByPolicy a owl:ObjectProperty ;
    rdfs:label "resolved by policy"@en ;
    obo:IAO_0000115 "Links a memory write conflict to the policy that resolved it."@en ;
    rdfs:domain pao:MemoryWriteConflict ;
    rdfs:range pao:PermissionPolicy ;
    skos:definition "Links a memory write conflict to the policy that resolved it."@en .

pao:retentionPeriodDays a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "retention period days"@en ;
    obo:IAO_0000115 "The number of days a memory item should be retained."@en ;
    rdfs:domain pao:RetentionPolicy ;
    rdfs:range xsd:nonNegativeInteger ;
    skos:definition "The number of days a memory item should be retained."@en .

pao:sentViaChannel a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "sent via channel"@en ;
    obo:IAO_0000115 "Links a message to the communication channel it was sent through."@en ;
    rdfs:domain pao:Message ;
    rdfs:range pao:CommunicationChannel ;
    skos:definition "Links a message to the communication channel it was sent through."@en .

pao:triggeredBy a owl:ObjectProperty ;
    rdfs:label "triggered by"@en ;
    obo:IAO_0000115 "The event that caused this status transition."@en ;
    rdfs:domain pao:StatusTransition ;
    rdfs:range pao:Event ;
    skos:definition "The event that caused this status transition."@en .

pao:triggeredReplan a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "triggered replan"@en ;
    obo:IAO_0000115 "Links an error recovery event to the replan event it triggered."@en ;
    rdfs:domain pao:ErrorRecoveryEvent ;
    rdfs:range pao:ReplanEvent ;
    skos:definition "Links an error recovery event to the replan event it triggered."@en .

pao:triggeredRollback a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "triggered rollback"@en ;
    obo:IAO_0000115 "Links an error recovery event to the rollback event it triggered."@en ;
    rdfs:domain pao:ErrorRecoveryEvent ;
    rdfs:range pao:RollbackEvent ;
    skos:definition "Links an error recovery event to the rollback event it triggered."@en .

pao:viaChannel a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "via channel"@en ;
    obo:IAO_0000115 "Links a session to the communication channel it uses."@en ;
    rdfs:domain pao:Session ;
    rdfs:range pao:CommunicationChannel ;
    skos:definition "Links a session to the communication channel it uses."@en .

pao:AgentRole a owl:Class ;
    rdfs:label "agent role"@en ;
    obo:IAO_0000115 "A role that an agent plays in the context of a conversation or activity."@en ;
    rdfs:subClassOf obo:BFO_0000023,
        prov:Role ;
    skos:definition "A role that an agent plays in the context of a conversation or activity."@en .

pao:HumanUser a owl:Class ;
    rdfs:label "human user"@en ;
    obo:IAO_0000115 "An agent that is a human person who interacts with AI systems."@en ;
    rdfs:subClassOf obo:BFO_0000030,
        prov:Person,
        foaf:Person,
        pao:Agent ;
    skos:definition "An agent that is a human person who interacts with AI systems."@en .

pao:Observation a owl:Class ;
    rdfs:label "observation"@en ;
    obo:IAO_0000115 "An event in which an agent receives environmental feedback."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty pao:inSession ;
            owl:someValuesFrom pao:Session ],
        pao:Event ;
    skos:definition "An event in which an agent receives environmental feedback."@en .

pao:SessionStatusTransition a owl:Class ;
    rdfs:label "session status transition"@en ;
    obo:IAO_0000115 "A status transition in which a session's status changes."@en ;
    rdfs:subClassOf pao:StatusTransition ;
    skos:definition "A status transition in which a session's status changes."@en .

pao:TaskStatusTransition a owl:Class ;
    rdfs:label "task status transition"@en ;
    obo:IAO_0000115 "A status transition in which a task's status changes."@en ;
    rdfs:subClassOf pao:StatusTransition ;
    skos:definition "A status transition in which a task's status changes."@en .

pao:aboutAgent a owl:ObjectProperty ;
    rdfs:label "about agent"@en ;
    obo:IAO_0000115 "Links a memory item to the agent it describes."@en ;
    rdfs:domain pao:MemoryItem ;
    rdfs:range pao:Agent ;
    skos:definition "Links a memory item to the agent it describes."@en .

pao:achievesGoal a owl:ObjectProperty ;
    rdfs:label "achieves goal"@en ;
    obo:IAO_0000115 "Links a plan to the goal it is designed to achieve."@en ;
    rdfs:domain pao:Plan ;
    rdfs:range pao:Goal ;
    skos:definition "Links a plan to the goal it is designed to achieve."@en .

pao:auditForInvocation a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "audit for invocation"@en ;
    obo:IAO_0000115 "Links an audit entry to the tool invocation it documents."@en ;
    rdfs:domain pao:AuditEntry ;
    rdfs:range pao:ToolInvocation ;
    skos:definition "Links an audit entry to the tool invocation it documents."@en .

pao:availableToAgent a owl:ObjectProperty ;
    rdfs:label "available to agent"@en ;
    obo:IAO_0000115 "Links a tool definition to an agent that may invoke it."@en ;
    rdfs:domain pao:ToolDefinition ;
    rdfs:range pao:Agent ;
    skos:definition "Links a tool definition to an agent that may invoke it."@en .

pao:blocks a owl:ObjectProperty ;
    rdfs:label "blocks"@en ;
    obo:IAO_0000115 "Links a task to another task that depends on its completion."@en ;
    rdfs:domain pao:Task ;
    rdfs:range pao:Task ;
    skos:definition "Links a task to another task that depends on its completion."@en .

pao:checkpointDecision a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "checkpoint decision"@en ;
    obo:IAO_0000115 "Links a checkpoint to the human decision recorded for it."@en ;
    rdfs:domain pao:Checkpoint ;
    rdfs:range pao:CheckpointDecision ;
    rdfs:subPropertyOf pao:hasStatus ;
    skos:definition "Links a checkpoint to the human decision recorded for it."@en .

pao:checkpointForTask a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "checkpoint for task"@en ;
    obo:IAO_0000115 "Links a checkpoint to the task it gates."@en ;
    rdfs:domain pao:Checkpoint ;
    rdfs:range pao:Task ;
    skos:definition "Links a checkpoint to the task it gates."@en .

pao:clarifiesTurn a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "clarifies turn"@en ;
    obo:IAO_0000115 "Links a clarification request to the turn it seeks to clarify."@en ;
    rdfs:domain pao:ClarificationRequest ;
    rdfs:range pao:Turn ;
    skos:definition "Links a clarification request to the turn it seeks to clarify."@en .

pao:compactedItem a owl:ObjectProperty ;
    rdfs:label "compacted item"@en ;
    obo:IAO_0000115 "Links a compaction event to an item that was in scope for compaction."@en ;
    rdfs:domain pao:CompactionEvent ;
    rdfs:range prov:Entity ;
    rdfs:subPropertyOf prov:used ;
    skos:definition "Links a compaction event to an item that was in scope for compaction."@en .

pao:conflictOnArtifact a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "conflict on artifact"@en ;
    obo:IAO_0000115 "Links a memory write conflict to the shared artifact in contention."@en ;
    rdfs:domain pao:MemoryWriteConflict ;
    rdfs:range pao:SharedMemoryArtifact ;
    skos:definition "Links a memory write conflict to the shared artifact in contention."@en .

pao:connectsToService a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "connects to service"@en ;
    obo:IAO_0000115 "Links a service connection to the external service it connects to."@en ;
    rdfs:domain pao:ServiceConnection ;
    rdfs:range pao:ExternalService ;
    skos:definition "Links a service connection to the external service it connects to."@en .

pao:consentSubject a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "consent subject"@en ;
    obo:IAO_0000115 "Links a consent record to the data subject agent."@en ;
    rdfs:domain pao:ConsentRecord ;
    rdfs:range pao:Agent ;
    skos:definition "Links a consent record to the data subject agent."@en .

pao:continuedBy a owl:ObjectProperty ;
    rdfs:label "continued by"@en ;
    obo:IAO_0000115 "Links a session to a subsequent session that continues its work."@en ;
    rdfs:domain pao:Session ;
    rdfs:range pao:Session ;
    skos:definition "Links a session to a subsequent session that continues its work."@en .

pao:contributesToCommonGround a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "contributes to common ground"@en ;
    obo:IAO_0000115 "Links a grounding act to the common ground it updates."@en ;
    rdfs:domain pao:GroundingAct ;
    rdfs:range pao:CommonGround ;
    skos:definition "Links a grounding act to the common ground it updates."@en .

pao:delegatedTask a owl:ObjectProperty ;
    rdfs:label "delegated task"@en ;
