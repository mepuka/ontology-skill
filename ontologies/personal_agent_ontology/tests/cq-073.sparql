PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX pao: <https://purl.org/pao/>

# CQ-073: What is the connection status of an agent's integrations?
# Expected: non-empty result set
SELECT ?agent ?integration ?label ?status WHERE {
  ?agent pao:hasIntegration ?integration .
  ?integration a pao:Integration ;
               rdfs:label ?label ;
               pao:hasIntegrationStatus ?status .
}
