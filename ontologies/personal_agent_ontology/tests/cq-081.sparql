PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX pao: <https://purl.org/pao/>

# CQ-081: Which capabilities were discovered in the latest discovery event?
# Expected: non-empty result set
SELECT ?event ?capability ?service WHERE {
  ?event a pao:CapabilityDiscoveryEvent ;
         pao:discoveredCapability ?capability ;
         pao:discoveryAgainstService ?service ;
         pao:hasTimestamp ?ts .
}
ORDER BY DESC(?ts) LIMIT 10
