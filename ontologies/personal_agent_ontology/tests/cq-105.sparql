PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX pao: <https://purl.org/pao/>

# CQ-105: What operational metrics are defined in the system?
# Expected: non_empty
SELECT ?metric ?name ?label WHERE {
  ?metric a pao:OperationalMetric ;
          pao:hasMetricName ?name .
  OPTIONAL { ?metric rdfs:label ?label . }
}
