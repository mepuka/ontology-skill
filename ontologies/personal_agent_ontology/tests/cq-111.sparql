PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX pao: <https://purl.org/pao/>

# CQ-111: What desires does an agent have?
# Expected: non_empty
SELECT ?agent ?desire ?label WHERE {
  ?agent pao:holdsDesire ?desire .
  ?desire a pao:Desire ;
          rdfs:label ?label .
}
