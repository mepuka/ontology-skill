PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX pao: <https://purl.org/pao/>

# CQ-068: Which sessions used a specific type of communication channel?
# Expected: non-empty result set
SELECT ?session ?channel ?channelType WHERE {
  ?session a pao:Session ;
           pao:viaChannel ?channel .
  ?channel pao:hasChannelType ?channelType .
}
