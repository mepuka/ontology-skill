# CQ-022: What events overlap temporally with a given event?
# Expected: non-empty result set (SELECT)

PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX pao: <https://purl.org/pao/>
PREFIX prov: <http://www.w3.org/ns/prov#>
PREFIX time: <http://www.w3.org/2006/time#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX foaf: <http://xmlns.com/foaf/0.1/>

SELECT ?event ?overlapping WHERE {
  ?event pao:hasTemporalExtent ?i1 .
  ?overlapping pao:hasTemporalExtent ?i2 .
  ?i1 time:hasBeginning/time:inXSDDateTime ?s1 ;
      time:hasEnd/time:inXSDDateTime ?e1 .
  ?i2 time:hasBeginning/time:inXSDDateTime ?s2 ;
      time:hasEnd/time:inXSDDateTime ?e2 .
  FILTER (?s1 < ?e2 && ?s2 < ?e1 && ?event != ?overlapping)
}
