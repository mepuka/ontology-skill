PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX pao: <https://purl.org/pao/>

# CQ-107: Is a reliability incident linked to a recovery event?
# Expected: non_empty
SELECT ?incident ?recovery WHERE {
  ?incident a pao:ReliabilityIncident ;
            pao:linkedToRecovery ?recovery .
  ?recovery a pao:ErrorRecoveryEvent .
}
