PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX pao: <https://purl.org/pao/>

# CQ-074: Which integration provides a given tool?
# Expected: non-empty result set
SELECT ?tool ?toolLabel ?integration ?integrationLabel WHERE {
  ?integration a pao:Integration ;
               rdfs:label ?integrationLabel ;
               pao:providesTool ?tool .
  ?tool rdfs:label ?toolLabel .
}
