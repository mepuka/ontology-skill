PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX pao: <https://purl.org/pao/>

# CQ-088: How many retries were attempted before success or abandonment?
# Expected: non-empty result set
SELECT ?recovery ?attemptCount ?outcome WHERE {
  ?recovery a pao:ErrorRecoveryEvent ;
            pao:hasAttemptCount ?attemptCount ;
            pao:hasRecoveryOutcome ?outcome .
}
