PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX pao: <https://purl.org/pao/>

# CQ-106: What reliability incidents occurred for a service?
# Expected: non_empty
SELECT ?incident ?label ?entity WHERE {
  ?incident a pao:ReliabilityIncident ;
            rdfs:label ?label ;
            pao:incidentForEntity ?entity .
}
