PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX pao: <https://purl.org/pao/>

# CQ-072: What tools are provided by a given integration?
# Expected: non-empty result set
SELECT ?integration ?tool ?toolLabel WHERE {
  ?integration a pao:Integration ;
               pao:providesTool ?tool .
  ?tool a pao:ToolDefinition ;
        rdfs:label ?toolLabel .
}
