PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX pao: <https://purl.org/pao/>

# CQ-076: Are there any integrations currently in error status?
# Expected: non-empty (sample ABox includes an error integration for testing)
SELECT ?integration ?label ?agent WHERE {
  ?integration a pao:Integration ;
               rdfs:label ?label ;
               pao:hasIntegrationStatus pao:Error .
  ?agent pao:hasIntegration ?integration .
}
