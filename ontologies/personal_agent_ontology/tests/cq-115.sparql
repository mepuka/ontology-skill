# CQ-115: What recurrence pattern does a given schedule use?
# Expected: non-empty result set (SELECT)

PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX pao: <https://purl.org/pao/>
PREFIX prov: <http://www.w3.org/ns/prov#>
PREFIX time: <http://www.w3.org/2006/time#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX foaf: <http://xmlns.com/foaf/0.1/>

SELECT ?schedule ?pattern ?cronExpr ?intervalSecs WHERE {
  ?schedule a pao:Schedule ;
            pao:hasRecurrencePattern ?pattern .
  ?pattern a pao:RecurrencePattern .
  OPTIONAL { ?pattern pao:hasCronExpression ?cronExpr }
  OPTIONAL { ?pattern pao:hasIntervalSeconds ?intervalSecs }
  FILTER (BOUND(?cronExpr) || BOUND(?intervalSecs))
}
