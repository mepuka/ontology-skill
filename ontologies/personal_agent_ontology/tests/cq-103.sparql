PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX pao: <https://purl.org/pao/>

# CQ-103: Which model does a given AI agent use?
# Expected: non_empty
SELECT ?agent ?agentLabel ?model ?modelLabel WHERE {
  ?agent a pao:AIAgent ;
         rdfs:label ?agentLabel ;
         pao:usesModel ?model .
  ?model a pao:FoundationModel ;
         rdfs:label ?modelLabel .
}
