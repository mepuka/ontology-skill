PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX pao: <https://purl.org/pao/>

# CQ-087: What recovery events occurred after failed invocations?
# Expected: non-empty result set
SELECT ?recovery ?invocation ?outcome WHERE {
  ?recovery a pao:ErrorRecoveryEvent ;
            pao:recoveringFrom ?invocation ;
            pao:hasRecoveryOutcome ?outcome .
}
