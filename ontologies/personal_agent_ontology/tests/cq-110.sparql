PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX pao: <https://purl.org/pao/>

# CQ-110: What beliefs does an agent hold?
# Expected: non_empty
SELECT ?agent ?belief ?label WHERE {
  ?agent pao:heldBelief ?belief .
  ?belief a pao:Belief ;
          rdfs:label ?label .
}
