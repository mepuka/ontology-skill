PREFIX pao: <https://purl.org/pao/>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

# CQ-060: What event triggered a given status transition?
# Expected: non-empty result set
SELECT ?transition ?trigger WHERE {
  ?transition rdf:type/rdfs:subClassOf* pao:StatusTransition ;
              pao:triggeredBy ?trigger .
}
