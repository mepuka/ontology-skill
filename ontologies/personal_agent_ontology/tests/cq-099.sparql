PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX pao: <https://purl.org/pao/>

# CQ-099: Which foundation model was used for a given turn?
# Expected: non_empty
SELECT ?turn ?model ?modelId WHERE {
  ?turn a pao:Turn .
  ?invocation a pao:ModelInvocation ;
              pao:modelInvocationForTurn ?turn ;
              pao:invokedOnDeployment ?deployment .
  ?deployment a pao:ModelDeployment .
  ?model a pao:FoundationModel ;
         pao:deployedAs ?deployment ;
         pao:hasModelId ?modelId .
}
