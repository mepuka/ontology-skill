@prefix pao: <https://purl.org/pao/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

pao:AIAgentShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:hasAgentId ],
        [ sh:class pao:ToolDefinition ;
            sh:minCount 1 ;
            sh:path pao:hasAvailableTool ] ;
    sh:targetClass pao:AIAgent .

pao:ActionShape a sh:NodeShape ;
    sh:property [ sh:class pao:Agent ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:performedBy ] ;
    sh:targetClass pao:Action .

pao:ClaimShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:decimal ;
            sh:maxCount 1 ;
            sh:maxInclusive 1.0 ;
            sh:minCount 0 ;
            sh:minInclusive 0.0 ;
            sh:path pao:hasConfidence ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:hasContent ] ;
    sh:targetClass pao:Claim .

pao:CommunicationChannelShape a sh:NodeShape ;
    sh:property [ sh:class pao:ChannelType ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:hasChannelType ] ;
    sh:targetClass pao:CommunicationChannel .

pao:CompactionDispositionShape a sh:NodeShape ;
    sh:property [ sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:dispositionOf ],
        [ sh:class pao:ItemFate ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:hasItemFate ] ;
    sh:targetClass pao:CompactionDisposition .

pao:CompactionEventShape a sh:NodeShape ;
    sh:property [ sh:class pao:ContextWindow ;
            sh:maxCount 1 ;
            sh:path pao:compactedContextOf ],
        [ sh:class pao:MemoryItem ;
            sh:minCount 1 ;
            sh:path pao:producedSummary ] ;
    sh:targetClass pao:CompactionEvent .

pao:ConsentRecordShape a sh:NodeShape ;
    sh:property [ sh:class pao:Agent ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:consentSubject ] ;
    sh:targetClass pao:ConsentRecord .

pao:ContextWindowShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:nonNegativeInteger ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:hasTokenCapacity ],
        [ sh:datatype xsd:nonNegativeInteger ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:hasTokensUsed ] ;
    sh:sparql [ sh:message "hasTokensUsed must not exceed hasTokenCapacity" ;
            sh:select """PREFIX pao: <https://purl.org/pao/>
SELECT $this WHERE {
  $this pao:hasTokensUsed ?used .
  $this pao:hasTokenCapacity ?cap .
  FILTER(?used > ?cap)
}""" ] ;
    sh:targetClass pao:ContextWindow .

pao:ConversationShape a sh:NodeShape ;
    sh:property [ sh:class pao:Agent ;
            sh:minCount 1 ;
            sh:path pao:hasParticipant ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:hasConversationId ] ;
    sh:targetClass pao:Conversation .

pao:EpisodeShape a sh:NodeShape ;
    sh:property [ sh:minCount 1 ;
            sh:path pao:hasTemporalExtent ],
        [ sh:minCount 1 ;
            sh:path pao:hasTopic ] ;
    sh:targetClass pao:Episode .

pao:ErasureEventShape a sh:NodeShape ;
    sh:property [ sh:class pao:Agent ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:requestedBy ] ;
    sh:targetClass pao:ErasureEvent .

pao:GoalShape a sh:NodeShape ;
    sh:property [ sh:class pao:TaskStatus ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:hasStatus ],
        [ sh:class pao:Agent ;
            sh:minCount 1 ;
            sh:path pao:pursuedBy ] ;
    sh:targetClass pao:Goal .

pao:IntegrationShape a sh:NodeShape ;
    sh:property [ sh:class pao:IntegrationStatus ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:hasIntegrationStatus ],
        [ sh:class pao:ToolDefinition ;
            sh:minCount 1 ;
            sh:path pao:providesTool ],
        [ sh:datatype xsd:anyURI ;
            sh:maxCount 1 ;
            sh:path pao:hasEndpoint ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:hasServiceName ] ;
    sh:targetClass pao:Integration .

pao:IntentionShape a sh:NodeShape ;
    sh:property [ sh:class pao:Goal ;
            sh:minCount 1 ;
            sh:path pao:derivedFromGoal ],
        [ sh:class pao:Agent ;
            sh:minCount 1 ;
            sh:path pao:intendedBy ] ;
    sh:targetClass pao:Intention .

pao:MemoryBlockShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:minCount 1 ;
            sh:path pao:hasBlockKey ],
        [ sh:datatype xsd:string ;
            sh:minCount 1 ;
            sh:path pao:hasBlockValue ] ;
    sh:targetClass pao:MemoryBlock .

pao:MemoryItemShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:dateTime ;
            sh:maxCount 1 ;
            sh:path pao:hasLastAccessTime ],
        [ sh:class pao:SensitivityLevel ;
            sh:maxCount 1 ;
            sh:minCount 0 ;
            sh:path pao:hasSensitivityLevel ],
        [ sh:class pao:MemoryTier ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:storedIn ] ;
    sh:targetClass pao:MemoryItem .

pao:MemoryOperationShape a sh:NodeShape ;
    sh:property [ sh:class pao:MemoryItem ;
            sh:minCount 1 ;
            sh:path pao:operatesOn ] ;
    sh:targetClass pao:MemoryOperation .

pao:MessageShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:hasContent ],
        [ sh:class pao:CommunicationChannel ;
            sh:maxCount 1 ;
            sh:path pao:sentViaChannel ] ;
    sh:targetClass pao:Message .

pao:ObservationShape a sh:NodeShape ;
    sh:property [ sh:class pao:Session ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:inSession ] ;
    sh:targetClass pao:Observation .

pao:OrganizationShape a sh:NodeShape ;
    sh:property [ sh:class pao:Agent ;
            sh:minCount 1 ;
            sh:path pao:hasMember ] ;
    sh:targetClass pao:Organization .

pao:PersonaShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:hasContent ] ;
    sh:targetClass pao:Persona .

pao:PlanShape a sh:NodeShape ;
    sh:property [ sh:class pao:Goal ;
            sh:minCount 1 ;
            sh:path pao:achievesGoal ] ;
    sh:targetClass pao:Plan .

pao:RetentionPolicyShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:nonNegativeInteger ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:retentionPeriodDays ] ;
    sh:targetClass pao:RetentionPolicy .

pao:SessionShape a sh:NodeShape ;
    sh:property [ sh:class pao:SessionStatus ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:hasStatus ],
        [ sh:class pao:Conversation ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:partOfConversation ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:hasSessionId ],
        [ sh:class pao:CommunicationChannel ;
            sh:maxCount 1 ;
            sh:path pao:viaChannel ],
        [ sh:class pao:ContextWindow ;
            sh:maxCount 1 ;
            sh:path pao:hasContextWindow ] ;
    sh:targetClass pao:Session .

pao:StatusTransitionShape a sh:NodeShape ;
    sh:property [ sh:class pao:Status ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:toStatus ],
        [ sh:class pao:Status ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:fromStatus ],
        [ sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:transitionSubject ] ;
    sh:targetClass pao:StatusTransition .

pao:SubAgentShape a sh:NodeShape ;
    sh:property [ sh:class pao:Agent ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:spawnedBy ] ;
    sh:targetClass pao:SubAgent .

pao:TaskShape a sh:NodeShape ;
    sh:property [ sh:class pao:TaskStatus ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:hasStatus ],
        [ sh:class pao:Plan ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:partOfPlan ] ;
    sh:targetClass pao:Task .

pao:ToolInvocationShape a sh:NodeShape ;
    sh:property [ sh:class pao:ToolDefinition ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:invokesTool ],
        [ sh:class pao:Agent ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:invokedBy ] ;
    sh:targetClass pao:ToolInvocation .

pao:TurnShape a sh:NodeShape ;
    sh:property [ sh:class pao:Session ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:partOfSession ],
        [ sh:datatype xsd:nonNegativeInteger ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path pao:hasTurnIndex ] ;
    sh:targetClass pao:Turn .
