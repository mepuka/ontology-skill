@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .

<https://purl.org/pao/prov-declarations> a owl:Ontology ;
    rdfs:label "PROV-O declarations for PAO"@en ;
    rdfs:comment "MIREOT-style stub declaring PROV-O terms used by PAO."@en .

# Classes
prov:Agent a owl:Class ; rdfs:label "Agent"@en .
prov:SoftwareAgent a owl:Class ; rdfs:subClassOf prov:Agent ; rdfs:label "Software Agent"@en .
prov:Person a owl:Class ; rdfs:subClassOf prov:Agent ; rdfs:label "Person (PROV-O)"@en .
prov:Entity a owl:Class ; rdfs:label "Entity"@en .
prov:Activity a owl:Class ; rdfs:label "Activity"@en .
prov:Plan a owl:Class ; rdfs:subClassOf prov:Entity ; rdfs:label "Plan"@en .
prov:Role a owl:Class ; rdfs:label "Role"@en .
prov:Association a owl:Class ; rdfs:label "Association"@en .

# Object Properties
prov:wasGeneratedBy a owl:ObjectProperty ; rdfs:label "was generated by"@en ;
    rdfs:domain prov:Entity ; rdfs:range prov:Activity .
prov:wasDerivedFrom a owl:ObjectProperty ; rdfs:label "was derived from"@en ;
    rdfs:domain prov:Entity ; rdfs:range prov:Entity .
prov:wasAttributedTo a owl:ObjectProperty ; rdfs:label "was attributed to"@en ;
    rdfs:domain prov:Entity ; rdfs:range prov:Agent .
prov:wasAssociatedWith a owl:ObjectProperty ; rdfs:label "was associated with"@en ;
    rdfs:domain prov:Activity ; rdfs:range prov:Agent .
prov:wasRevisionOf a owl:ObjectProperty ; rdfs:subPropertyOf prov:wasDerivedFrom ;
    rdfs:label "was revision of"@en ;
    rdfs:domain prov:Entity ; rdfs:range prov:Entity .
prov:qualifiedAssociation a owl:ObjectProperty ; rdfs:label "qualified association"@en ;
    rdfs:domain prov:Activity ; rdfs:range prov:Association .
prov:agent a owl:ObjectProperty ; rdfs:label "prov agent"@en ;
    rdfs:domain prov:Association ; rdfs:range prov:Agent .
prov:hadRole a owl:ObjectProperty ; rdfs:label "had role"@en ;
    rdfs:domain prov:Association ; rdfs:range prov:Role .

# Additional PROV-O terms for v0.3.0
prov:used a owl:ObjectProperty ; rdfs:label "used"@en ;
    rdfs:domain prov:Activity ; rdfs:range prov:Entity .
prov:wasInvalidatedBy a owl:ObjectProperty ; rdfs:label "was invalidated by"@en ;
    rdfs:domain prov:Entity ; rdfs:range prov:Activity .
prov:Derivation a owl:Class ; rdfs:label "Derivation"@en .
prov:qualifiedDerivation a owl:ObjectProperty ; rdfs:label "qualified derivation"@en ;
    rdfs:domain prov:Entity ; rdfs:range prov:Derivation .
prov:entity a owl:ObjectProperty ; rdfs:label "prov entity"@en ;
    rdfs:domain prov:Derivation ; rdfs:range prov:Entity .
prov:hadActivity a owl:ObjectProperty ; rdfs:label "had activity"@en ;
    rdfs:domain prov:Derivation ; rdfs:range prov:Activity .
