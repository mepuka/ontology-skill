PREFIX rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX ei:   <https://w3id.org/energy-intel/>

# CQ-006 (must_have, UC-003)
# For a given Variable, which CanonicalMeasurementClaims reference it?
# Expected: 0..n rows.
# Derivation: direct_lookup (inverse walk).

SELECT ?cmc WHERE {
  ?cmc ei:referencesVariable <https://id.skygest.io/variable/var_01J_solar_installed_capacity> ;
       a ei:CanonicalMeasurementClaim .
}
