# CQ: CQ-N6
# Kind: select
# Expected: 0..n distinct rows
# Expected shape:
#   Columns: ?expert
#   Cardinality: 0..n; DISTINCT applied
#   Two paths combined via UNION: (a) explicit ei:narrativeMentionsExpert
#   assertion (asserted at import time by NarrativeWriteService); (b) walk
#   through hasNarrativePostMembership/memberPost/authoredBy. The fallback
#   path is defense-in-depth and works even before auto-derivation runs.
# Source use case: UC-010 (Attach a post — auto-derived expert mentions)
# Priority: should_have
# Entailment regime: simple

PREFIX rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:  <http://www.w3.org/2000/01/rdf-schema#>
PREFIX foaf:  <http://xmlns.com/foaf/0.1/>
PREFIX ei:    <https://w3id.org/energy-intel/>

SELECT DISTINCT ?expert WHERE {
  {
    <https://w3id.org/energy-intel/narrative/2026-04-06-tva-nuclear-costs>
      ei:narrativeMentionsExpert ?expert .
  } UNION {
    <https://w3id.org/energy-intel/narrative/2026-04-06-tva-nuclear-costs>
      ei:hasNarrativePostMembership/ei:memberPost/ei:authoredBy ?expert .
  }
}
