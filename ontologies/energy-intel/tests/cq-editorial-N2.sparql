# CQ: CQ-N2
# Kind: select
# Expected: 0..n rows
# Expected shape:
#   Columns: ?post ?role
#   Cardinality: 0..n
#   Forward walk: Narrative -> hasNarrativePostMembership -> {memberPost, memberRole}.
#   Returns one row per (post, role) pair attached to the bound Narrative.
# Source use case: UC-010 (Attach a post in a role and walk the membership)
# Priority: must_have
# Entailment regime: simple

PREFIX rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:  <http://www.w3.org/2000/01/rdf-schema#>
PREFIX skos:  <http://www.w3.org/2004/02/skos/core#>
PREFIX ei:    <https://w3id.org/energy-intel/>

SELECT ?post ?role WHERE {
  <https://w3id.org/energy-intel/narrative/2026-04-06-tva-nuclear-costs>
    ei:hasNarrativePostMembership ?membership .
  ?membership ei:memberPost ?post ;
              ei:memberRole ?role .
}
