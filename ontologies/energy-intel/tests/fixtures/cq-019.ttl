    rdfs:label "thermal energy"@en ;
    ns1:IAO_0000115 "Thermal energy is the energy that a material entity contains in the undirected motion of its constituent parts (e.g. molecules and atoms)."@en ;
    ns1:IAO_0000118 "Wärme"@de,
