:OEO_00000099 a owl:Class ;
    rdfs:label "combustion fuel"@en ;
    ns1:IAO_0000115 "A combustion fuel is a fuel that realises its fuel role in processes that release energy in the form of heat or work by chemical reaction with other substances." ;
    rdfs:subClassOf :OEO_00000173 ;
    :OEO_00020426 """issue: https://github.com/OpenEnergyPlatform/ontology/issues/182
pull request: https://github.com/OpenEnergyPlatform/ontology/pull/237

Update definition:
https://github.com/OpenEnergyPlatform/ontology/pull/931

move to oeo-shared:
issue: https://github.com/OpenEnergyPlatform/ontology/issues/1384
pull request: https://github.com/OpenEnergyPlatform/ontology/pull/1390

rework module structure
issue: https://github.com/OpenEnergyPlatform/ontology/issues/1592
pull request: https://github.com/OpenEnergyPlatform/ontology/pull/1652""" .

ns1:IAO_0000109 a owl:Class ;
    rdfs:label "measurement datum"@en ;
    ns1:IAO_0000111 "measurement datum"@en ;
    ns1:IAO_0000112 "Examples of measurement data are the recoding of the weight of a mouse as {40,mass,\"grams\"}, the recording of an observation of the behavior of the mouse {,process,\"agitated\"}, the recording of the expression level of a gene as measured through the process of microarray experiment {3.4,luminosity,}."@en ;
    ns1:IAO_0000114 ns1:IAO_0000125 ;
    ns1:IAO_0000115 "A measurement datum is an information content entity that is a recording of the output of a measurement such as produced by a device."@en ;
    ns1:IAO_0000116 "2/2/2009 is_specified_output of some assay?"@en ;
    ns1:IAO_0000117 "person:Chris Stoeckert"@en ;
    ns1:IAO_0000119 "OBI_0000305"@en,
        "group:OBI"@en ;
    rdfs:isDefinedBy <https://openenergyplatform.org/ontology/oeo/imports/iao-extracted.owl> ;
    rdfs:subClassOf ns1:IAO_0000027 .

:OEO_00010490 a owl:Class ;
    rdfs:label "physical unit"@en ;
    ns1:IAO_0000115 "A physical unit is a unit that represents a standardised quantity value of a physical quantifiable entity."@en ;
    ns1:IAO_0000116 "The OEO developers have different views on the correct classification of a (physical) unit. On one hand, a (physical) unit is often referred to be \"a standardized quantity\", e.g. in the UO, and thus is interpreted as a quantity itself. On the other hand, a (physical) unit can be seen as a generically dependent reference measure that is not bound to a specific bearer. Together with the numerical value it can describe a quantity value. In the OEO, we have opted for the latter view and therefore implemented (physical) unit as generically dependent continuants." ;
    ns1:IAO_0000118 "physikalische Einheit"@en ;
    rdfs:subClassOf :OEO_00010489 ;
    :OEO_00020426 """issue: https://github.com/OpenEnergyPlatform/ontology/issues/1871
pull request: https://github.com/OpenEnergyPlatform/ontology/pull/1892
remove equivalence axiom to uo:unit
issue: https://github.com/OpenEnergyPlatform/ontology/issues/2135
pull request: https://github.com/OpenEnergyPlatform/ontology/pull/2141""" .

