:OEO_00030031 a owl:Class ;
    rdfs:label "start time"@en ;
    ns1:IAO_0000115 "A start time is a zero-dimensional temporal region that indicates the beginning of a one-dimensional temporal region." ;
    ns1:IAO_0000118 "Startzeit"@de ;
    :OEO_00020426 """issue: https://github.com/OpenEnergyPlatform/ontology/issues/267
