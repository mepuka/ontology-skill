    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :OEO_00020188 ;
            owl:someValuesFrom :OEO_00020187 ],
        ns1:IAO_0000104 ;
    :OEO_00020426 """Add 'has licence' axiom:
