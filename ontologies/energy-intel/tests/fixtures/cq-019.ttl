:OEO_00010248 a owl:Class ;
    rdfs:label "heat gain process"@en ;
    ns1:IAO_0000115 "A heat gain process is an energy transformation that has thermal energy as energy output." ;
    ns1:IAO_0000118 "heat generation",
        "heat generation process" ;
    rdfs:comment "With the logical definition of heat gain process, heat transfer is inferred as subclass which is intended but depends on the perspective and the system boundaries. To avoid confusion, the main label was changed from heat generation to heat gain process." ;
    rdfs:subClassOf :OEO_00020003 ;
    :OEO_00020426 """issue: https://github.com/OpenEnergyPlatform/ontology/issues/1045
pull request: https://github.com/OpenEnergyPlatform/ontology/pull/1130

