:OEO_00340062 a owl:Class ;
    rdfs:label "quantity"@en ;
    ns1:IAO_0000115 "A quantity is a quality of a material entity where the magnitude  of the quality can be quantified via a quantity value, which means that it can be expressed as a number and a unit." ;
    ns1:IAO_0000119 "Derived from: https://jcgm.bipm.org/vim/en/1.1.html" ;
    :OEO_00020426 """issue: https://github.com/OpenEnergyPlatform/ontology/issues/1510
pull request: https://github.com/OpenEnergyPlatform/ontology/pull/1839""" .

:OEO_00340068 a owl:Class ;
    rdfs:label "size"@en ;
    ns1:IAO_0000115 "Size is a quantity of an entity that quantifies its spatial extend." ;
    ns1:IAO_0000119 "Derived from: http://purl.allotrope.org/ontologies/result#AFR_0002109 and http://purl.obolibrary.org/obo/PATO_0000117" ;
    rdfs:subClassOf :OEO_00340062 ;
    :OEO_00020426 """restructuring of quantity values
