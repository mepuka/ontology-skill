    rdfs:label "software"@en ;
    ns1:IAO_0000111 "software"@en ;
    ns1:IAO_0000114 ns1:IAO_0000120 ;
    ns1:IAO_0000115 """Software is a plan specification composed of a series of instructions that can be
interpreted by or directly executed by a processing unit."""@en ;
    ns1:IAO_0000116 "see sourceforge tracker discussion at http://sourceforge.net/tracker/index.php?func=detail&aid=1958818&group_id=177891&atid=886178"@en ;
    ns1:IAO_0000117 "PERSON: Alan Ruttenberg"@en,
        "PERSON: Bjoern Peters"@en,
        "PERSON: Chris Stoeckert"@en,
        "PERSON: Melanie Courtot"@en ;
    ns1:IAO_0000119 "GROUP: OBI"@en ;
