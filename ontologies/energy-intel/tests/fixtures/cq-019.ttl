    ns1:IAO_0000115 "The CRF sector (IPCC 2006) 'other product manufacture and use - other' is an industry sector defined by the 2006 IPCC Guidelines for National Greenhouse Gas Inventories" ;
    ns1:IAO_0000119 "2006 IPCC Guidelines for National Greenhouse Gas Inventories, Volume 1, Chapter 8.5, https://www.ipcc-nggip.iges.or.jp/public/2006gl/" ;
    :OEO_00000504 :OEO_00000242 ;
    :OEO_00010037 "CRF 2.G.4" ;
