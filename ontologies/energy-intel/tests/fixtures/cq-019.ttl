:OEO_00010078 a owl:Class ;
    rdfs:label "global warming potential"@en ;
    ns1:IAO_0000115 "Global warming potential (GWP) is a quantity value that measures the the time-integrated radiative forcing due to a pulse emission of a given component, relative to a pulse emission of an equal mass of carbon dioxide (CO2)." ;
    ns1:IAO_0000118 "Treibhauspotenzial"@de,
        "GWP"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :OEO_00040010 ;
            owl:someValuesFrom ns1:UO_0010006 ],
