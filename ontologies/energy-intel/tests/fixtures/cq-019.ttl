:OEO_00240012 a owl:Class ;
    rdfs:label "gross electricity generation"@en ;
    ns1:IAO_0000115 "Gross electricity generation is a process attribute that refers to the total amount of electrical energy produced in an electricity generation process."@en ;
    ns1:IAO_0000118 "Bruttostromerzeugung"@de,
        "gross electricity production"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :OEO_00140002 ;
            owl:someValuesFrom :OEO_00050019 ],
        :OEO_00030019 ;
    :OEO_00020425 "study descriptor" ;
    :OEO_00020426 """issue: https://github.com/OpenEnergyPlatform/ontology/issues/917
pull request: https://github.com/OpenEnergyPlatform/ontology/pull/932
add oekg annotation
issue: https://github.com/OpenEnergyPlatform/ontology/issues/1529
pull request: https://github.com/OpenEnergyPlatform/ontology/pull/1897""" .

:OEO_00240013 a owl:Class ;
    rdfs:label "net electricity generation"@en ;
    ns1:IAO_0000115 "Net electricity generation is a process attribute that equals to gross electricity generation minus the consumption of power stations' auxiliary services."@en ;
    ns1:IAO_0000118 "Nettostromerzeugung"@de,
        "net electricity production"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :OEO_00140002 ;
            owl:someValuesFrom :OEO_00050019 ],
        :OEO_00030019 ;
    :OEO_00020425 "study descriptor tag" ;
