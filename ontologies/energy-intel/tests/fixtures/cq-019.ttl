:OEO_00010190 a owl:NamedIndividual,
        :OEO_00010035 ;
    rdfs:label "CRF sector (IPCC 2006): cropland"@en ;
    ns1:IAO_0000115 """The CRF sector (IPCC 2006) 'cropland' is an agriculture, forestry and land use sector defined by the 2006 IPCC Guidelines for National Greenhouse Gas Inventories:
Emissions and removals from arable and tillage land, rice fields, and agro-forestry systems where vegetation falls below the thresholds used for the forest land category.""" ;
    ns1:IAO_0000119 "2006 IPCC Guidelines for National Greenhouse Gas Inventories, Volume 1, Chapter 8.5, https://www.ipcc-nggip.iges.or.jp/public/2006gl/" ;
    :OEO_00000504 :OEO_00000242 ;
    :OEO_00010037 "CRF 4.B" ;
