:OEO_00010365 a owl:NamedIndividual,
        :OEO_00000227 ;
    rdfs:label "CRF sector (IPCC 2006): photovoltaics"@en ;
    ns1:IAO_0000115 """The CRF sector (IPCC 2006) 'photovoltaics' is an industry sector defined by the 2006 IPCC Guidelines for National Greenhouse Gas Inventories:
Photovoltaic cell manufacture may use and emit CF4 and C2F6 among others.""" ;
    ns1:IAO_0000119 "2006 IPCC Guidelines for National Greenhouse Gas Inventories, Volume 1, Chapter 8.5, https://www.ipcc-nggip.iges.or.jp/public/2006gl/" ;
