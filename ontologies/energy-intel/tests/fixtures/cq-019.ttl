    owl:annotatedSource ns1:IAO_0000088 ;
    owl:annotatedTarget "Examples of reports are gene lists and investigation reports. These are not published (journal) articles but may be included in a journal article."@en ;
    prov:wasDerivedFrom <https://openenergyplatform.org/ontology/oeo/dev/imports/iao-extracted.owl> .

