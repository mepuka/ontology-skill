:OEO_00000391 a owl:Class ;
    rdfs:label "solid fossil fuel"@en ;
    ns1:IAO_0000115 "A solid fossil fuel is a fossil fuel that has a solid state of matter under normal conditions." ;
    ns1:IAO_0000118 "fossiler Festbrennstoff"@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :OEO_00000530 ;
            owl:someValuesFrom :OEO_00030002 ],
        [ a owl:Restriction ;
            owl:hasValue :OEO_00000390 ;
            owl:onProperty :OEO_00000529 ],
        :OEO_00000014 ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( :OEO_00000014 [ a owl:Restriction ;
                        owl:hasValue :OEO_00000390 ;
                        owl:onProperty :OEO_00000529 ] ) ] ;
    :OEO_00020426 """issue: https://github.com/OpenEnergyPlatform/ontology/issues/106
pull request: https://github.com/OpenEnergyPlatform/ontology/pull/164

Update definition and axioms:
pull request: https://github.com/OpenEnergyPlatform/ontology/pull/931""" .

