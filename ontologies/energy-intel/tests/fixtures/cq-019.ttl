:OEO_00320000 a owl:Class ;
    rdfs:label "transport performance value"@en ;
    ns1:IAO_0000115 "A transport performance value is a quantity value that indicates the performance of a transport process in terms of its mileage and amount of transported people and/or goods."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :OEO_00040010 ;
            owl:someValuesFrom :OEO_00320001 ],
        :OEO_00000350 ;
