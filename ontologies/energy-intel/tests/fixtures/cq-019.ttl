    rdfs:label "European Union Emissions Trading System"@en ;
    ns1:IAO_0000115 "The European Union Emissions Trading System (EU ETS) is a policy instrument that implements an emissions trading system covering the European Union, Norway, Iceland and Liechtenstein." ;
