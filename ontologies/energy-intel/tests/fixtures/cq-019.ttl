    rdfs:label "CRF sector (IPCC 2006): petrochemical and carbon black production"@en ;
    ns1:IAO_0000115 "The CRF sector (IPCC 2006) 'petrochemical and carbon black production' is an industry sector defined by the 2006 IPCC Guidelines for National Greenhouse Gas Inventories:" ;
    ns1:IAO_0000119 "2006 IPCC Guidelines for National Greenhouse Gas Inventories, Volume 1, Chapter 8.5, https://www.ipcc-nggip.iges.or.jp/public/2006gl/" ;
