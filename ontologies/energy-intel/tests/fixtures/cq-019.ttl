ns2:ont00000127 a owl:Class ;
    rdfs:label "Performance Specification"@en ;
    rdfs:comment """The CCO also assigns this class the following subclass axiom: 'describes condition' some entity
However, this was left out."""@en ;
    rdfs:isDefinedBy <https://openenergyplatform.org/ontology/oeo/imports/cco-extracted.owl> ;
    rdfs:subClassOf ns1:IAO_0000033 ;
    skos:definition "A Directive Information Content Entity that prescribes some aspect of the behavior of a participant in a Process given one or more operating conditions."@en ;
    skos:example "Maximum Speed at high altitude; Rate of Ascent at 10 degrees celsius with nominal payload." ;
    :OEO_00020426 """import from CCO
issue: https://github.com/OpenEnergyPlatform/ontology/issues/2107
pull request: https://github.com/OpenEnergyPlatform/ontology/pull/2108""" ;
    ns2:ont00001760 "https://www.commoncoreontologies.org/InformationEntityOntology"^^xsd:anyURI .

ns2:ont00000131 a owl:Class ;
    rdfs:label "Increase of Quality"@en ;
    rdfs:isDefinedBy <https://openenergyplatform.org/ontology/oeo/imports/cco-extracted.owl> ;
    rdfs:subClassOf ns2:ont00001214 ;
    skos:definition "An Increase of Specifically Dependent Continuant in which some Indpendent Continuant has an increase of some Quality that it bears."@en ;
    ns2:ont00001760 "https://www.commoncoreontologies.org/EventOntology"^^xsd:anyURI .

ns1:UO_0000217 a owl:Class ;
    rdfs:label "electric potential difference unit" ;
    ns1:IAO_0000115 "\"A unit which is a standard measure of the work done per unit charge as a charge is moved between two points in an electric field.\" [Wikipedia:Wikipedia]" ;
    rdfs:isDefinedBy ns1:uo.owl ;
    rdfs:subClassOf :OEO_00010490 ;
    :OEO_00020426 """make subclass of 'physical unit'
