:OEO_00400014 a owl:NamedIndividual,
        :OEO_00400013 ;
    rdfs:label "ambiguous uncertainty"@en ;
    ns1:IAO_0000115 "Ambiguous uncertainty is a nature of model uncertainty that stems from multiple frames of reference about a phenomenon existing similtaneously." ;
    ns1:IAO_0000118 "ambiguity of uncertainty"@en ;
    ns1:IAO_0000119 "https://www.researchgate.net/publication/264816512_Classifying_and_communicating_uncertainties_in_model-based_policy_analysis" ;
    :OEO_00020426 """issue: https://github.com/OpenEnergyPlatform/ontology/issues/1829
pull request: https://github.com/OpenEnergyPlatform/ontology/pull/1945""" .

:OEO_00400015 a owl:NamedIndividual,
        :OEO_00400013 ;
    rdfs:label "epistemological uncertainty"@en ;
    ns1:IAO_0000115 "Epistemological uncertainty is a nature of model uncertainty that stems from a lack of knowledge about a certain phenomenon." ;
    ns1:IAO_0000118 "epistemology of uncertainty"@en ;
    ns1:IAO_0000119 "https://www.researchgate.net/publication/264816512_Classifying_and_communicating_uncertainties_in_model-based_policy_analysis" ;
    :OEO_00020426 """issue: https://github.com/OpenEnergyPlatform/ontology/issues/1829
pull request: https://github.com/OpenEnergyPlatform/ontology/pull/1945""" .

:OEO_00400016 a owl:NamedIndividual,
        :OEO_00400013 ;
    rdfs:label "ontological uncertainty"@en ;
    ns1:IAO_0000115 "Ontological uncertainty is a nature of model uncertainty that stems from inherent variability of a phenomenon." ;
    ns1:IAO_0000118 "ontology of uncertainty"@en ;
    ns1:IAO_0000119 "https://www.researchgate.net/publication/264816512_Classifying_and_communicating_uncertainties_in_model-based_policy_analysis" ;
    :OEO_00020426 """issue: https://github.com/OpenEnergyPlatform/ontology/issues/1829
pull request: https://github.com/OpenEnergyPlatform/ontology/pull/1945""" .

:OEO_00400018 a owl:NamedIndividual,
        :OEO_00400017 ;
    rdfs:label "shallow uncertainty"@en ;
    ns1:IAO_0000115 "Shallow uncertainty is a level of model uncertainty at which one can enumerate multiple alternatives and provide probabilites(subjective or objective) for them." ;
    ns1:IAO_0000119 "https://www.researchgate.net/publication/264816512_Classifying_and_communicating_uncertainties_in_model-based_policy_analysis" ;
    :OEO_00020426 """issue: https://github.com/OpenEnergyPlatform/ontology/issues/1829
pull request: https://github.com/OpenEnergyPlatform/ontology/pull/1945""" .

:OEO_00400019 a owl:NamedIndividual,
