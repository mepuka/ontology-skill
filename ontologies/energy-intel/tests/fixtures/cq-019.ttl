:OEO_00010363 a owl:NamedIndividual,
        :OEO_00000227 ;
    rdfs:label "CRF sector (IPCC 2006): integrated circuit or semiconductor"@en ;
    ns1:IAO_0000115 """The CRF sector (IPCC 2006) 'integrated circuit or semiconductor' is an industry sector defined by the 2006 IPCC Guidelines for National Greenhouse Gas Inventories:
Emissions of CF4, C2F6, C3F8, c-C4F8, C4F6, C4F8O, C5F8, CHF3, CH2F2, NF3 and SF6 from uses of these gases in Integrated Circuit (IC) manufacturing in rapidly evolving ways and in varying amounts, which depend on product
(e.g., memory or logic devices) and equipment manufacturer.""" ;
    ns1:IAO_0000119 "2006 IPCC Guidelines for National Greenhouse Gas Inventories, Volume 1, Chapter 8.5, https://www.ipcc-nggip.iges.or.jp/public/2006gl/" ;
    :OEO_00000504 :OEO_00000242 ;
    :OEO_00010037 "CRF 2.E.1" ;
