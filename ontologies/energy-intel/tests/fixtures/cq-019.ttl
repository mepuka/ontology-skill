            owl:someValuesFrom :OEO_00010130 ],
        owl:NamedIndividual,
        :OEO_00140150 ;
    rdfs:label "EU climate policy"@en ;
    ns1:IAO_0000115 "The EU climate policy is the policy of the European Union for reducing greenhouse gas emissions. It uses an EU emission sector division." ;
    ns1:IAO_0000118 "EU-Klimapolitik"@de ;
    :OEO_00020426 """issue: https://github.com/OpenEnergyPlatform/ontology/issues/834
