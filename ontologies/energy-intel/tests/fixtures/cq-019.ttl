    rdfs:label "steel"@en ;
    ns1:IAO_0000115 "Steel is a metal that consists mainly of iron and up to 2.14 % of carbon; other elements may be present. It has a solid normal state of matter. It has a solid normal state of matter. It is the physical output of an industrial process and has a commodity role."@en ;
    ns1:IAO_0000118 "Stahl"@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :OEO_00240025 ;
