ns2:ont00000004 a owl:Class ;
    rdfs:label "Change"@en ;
    rdfs:comment "In CCO, the SubClassOf axioms are actually anonymous ancestors and inherited from process (BFO 2020)." ;
    rdfs:isDefinedBy <https://openenergyplatform.org/ontology/oeo/imports/cco-extracted.owl> ;
    skos:definition "A Process in which some independent continuant endures and 1) one or more of the dependent entities it bears increase or decrease in intensity, 2) the entity begins to bear some dependent entity or 3) the entity ceases to bear some dependent entity."@en ;
    :OEO_00020426 """issue https://github.com/OpenEnergyPlatform/ontology/issues/2014
pull request: https://github.com/OpenEnergyPlatform/ontology/pull/2016""" ;
    ns2:ont00001760 "https://www.commoncoreontologies.org/EventOntology"^^xsd:anyURI .

ns2:ont00001942 a owl:ObjectProperty ;
    rdfs:label "prescribes"@en ;
    rdfs:isDefinedBy <https://openenergyplatform.org/ontology/oeo/imports/cco-extracted.owl> ;
    rdfs:subPropertyOf ns1:IAO_0000136 ;
    skos:definition "x prescribes y iff x is an instance of Information Content Entity and y is an instance of Entity, such that x serves as a rule or guide for y if y an Occurrent, or x serves as a model for y if y is a Continuant."@en ;
    skos:example "A blueprint prescribes some artifact or facility by being a model for it.",
        "A professional code of conduct prescribes some realizations of a profession (role) by giving rules for how the bearer should act in those realizations.",
        "An operations plan prescribes an operation by enumerating the tasks that need to be performed in order to achieve the objectives of the operation." ;
    ns2:ont00001760 "https://www.commoncoreontologies.org/InformationEntityOntology"^^xsd:anyURI .

ns1:IAO_0000007 a owl:Class ;
    rdfs:label "action specification"@en ;
    ns1:IAO_0000112 "Pour the contents of flask 1 into flask 2"@en ;
    ns1:IAO_0000114 ns1:IAO_0000122 ;
    ns1:IAO_0000115 "A directive information entity that describes an action the bearer will take."@en ;
    ns1:IAO_0000117 "Alan Ruttenberg"@en ;
    ns1:IAO_0000119 "OBI Plan and Planned Process branch"@en ;
    rdfs:isDefinedBy <https://openenergyplatform.org/ontology/oeo/imports/iao-extracted.owl> ;
    rdfs:subClassOf ns1:IAO_0000033 .

ns1:UO_0000218 a owl:Class ;
    rdfs:label "volt" ;
    ns1:IAO_0000115 "\"An electric potential difference unit which is equal to the work per unit charge. One volt is the potential difference required to move one coulomb of charge between two points in a circuit while using one joule of energy.\" [Wikipedia:Wikipedia]" ;
    ns3:hasExactSynonym "V" ;
    rdfs:isDefinedBy ns1:uo.owl ;
    rdfs:subClassOf ns1:UO_1000218 .

:OEO_00000150 a owl:Class ;
    rdfs:label "energy"@en ;
    ns1:IAO_0000115 "Energy is a quality of material entities which manifests as a capacity to perform work (such as causing motion or the interaction of molecules)" ;
    ns1:IAO_0000118 "Energie"@de ;
    ns1:IAO_0000119 "Derived from https://www.lexico.com/en/definition/energy" ;
    rdfs:comment "Energy is power integrated over time." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :OEO_00000530 ;
            owl:someValuesFrom :OEO_00000316 ] ;
    skos:closeMatch ns1:ENVO_2000015 ;
    :OEO_00020426 """issue: https://github.com/OpenEnergyPlatform/ontology/issues/224
pull request: https://github.com/OpenEnergyPlatform/ontology/pull/364
fix grammar error:
pull request: https://github.com/OpenEnergyPlatform/ontology/pull/657
