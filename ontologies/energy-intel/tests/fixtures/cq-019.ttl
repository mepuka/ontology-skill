:OEO_00010338 a owl:NamedIndividual,
        :OEO_00000367 ;
    rdfs:label "CRF sector (IPCC 2006): transport of CO2"@en ;
    ns1:IAO_0000115 """The CRF sector (IPCC 2006) 'transport of CO2' is a sector defined by the 2006 IPCC Guidelines for National Greenhouse Gas Inventories:
This comprises fugitive emissions from the systems used to transport captured CO2 from the source to the injection site. These emissions may comprise losses due to fugitive equipment leaks, venting and releases due to pipeline
ruptures or other accidental releases (e.g., temporary storage).""" ;
    ns1:IAO_0000119 "2006 IPCC Guidelines for National Greenhouse Gas Inventories, Volume 1, Chapter 8.5, https://www.ipcc-nggip.iges.or.jp/public/2006gl/" ;
    :OEO_00000504 :OEO_00000242 ;
