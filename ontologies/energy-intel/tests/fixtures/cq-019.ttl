:OEO_00320041 a owl:Class ;
    rdfs:label "vehicle operational mode"@en ;
    ns1:IAO_0000115 "A vehicle operational mode is a realizable entity that determines how a vehicle is operating."@en ;
    ns1:IAO_0000118 "Fahrzeugbetriebsmodus"@de ;
