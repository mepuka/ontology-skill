        :OEO_00010123 ;
    rdfs:label "Effort Sharing Decision"@en ;
    ns1:IAO_0000115 "The Effort Sharing Decision (ESD) is the European effort sharing for the years 2013-2020. It covers the European Union, Norway, Iceland and Liechtenstein and the following greenhouse gases: carbon dioxide, methane, nitrous oxide, hydrofluorocarbons, perfluorocarbons and sulphur hexafluoride. Emission quantities under the ESD are calculated using global warming potentials from the Fourth IPCC Assessment Report." ;
    ns1:IAO_0000118 "ESD",
        "Lastenteilungsentscheidung"@de ;
    :OEO_00020426 """issue: https://github.com/OpenEnergyPlatform/ontology/issues/834
