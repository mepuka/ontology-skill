:OEO_00010404 a owl:Class ;
    rdfs:label "energy balance data set"@en ;
    ns1:IAO_0000115 "An energy balance data set is an empirical data set that describes a specified set of energy transformations and a specified set of energy carriers in a spatial region for a specific time step (usually a year)." ;
    ns1:IAO_0000118 "Energiebilanzdatensatz"@de ;
