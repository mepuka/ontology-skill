:OEO_00320001 a owl:Class ;
    rdfs:label "transport performance unit"@en ;
    ns1:IAO_0000115 "A transport performance unit is a unit of measurement for the accumulated transport distance of a number of people and/or amount of goods." ;
    rdfs:subClassOf :OEO_00010490 ;
    :OEO_00020426 """issue: https://github.com/OpenEnergyPlatform/ontology/issues/1272
