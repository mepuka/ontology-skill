:OEO_00010366 a owl:NamedIndividual,
        :OEO_00000227 ;
    rdfs:label "CRF sector (IPCC 2006): heat transfer fluid"@en ;
    ns1:IAO_0000115 """The CRF sector (IPCC 2006) 'heat transfer fluid' is an industry sector defined by the 2006 IPCC Guidelines for National Greenhouse Gas Inventories:
Heat transfer fluids, which include several fully fluorinated carbon compounds (either in pure form or in mixtures) with six or more carbon atoms, used and emitted during IC manufacture, testing and assembly. They are used in chillers, temperature shock testers and vapour phase reflow soldering.""" ;
    ns1:IAO_0000119 "2006 IPCC Guidelines for National Greenhouse Gas Inventories, Volume 1, Chapter 8.5, https://www.ipcc-nggip.iges.or.jp/public/2006gl/" ;
    :OEO_00000504 :OEO_00000242 ;
    :OEO_00010037 "CRF 2.E.4" ;
