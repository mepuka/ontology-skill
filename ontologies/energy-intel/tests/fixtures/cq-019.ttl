pull request: https://github.com/OpenEnergyPlatform/ontology/pull/1652""" .

:OEO_00010079 a owl:Class ;
    rdfs:label "emission value"@en ;
    ns1:IAO_0000115 "An emission value is a quantity value that quantifies an emission rate and has a mass unit."@en ;
    ns1:IAO_0000118 "emission quantity value",
        "Emissionswert"@de ;
    ns1:IAO_0000600 "It can be calculated using the an emission factor." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :OEO_00020056 ;
            owl:someValuesFrom :OEO_00020063 ],
