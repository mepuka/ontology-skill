:OEO_00240027 a owl:Class ;
    rdfs:label "chemical substance"@en ;
    ns1:IAO_0000115 "A chemical substance is a portion of matter of constant composition and that is neither a metal or mineral. It is composed of molecular entities of the same type or of different types that is used in or produced by a chemical reaction involving changes to atoms or molecules. It is the physical output of an industrial process and has a commodity role."@en ;
    ns1:IAO_0000118 "chemische Substanz"@de ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :OEO_00240025 ;
            owl:someValuesFrom :OEO_00050000 ],
        [ a owl:Restriction ;
            owl:onProperty :OEO_00240025 ;
            owl:someValuesFrom :OEO_00140033 ],
        :OEO_00000331 ;
