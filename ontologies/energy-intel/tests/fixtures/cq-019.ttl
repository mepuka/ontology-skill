ns2:ont00001920 a owl:ObjectProperty ;
    rdfs:label "prescribed by"@en ;
    rdfs:isDefinedBy <https://openenergyplatform.org/ontology/oeo/imports/cco-extracted.owl> ;
    rdfs:subPropertyOf :OEO_00010231 ;
    owl:inverseOf ns2:ont00001942 ;
    skos:definition "x prescribed_by y iff y is an instance of Information Content Entity and x is an instance of Entity, such that y serves as a rule or guide for x if x is an Occurrent, or y serves as a model for x if x is a Continuant."@en ;
    ns2:ont00001760 "https://www.commoncoreontologies.org/InformationEntityOntology"^^xsd:anyURI .

ns1:UO_0000186 a owl:Class ;
    rdfs:label "dimensionless unit" ;
    ns1:IAO_0000115 "\"A unit which is a standard measure of physical quantity consisting of only a numerical number without any units.\" [Wikipedia:Wikipedia]" ;
    rdfs:isDefinedBy ns1:uo.owl ;
    rdfs:subClassOf :OEO_00010490 ;
    :OEO_00020426 """make subclass of 'physical unit'
issue: https://github.com/OpenEnergyPlatform/ontology/issues/2135
pull request: https://github.com/OpenEnergyPlatform/ontology/pull/2141""" .

ns1:UO_0000190 a owl:Class ;
    rdfs:label "ratio unit" ;
    ns1:IAO_0000115 "\"A dimensionless unit which denotes an amount or magnitude of one quantity relative to another.\" [Wikipedia:Wikipedia]" ;
    rdfs:isDefinedBy ns1:uo.owl ;
    rdfs:subClassOf ns1:UO_0000186 .

ns1:UO_0010006 a owl:Class ;
    rdfs:label "ratio" ;
    ns1:IAO_0000115 "\"A dimensionless ratio unit which, given a pair of quantities a and b, for which b is a multiple of a, denotes b by giving the multiplier (coefficient) c for a to result in b.\" [UOB:LKSR]" ;
    rdfs:isDefinedBy ns1:uo.owl ;
    rdfs:subClassOf ns1:UO_0000190 .

owl:topObjectProperty a owl:ObjectProperty ;
    rdfs:isDefinedBy <https://openenergyplatform.org/ontology/oeo/imports/iao-extracted.owl> .

skos:closeMatch a owl:AnnotationProperty .

:OEO_00000182 a owl:NamedIndividual,
        :OEO_00000395 ;
    rdfs:label "gaseous"@en ;
    ns1:IAO_0000115 "The state of being a gas. A portion of matter is in gaseous state if and only if it has no definite shape and no definite volume and is not electrically conductive." ;
    ns1:IAO_0000118 "gasförmig"@de ;
    :OEO_00020426 """move to oeo-shared:
issue: https://github.com/OpenEnergyPlatform/ontology/issues/1384
pull request: https://github.com/OpenEnergyPlatform/ontology/pull/1390,
restructure modules:
issue: https://github.com/OpenEnergyPlatform/ontology/issues/1592
pull request: https://github.com/OpenEnergyPlatform/ontology/pull/1652

Fix definition:
https://github.com/OpenEnergyPlatform/ontology/pull/1980""" .

:OEO_00000256 a owl:NamedIndividual,
        :OEO_00000395 ;
    rdfs:label "liquid"@en ;
    ns1:IAO_0000115 "The state of being liquid. A portion of matter is liquid has no definite shape but a definite volume (at a given temperature and pressure)." ;
    ns1:IAO_0000118 "flüssig"@de ;
    :OEO_00020426 """restructure modules:
issue: https://github.com/OpenEnergyPlatform/ontology/issues/1592
pull request: https://github.com/OpenEnergyPlatform/ontology/pull/1652""" .

