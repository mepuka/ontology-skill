PREFIX rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX dcat: <http://www.w3.org/ns/dcat#>
PREFIX ei:   <https://w3id.org/energy-intel/>

# CQ-005 (must_have, UC-002)
# For a given CanonicalMeasurementClaim, which Distribution does it reference?
# Expected: 0..1 rows.
# Derivation: direct_lookup.

SELECT ?distribution WHERE {
  <https://id.skygest.io/cmc/cmc_01J_example> ei:referencesDistribution ?distribution .
  ?distribution a dcat:Distribution .
}
