PREFIX rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX ei:   <https://w3id.org/energy-intel/>

# CQ-004 (must_have, UC-002)
# For a given CanonicalMeasurementClaim, which Series does it reference?
# Expected: 0..1 rows.
# Derivation: direct_lookup.

SELECT ?series WHERE {
  <https://id.skygest.io/cmc/cmc_01J_example> ei:referencesSeries ?series .
  ?series a ei:Series .
}
