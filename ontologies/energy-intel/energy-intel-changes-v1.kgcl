add_axiom ei:shape/CanonicalUnitInQudtSubset a sh:NodeShape           # S-V1-1
add_axiom ei:shape/ResolvabilityGate a sh:NodeShape                    # S-V1-2
add_axiom ei:shape/PostAuthorBearsEnergyExpertRole a sh:NodeShape      # S-V1-3
add_axiom ei:shape/PodcastSpeakerBearsEnergyExpertRole a sh:NodeShape  # S-V1-4
