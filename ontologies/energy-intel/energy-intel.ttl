@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix ei: <https://w3id.org/energy-intel/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ei:energy-intel a owl:Ontology ;
    dcterms:created "2026-04-22"^^xsd:date ;
    dcterms:creator "energy-intel / ontology-architect"@en ;
    dcterms:description "Top-level energy-intel ontology. Imports the five authored modules (agent, media, measurement, data, editorial), the hand-seeded SKOS schemes (aggregation-type, temporal-resolution, argument-pattern, narrative-role, oeo-topics), and the declared external ontologies. V2 (2026-05-04) adds the editorial extension: ei:Narrative + ei:NarrativePostMembership classes, 6 object properties, 3 new SKOS schemes (argument-pattern, narrative-role, oeo-topics with split + aggregator structure), the rebuilt OEO topic subset, and SHACL editorial shapes. V2 retires V1's modules/concept-schemes/technology-seeds.ttl from the import closure (oeo-topics replaces it as runtime authority); the file is preserved on disk for V0/V1 fixture compatibility."@en ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:modified "2026-05-04"^^xsd:date ;
    dcterms:title "energy-intel — top-level ontology"@en ;
    owl:imports <http://purl.obolibrary.org/obo/bfo.owl>,
        <http://purl.obolibrary.org/obo/iao.owl>,
        dcterms:,
        <http://www.w3.org/2004/02/skos/core>,
        <http://www.w3.org/ns/dcat>,
        <http://www.w3.org/ns/prov-o>,
        foaf:,
        <https://w3id.org/energy-intel/imports/oeo-carrier-subset>,
        <https://w3id.org/energy-intel/imports/oeo-technology-subset>,
        <https://w3id.org/energy-intel/imports/oeo-topic-subset>,
        <https://w3id.org/energy-intel/imports/qudt-units-subset>,
        <https://w3id.org/energy-intel/modules/agent>,
        <https://w3id.org/energy-intel/modules/concept-schemes/aggregation-type>,
        <https://w3id.org/energy-intel/modules/concept-schemes/argument-pattern>,
        <https://w3id.org/energy-intel/modules/concept-schemes/narrative-role>,
        <https://w3id.org/energy-intel/modules/concept-schemes/oeo-topics>,
        <https://w3id.org/energy-intel/modules/concept-schemes/temporal-resolution>,
        <https://w3id.org/energy-intel/modules/data>,
        <https://w3id.org/energy-intel/modules/editorial>,
        <https://w3id.org/energy-intel/modules/measurement>,
        <https://w3id.org/energy-intel/modules/media> ;
    owl:versionIRI <https://w3id.org/energy-intel/v2/2026-05-04> ;
    owl:versionInfo "v2 (2026-05-04)" .
