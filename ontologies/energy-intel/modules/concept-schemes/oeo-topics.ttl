    skos:closeMatch oeo:OEO_00020063,
        oeo:OEO_00020075 ;
    skos:definition "Editorial umbrella for carbon-credit and emissions-trading markets."@en ;
    skos:inScheme <https://w3id.org/energy-intel/concept/editorial-supplement>,
        <https://w3id.org/energy-intel/concept/topic> ;
