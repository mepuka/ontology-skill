<https://w3id.org/energy-intel/concept/editorial-supplement> a owl:NamedIndividual,
        skos:ConceptScheme ;
    rdfs:label "editorial supplement topic"@en ;
    skos:definition "Skygest-coined umbrella topic concepts. Each member is a skos:Concept individual in the https://w3id.org/energy-intel/concept/ namespace, carrying a skos:notation with the legacy editorial topic_slug."@en ;
    skos:hasTopConcept <https://w3id.org/energy-intel/concept/biomass>,
        <https://w3id.org/energy-intel/concept/carbon-markets>,
        <https://w3id.org/energy-intel/concept/climate-and-emissions>,
