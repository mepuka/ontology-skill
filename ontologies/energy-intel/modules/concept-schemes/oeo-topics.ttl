<https://w3id.org/energy-intel/concept/biomass> a owl:NamedIndividual,
        skos:Concept ;
    rdfs:label "biomass (editorial umbrella)"@en ;
    skos:closeMatch oeo:OEO_00010214,
        oeo:OEO_00010258 ;
    skos:definition "Editorial umbrella for biomass and bioenergy, broader than OEO_00010258/_00010214 alone — covers materials, conversion, and sustainability debates. Label disambiguated from OEO_00010214 (biomass material) and OEO_00010258 (bioenergy)."@en ;
    skos:inScheme <https://w3id.org/energy-intel/concept/editorial-supplement>,
        <https://w3id.org/energy-intel/concept/topic> ;
    skos:notation "biomass" ;
    skos:prefLabel "biomass (editorial umbrella)"@en ;
    skos:topConceptOf <https://w3id.org/energy-intel/concept/editorial-supplement> .

