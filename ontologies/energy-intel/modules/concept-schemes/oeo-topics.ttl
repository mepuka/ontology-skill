        <https://w3id.org/energy-intel/concept/energy-finance>,
        <https://w3id.org/energy-intel/concept/energy-geopolitics>,
        <https://w3id.org/energy-intel/concept/energy-justice>,
        <https://w3id.org/energy-intel/concept/energy-markets>,
        <https://w3id.org/energy-intel/concept/energy-policy>,
        <https://w3id.org/energy-intel/concept/energy-storage>,
        <https://w3id.org/energy-intel/concept/environment-and-land-use>,
        <https://w3id.org/energy-intel/concept/grid-and-infrastructure>,
        <https://w3id.org/energy-intel/concept/research-and-innovation>,
        <https://w3id.org/energy-intel/concept/sectoral-decarbonization>,
        <https://w3id.org/energy-intel/concept/workforce-and-manufacturing> ;
    skos:prefLabel "editorial supplement topic"@en .

<https://w3id.org/energy-intel/concept/oeo-topic> a owl:NamedIndividual,
        skos:ConceptScheme ;
    rdfs:label "OEO topic"@en ;
    skos:definition "OEO classes admitted as runtime topic catalog members. Each member is an OEO class IRI, admitted as a skos:Concept individual via OWL 2 punning."@en ;
    skos:prefLabel "OEO topic"@en .

<https://w3id.org/energy-intel/concept/topic> a owl:NamedIndividual,
        skos:ConceptScheme ;
    rdfs:label "energy topic (aggregator)"@en ;
    skos:definition "Aggregator scheme over ei:concept/oeo-topic and ei:concept/editorial-supplement. Runtime queries (CQ-N4) target this scheme."@en ;
    skos:prefLabel "energy topic (aggregator)"@en .
