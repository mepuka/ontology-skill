@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix enews: <http://example.org/ontology/energy-news#> .
@prefix obo: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix sioc: <http://rdfs.org/sioc/ns#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/ontology/energy-news> a owl:Ontology ;
    dcterms:created "2026-02-11" ;
    dcterms:creator "ontology-architect skill" ;
    dcterms:description "A lightweight OWL 2 DL ontology modeling the energy news media landscape as observed through social media posts."@en ;
    dcterms:license <https://spdx.org/licenses/MIT> ;
    dcterms:modified "2026-02-12" ;
    dcterms:title "Energy News Ontology"@en ;
    owl:imports <http://example.org/ontology/energy-news/bfo-declarations>,
        <http://example.org/ontology/energy-news/reference-individuals>,
        <http://example.org/ontology/energy-news/schema-declarations> ;
    owl:priorVersion <http://example.org/ontology/energy-news/0.1.0> ;
    owl:versionIRI <http://example.org/ontology/energy-news/0.2.0> ;
    owl:versionInfo "0.2.0" .

enews:altText a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "alt text"@en ;
    rdfs:domain enews:MediaAttachment ;
    rdfs:range xsd:string ;
    skos:definition "The alternative text description for the media attachment"@en .

enews:altTextProvenance a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "alt text provenance"@en ;
    rdfs:domain enews:MediaAttachment ;
    rdfs:range skos:Concept ;
    skos:definition "Links a MediaAttachment to the provenance category of its alt text"@en .

enews:axisLabel a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "axis label"@en ;
    rdfs:domain enews:ChartAxis ;
    rdfs:range xsd:string ;
    skos:definition "The text label of a chart axis"@en .

enews:axisUnit a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "axis unit"@en ;
    rdfs:domain enews:ChartAxis ;
    rdfs:range xsd:string ;
    skos:definition "The unit of measurement for a chart axis"@en .

enews:containsChart a owl:ObjectProperty ;
    rdfs:label "contains chart"@en ;
    rdfs:domain enews:DocumentExcerpt ;
    rdfs:range enews:Chart ;
    skos:definition "Links a DocumentExcerpt to a Chart embedded within it"@en .

enews:description a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "description"@en ;
    rdfs:domain enews:Article ;
    rdfs:range xsd:string ;
    owl:equivalentProperty schema:description ;
    skos:definition "The description or summary text of an Article"@en .

enews:endDate a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "end date"@en ;
    rdfs:domain enews:TemporalCoverage ;
    rdfs:range xsd:date ;
    skos:definition "The end date of a temporal coverage period"@en .

enews:hasGeographicFocus a owl:ObjectProperty ;
    rdfs:label "has geographic focus"@en ;
    rdfs:domain enews:Article ;
    rdfs:range enews:GeographicEntity ;
    owl:equivalentProperty schema:contentLocation ;
    skos:definition "Links an Article to a GeographicEntity representing its geographic focus"@en .

enews:hasSector a owl:ObjectProperty ;
    rdfs:label "has sector"@en ;
    rdfs:domain enews:Organization ;
    rdfs:range enews:EnergyTopic ;
    skos:definition "Links an Organization to an EnergyTopic sector it operates in"@en .

enews:hasSeries a owl:ObjectProperty ;
    rdfs:label "has series"@en ;
    rdfs:domain enews:Chart ;
    rdfs:range enews:ChartSeries ;
    skos:definition "Links a Chart to a data series plotted in it"@en .

enews:hasSourceLine a owl:ObjectProperty ;
    rdfs:label "has source line"@en ;
    rdfs:domain enews:Chart ;
    rdfs:range enews:ChartSourceLine ;
    skos:definition "Links a Chart to its source attribution text"@en .

enews:hasTemporalCoverage a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "has temporal coverage"@en ;
    rdfs:domain enews:Chart ;
    rdfs:range enews:TemporalCoverage ;
    skos:definition "Links a Chart to the time period it covers"@en .

enews:keyFinding a owl:DatatypeProperty ;
    rdfs:label "key finding"@en ;
    rdfs:domain enews:Chart ;
    rdfs:range xsd:string ;
    skos:definition "A key finding or takeaway extracted from a chart"@en .

enews:legendLabel a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "legend label"@en ;
    rdfs:domain enews:ChartSeries ;
    rdfs:range xsd:string ;
    skos:definition "The legend label text for a data series"@en .

enews:mediaUrl a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "media url"@en ;
    rdfs:domain enews:MediaAttachment ;
    rdfs:range xsd:anyURI ;
    skos:definition "The URL of the media resource"@en .

enews:mentionsOrganization a owl:ObjectProperty ;
    rdfs:label "mentions organization"@en ;
    rdfs:domain enews:Article ;
    rdfs:range enews:Organization ;
    rdfs:subPropertyOf schema:mentions ;
    skos:definition "Links an Article to an Organization mentioned in its coverage"@en .

enews:publishedBy a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "published by"@en ;
    rdfs:domain enews:Article ;
    rdfs:range enews:Publication ;
    owl:equivalentProperty schema:publisher ;
    skos:definition "Links an Article to the Publication that published it"@en .

enews:publishedDate a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "published date"@en ;
    rdfs:domain enews:Article ;
    rdfs:range xsd:dateTime ;
    owl:equivalentProperty schema:datePublished ;
    skos:definition "The publication date of an Article"@en .

enews:seriesUnit a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "series unit"@en ;
    rdfs:domain enews:ChartSeries ;
    rdfs:range xsd:string ;
    skos:definition "The unit of measurement for a data series"@en .

enews:sharesArticle a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "shares article"@en ;
    rdfs:domain enews:Post ;
    rdfs:range enews:Article ;
    owl:equivalentProperty schema:sharedContent ;
    skos:definition "Links a Post to the Article it shares via embedded link"@en .

enews:sourceText a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "source text"@en ;
    rdfs:domain enews:ChartSourceLine ;
    rdfs:range xsd:string ;
    skos:definition "The raw source attribution text appearing on a chart"@en .

enews:startDate a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "start date"@en ;
    rdfs:domain enews:TemporalCoverage ;
    rdfs:range xsd:date ;
    skos:definition "The start date of a temporal coverage period"@en .

enews:thumbnailUrl a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "thumbnail url"@en ;
    rdfs:domain enews:MediaAttachment ;
    rdfs:range xsd:anyURI ;
    skos:definition "The URL of the thumbnail image"@en .

enews:title a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "title"@en ;
    rdfs:domain enews:Article ;
    rdfs:range xsd:string ;
    owl:equivalentProperty schema:headline ;
    skos:definition "The headline or title string of an Article"@en .

dcterms:source a owl:ObjectProperty .

dcterms:spatial a owl:ObjectProperty .

prov:wasAttributedTo a owl:ObjectProperty .

prov:wasDerivedFrom a owl:ObjectProperty .

enews:EnergyDataset a owl:Class ;
    rdfs:label "energy dataset"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty enews:providedBy ;
            owl:someValuesFrom enews:EnergyDataProvider ],
        obo:BFO_0000031,
        schema:Dataset ;
    skos:definition "A specific dataset published by an EnergyDataProvider"@en .

enews:Feed a owl:Class ;
    rdfs:label "feed"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty enews:onPlatform ;
            owl:someValuesFrom enews:SocialMediaPlatform ],
        obo:BFO_0000031 ;
    skos:definition "A GenericallyDependentContinuant that represents a curated social media feed for energy content"@en .

enews:Infographic a owl:Class ;
    rdfs:label "infographic"@en ;
    rdfs:subClassOf enews:MediaAttachment,
        obo:BFO_0000031 ;
    skos:definition "A MediaAttachment that is a designed visual composition combining data, text, and graphics"@en .

enews:Photo a owl:Class ;
    rdfs:label "photo"@en ;
    rdfs:subClassOf enews:MediaAttachment,
        obo:BFO_0000031,
        schema:ImageObject ;
    skos:definition "A MediaAttachment that is a photographic image of a real-world scene"@en .

enews:VideoAttachment a owl:Class ;
    rdfs:label "video attachment"@en ;
    rdfs:subClassOf enews:MediaAttachment,
        obo:BFO_0000031,
        schema:VideoObject ;
    skos:definition "A MediaAttachment that is a video recording or animation"@en .

enews:chartType a owl:ObjectProperty ;
    rdfs:label "chart type"@en ;
    rdfs:domain enews:Chart ;
    rdfs:range skos:Concept ;
    skos:definition "Links a Chart to its visualization type classification"@en .

enews:coversTopic a owl:ObjectProperty ;
    rdfs:label "covers topic"@en ;
    rdfs:domain enews:Article ;
    rdfs:range enews:EnergyTopic ;
    owl:equivalentProperty schema:about ;
    skos:definition "Links an Article to an EnergyTopic individual it covers"@en .

enews:handle a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "handle"@en ;
    rdfs:domain enews:AuthorAccount ;
    rdfs:range xsd:string ;
    skos:definition "The handle or username string for an AuthorAccount"@en .

enews:hasXAxis a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "has x axis"@en ;
    rdfs:domain enews:Chart ;
    rdfs:range enews:ChartAxis ;
    skos:definition "Links a Chart to its x-axis"@en .

enews:hasYAxis a owl:ObjectProperty ;
    rdfs:label "has y axis"@en ;
    rdfs:domain enews:Chart ;
    rdfs:range enews:ChartAxis ;
    skos:definition "Links a Chart to a y-axis"@en .

enews:postedBy a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "posted by"@en ;
    rdfs:domain enews:Post ;
    rdfs:range enews:AuthorAccount ;
    rdfs:subPropertyOf schema:author ;
    skos:definition "Links a Post to the AuthorAccount who created it"@en .

enews:providedBy a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "provided by"@en ;
    rdfs:domain enews:EnergyDataset ;
    rdfs:range enews:EnergyDataProvider ;
    skos:definition "Links an EnergyDataset to its provider organization"@en .

enews:siteDomain a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "site domain"@en ;
    rdfs:domain enews:Publication ;
    rdfs:range xsd:string ;
    skos:definition "The domain name string of a Publication"@en .

enews:url a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "url"@en ;
    rdfs:domain enews:Article ;
    rdfs:range xsd:anyURI ;
    owl:equivalentProperty schema:url ;
    skos:definition "The URL of an Article"@en .

enews:DocumentExcerpt a owl:Class ;
    rdfs:label "document excerpt"@en ;
    rdfs:subClassOf enews:MediaAttachment,
        obo:BFO_0000031 ;
    skos:definition "A MediaAttachment that is an extracted portion of a document, article, or report"@en .

enews:EnergyDataProvider a owl:Class ;
    rdfs:label "energy data provider"@en ;
    rdfs:subClassOf obo:BFO_0000030,
        schema:Organization ;
    skos:definition "An organization that publishes energy data accessible via API or download"@en .

enews:GeographicEntity a owl:Class ;
    rdfs:label "geographic entity"@en ;
    rdfs:subClassOf obo:BFO_0000029,
        schema:Place ;
    skos:definition "A Site that represents a country region or subnational area relevant to energy news coverage"@en .

enews:ChartSourceLine a owl:Class ;
    rdfs:label "chart source line"@en ;
    rdfs:subClassOf obo:BFO_0000031 ;
    skos:definition "The source attribution text appearing on a chart, typically at the bottom"@en .

enews:Organization a owl:Class ;
    rdfs:label "organization"@en ;
    rdfs:subClassOf obo:BFO_0000030 ;
    owl:equivalentClass schema:Organization ;
    skos:definition "An Object that represents a company agency or institutional body mentioned in energy news"@en .

enews:Post a owl:Class ;
    rdfs:label "post"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty enews:postedBy ;
            owl:someValuesFrom enews:AuthorAccount ],
        obo:BFO_0000031 ;
    owl:equivalentClass schema:SocialMediaPosting ;
    skos:definition "A GenericallyDependentContinuant that represents a social media post sharing energy content"@en .

enews:Publication a owl:Class ;
    rdfs:label "publication"@en ;
    rdfs:subClassOf obo:BFO_0000030,
        schema:NewsMediaOrganization ;
    owl:hasKey ( enews:siteDomain ) ;
    skos:definition "An Object that represents a news media outlet or website that publishes articles"@en .

enews:TemporalCoverage a owl:Class ;
    rdfs:label "temporal coverage"@en ;
    rdfs:subClassOf obo:BFO_0000008 ;
    skos:definition "A time period that a chart or visualization covers, with start and end dates"@en .

enews:onPlatform a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "on platform"@en ;
    rdfs:range enews:SocialMediaPlatform ;
    skos:definition "Links an AuthorAccount or Feed to the SocialMediaPlatform it belongs to"@en .

enews:AuthorAccount a owl:Class ;
    rdfs:label "author account"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty enews:onPlatform ;
            owl:someValuesFrom enews:SocialMediaPlatform ],
        obo:BFO_0000031 ;
    owl:equivalentClass sioc:UserAccount ;
    owl:hasKey ( enews:handle enews:onPlatform ) ;
    skos:definition "A GenericallyDependentContinuant that represents a social media account that shares energy news"@en ;
    skos:relatedMatch schema:Person .

enews:ChartSeries a owl:Class ;
    rdfs:label "chart series"@en ;
    rdfs:subClassOf obo:BFO_0000031 ;
    skos:definition "A named data series plotted within a chart"@en .

enews:EnergyTopic a owl:Class ;
    rdfs:label "energy topic"@en ;
    rdfs:subClassOf obo:BFO_0000031 ;
    skos:definition "An owl:Class whose instances are skos:Concept individuals representing subject areas within the energy sector used to classify news articles"@en .

enews:SocialMediaPlatform a owl:Class ;
    rdfs:label "social media platform"@en ;
    rdfs:subClassOf obo:BFO_0000031 ;
    skos:definition "An owl:Class whose instances are named individuals representing social media platforms"@en .

enews:ChartAxis a owl:Class ;
    rdfs:label "chart axis"@en ;
    rdfs:subClassOf obo:BFO_0000031 ;
    skos:definition "A dimensional axis of a chart with label, unit, and optional scale"@en .

enews:Chart a owl:Class ;
    rdfs:label "chart"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty enews:chartType ;
            owl:someValuesFrom skos:Concept ],
        [ a owl:Restriction ;
            owl:onProperty enews:hasXAxis ;
            owl:someValuesFrom enews:ChartAxis ],
        [ a owl:Restriction ;
            owl:onProperty enews:hasYAxis ;
            owl:someValuesFrom enews:ChartAxis ],
        enews:MediaAttachment,
        obo:BFO_0000031,
        schema:ImageObject ;
    skos:definition "A MediaAttachment that is a data visualization depicting quantitative information"@en .

enews:MediaAttachment a owl:Class ;
    rdfs:label "media attachment"@en ;
    rdfs:subClassOf obo:BFO_0000031 ;
    skos:definition "A digital resource attached to or embedded in a Post"@en .

enews:Article a owl:Class ;
    rdfs:label "article"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty enews:coversTopic ;
            owl:someValuesFrom enews:EnergyTopic ],
        obo:BFO_0000031,
        schema:NewsArticle ;
    owl:hasKey ( enews:url ) ;
    skos:definition "A GenericallyDependentContinuant that represents a news article referenced by an embedded link in a social media post"@en .

[] a owl:AllDisjointClasses ;
    owl:members ( enews:ChartAxis enews:ChartSeries enews:ChartSourceLine ) .

[] a owl:AllDisjointClasses ;
    owl:members ( enews:EnergyTopic enews:Article enews:Publication enews:Post enews:AuthorAccount enews:Feed enews:Organization enews:GeographicEntity enews:SocialMediaPlatform ) .

[] a owl:AllDisjointClasses ;
    owl:members ( enews:Chart enews:DocumentExcerpt enews:Photo enews:Infographic enews:VideoAttachment ) .
