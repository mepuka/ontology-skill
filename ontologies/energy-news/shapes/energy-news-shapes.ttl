@prefix enews: <http://example.org/ontology/energy-news#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

enews:ArticleShape a sh:NodeShape ;
    sh:property [ sh:maxCount 1 ;
            sh:path enews:title ],
        [ sh:maxCount 1 ;
            sh:path enews:publishedBy ],
        [ sh:datatype xsd:anyURI ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path enews:url ],
        [ sh:class enews:EnergyTopic ;
            sh:minCount 1 ;
            sh:path enews:coversTopic ],
        [ sh:maxCount 1 ;
            sh:path enews:description ],
        [ sh:maxCount 1 ;
            sh:path enews:publishedDate ] ;
    sh:sparql [ a sh:SPARQLConstraint ;
            sh:message "Article URL domain does not match its Publication siteDomain" ;
            sh:select """PREFIX enews: <http://example.org/ontology/energy-news#>
SELECT $this WHERE {
  $this enews:url ?url ;
        enews:publishedBy ?pub .
  ?pub enews:siteDomain ?siteDomain .
  BIND(REPLACE(STR(?url), "^https?://([^/]+).*$", "$1") AS ?urlDomain)
  BIND(IF(STRSTARTS(?urlDomain, "www."),
          SUBSTR(?urlDomain, 5),
          ?urlDomain) AS ?canonicalDomain)
  FILTER(?canonicalDomain != ?siteDomain)
}""" ] ;
    sh:targetClass enews:Article .

enews:AuthorAccountShape a sh:NodeShape ;
    sh:property [ sh:class enews:SocialMediaPlatform ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path enews:onPlatform ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path enews:handle ] ;
    sh:targetClass enews:AuthorAccount .

enews:ChartAxisShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:path enews:axisUnit ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path enews:axisLabel ] ;
    sh:targetClass enews:ChartAxis .

enews:ChartSeriesShape a sh:NodeShape ;
    sh:property [ sh:minCount 1 ;
            sh:path rdfs:label ] ;
    sh:targetClass enews:ChartSeries .

enews:ChartShape a sh:NodeShape ;
    sh:property [ sh:path enews:hasYAxis ],
        [ sh:maxCount 1 ;
            sh:path enews:hasXAxis ],
        [ sh:minCount 1 ;
            sh:path enews:chartType ],
        [ sh:path enews:hasSeries ] ;
    sh:targetClass enews:Chart .

enews:ChartSourceLineShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:minCount 1 ;
            sh:path enews:sourceText ] ;
    sh:targetClass enews:ChartSourceLine .

enews:DocumentExcerptShape a sh:NodeShape ;
    sh:targetClass enews:DocumentExcerpt .

enews:EnergyDataProviderShape a sh:NodeShape ;
    sh:property [ sh:minCount 1 ;
            sh:path rdfs:label ] ;
    sh:targetClass enews:EnergyDataProvider .

enews:EnergyDatasetShape a sh:NodeShape ;
    sh:property [ sh:minCount 1 ;
            sh:path rdfs:label ],
        [ sh:class enews:EnergyDataProvider ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path enews:providedBy ] ;
    sh:targetClass enews:EnergyDataset .

enews:EnergyTopicInstanceShape a sh:NodeShape ;
    sh:property [ sh:minCount 1 ;
            sh:path skos:inScheme ],
        [ sh:minCount 1 ;
            sh:path skos:definition ],
        [ sh:minCount 1 ;
            sh:path rdfs:label ] ;
    sh:targetClass enews:EnergyTopic .

enews:FeedShape a sh:NodeShape ;
    sh:property [ sh:class enews:SocialMediaPlatform ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path enews:onPlatform ],
        [ sh:minCount 1 ;
            sh:path rdfs:label ] ;
    sh:targetClass enews:Feed .

enews:InfographicShape a sh:NodeShape ;
    sh:targetClass enews:Infographic .

enews:MediaAttachmentShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:path enews:altText ],
        [ sh:datatype xsd:anyURI ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path enews:mediaUrl ],
        [ sh:minCount 1 ;
            sh:path enews:altTextProvenance ] ;
    sh:targetClass enews:MediaAttachment .

enews:PhotoShape a sh:NodeShape ;
    sh:targetClass enews:Photo .

enews:PostShape a sh:NodeShape ;
    sh:property [ sh:class enews:AuthorAccount ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path enews:postedBy ],
        [ sh:maxCount 1 ;
            sh:path enews:sharesArticle ] ;
    sh:targetClass enews:Post .

enews:PublicationShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:path enews:siteDomain ] ;
    sh:targetClass enews:Publication .

enews:SocialMediaPlatformShape a sh:NodeShape ;
    sh:property [ sh:minCount 1 ;
            sh:path rdfs:label ] ;
    sh:targetClass enews:SocialMediaPlatform .

enews:TemporalCoverageShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:date ;
            sh:maxCount 1 ;
            sh:path enews:endDate ],
        [ sh:datatype xsd:date ;
            sh:maxCount 1 ;
            sh:path enews:startDate ] ;
    sh:targetClass enews:TemporalCoverage .

enews:VideoAttachmentShape a sh:NodeShape ;
    sh:targetClass enews:VideoAttachment .
