PREFIX enews: <http://example.org/ontology/energy-news#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX obo: <http://purl.obolibrary.org/obo/>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>

# CQ-026: What energy topics relate to sectoral decarbonization?
# Expected: non_empty (IndustrialDecarbonization, MaritimeDecarbonization, AviationDecarbonization)
SELECT ?child ?label WHERE {
  ?child skos:broader enews:SectoralDecarbonization ;
         rdfs:label ?label .
}
