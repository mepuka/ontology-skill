PREFIX enews: <http://example.org/ontology/energy-news#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX obo: <http://purl.obolibrary.org/obo/>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>

# CQ-020: What are the top-level energy topic categories?
# Expected: non_empty (should return 23 top-level concepts)
SELECT ?topic ?label WHERE {
  ?topic skos:topConceptOf enews:EnergyTopicScheme ;
         rdfs:label ?label .
}
ORDER BY ?label
