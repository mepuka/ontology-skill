                             enews:EnergyTopic ,
                             skos:Concept ;
                    rdfs:label "green hydrogen"@en ;
                    skos:altLabel "electrolytic hydrogen"@en ,
                                  "green H2"@en ,
                                  "renewable hydrogen"@en ;
                    skos:broader enews:Hydrogen ;
                    skos:definition "A skos:Concept representing hydrogen produced via electrolysis powered by renewable energy sources"@en ;
                    skos:inScheme enews:EnergyTopicScheme .


