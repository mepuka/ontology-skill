<?xml version="1.0"?>
<rdf:RDF xmlns="http://example.org/ontology/energy-news#"
     xml:base="http://example.org/ontology/energy-news"
     xmlns:obo="http://purl.obolibrary.org/obo/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:sioc="http://rdfs.org/sioc/ns#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:enews="http://example.org/ontology/energy-news#"
     xmlns:schema="https://schema.org/"
     xmlns:dcterms="http://purl.org/dc/terms/">
    <owl:Ontology rdf:about="http://example.org/ontology/energy-news">
        <owl:versionIRI rdf:resource="http://example.org/ontology/energy-news/0.2.0"/>
        <dcterms:created>2026-02-11</dcterms:created>
        <dcterms:creator>ontology-architect skill</dcterms:creator>
        <dcterms:description xml:lang="en">A lightweight OWL 2 DL ontology modeling the energy news media landscape as observed through social media posts.</dcterms:description>
        <dcterms:license rdf:resource="https://spdx.org/licenses/MIT"/>
        <dcterms:modified>2026-02-12</dcterms:modified>
        <dcterms:title xml:lang="en">Energy News Ontology</dcterms:title>
        <owl:priorVersion rdf:resource="http://example.org/ontology/energy-news/0.1.0"/>
        <owl:versionInfo>0.2.0</owl:versionInfo>
    </owl:Ontology>



    <!--
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->




    <!-- http://purl.org/dc/terms/created -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/created"/>



    <!-- http://purl.org/dc/terms/creator -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/creator"/>



    <!-- http://purl.org/dc/terms/description -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/description"/>



    <!-- http://purl.org/dc/terms/license -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/license"/>



    <!-- http://purl.org/dc/terms/modified -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/modified"/>



    <!-- http://purl.org/dc/terms/title -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/title"/>



    <!-- http://www.w3.org/2004/02/skos/core#altLabel -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#altLabel"/>



    <!-- http://www.w3.org/2004/02/skos/core#broader -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#broader"/>



    <!-- http://www.w3.org/2004/02/skos/core#definition -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#definition"/>



    <!-- http://www.w3.org/2004/02/skos/core#hasTopConcept -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#hasTopConcept"/>



    <!-- http://www.w3.org/2004/02/skos/core#inScheme -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#inScheme"/>



    <!-- http://www.w3.org/2004/02/skos/core#relatedMatch -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#relatedMatch"/>



    <!-- http://www.w3.org/2004/02/skos/core#topConceptOf -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#topConceptOf"/>



    <!--
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->




    <!-- http://example.org/ontology/energy-news#coversTopic -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology/energy-news#coversTopic">
        <owl:equivalentProperty rdf:resource="https://schema.org/about"/>
        <rdfs:domain rdf:resource="http://example.org/ontology/energy-news#Article"/>
        <rdfs:range rdf:resource="http://example.org/ontology/energy-news#EnergyTopic"/>
        <rdfs:label xml:lang="en">covers topic</rdfs:label>
        <skos:definition xml:lang="en">Links an Article to an EnergyTopic individual it covers</skos:definition>
    </owl:ObjectProperty>



    <!-- http://example.org/ontology/energy-news#hasGeographicFocus -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology/energy-news#hasGeographicFocus">
        <owl:equivalentProperty rdf:resource="https://schema.org/contentLocation"/>
        <rdfs:domain rdf:resource="http://example.org/ontology/energy-news#Article"/>
        <rdfs:range rdf:resource="http://example.org/ontology/energy-news#GeographicEntity"/>
        <rdfs:label xml:lang="en">has geographic focus</rdfs:label>
        <skos:definition xml:lang="en">Links an Article to a GeographicEntity representing its geographic focus</skos:definition>
    </owl:ObjectProperty>



    <!-- http://example.org/ontology/energy-news#hasSector -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology/energy-news#hasSector">
        <rdfs:domain rdf:resource="http://example.org/ontology/energy-news#Organization"/>
        <rdfs:range rdf:resource="http://example.org/ontology/energy-news#EnergyTopic"/>
        <rdfs:label xml:lang="en">has sector</rdfs:label>
        <skos:definition xml:lang="en">Links an Organization to an EnergyTopic sector it operates in</skos:definition>
    </owl:ObjectProperty>



    <!-- http://example.org/ontology/energy-news#mentionsOrganization -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology/energy-news#mentionsOrganization">
        <rdfs:subPropertyOf rdf:resource="https://schema.org/mentions"/>
        <rdfs:domain rdf:resource="http://example.org/ontology/energy-news#Article"/>
        <rdfs:range rdf:resource="http://example.org/ontology/energy-news#Organization"/>
        <rdfs:label xml:lang="en">mentions organization</rdfs:label>
        <skos:definition xml:lang="en">Links an Article to an Organization mentioned in its coverage</skos:definition>
    </owl:ObjectProperty>



    <!-- http://example.org/ontology/energy-news#onPlatform -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology/energy-news#onPlatform">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:range rdf:resource="http://example.org/ontology/energy-news#SocialMediaPlatform"/>
        <rdfs:label xml:lang="en">on platform</rdfs:label>
        <skos:definition xml:lang="en">Links an AuthorAccount or Feed to the SocialMediaPlatform it belongs to</skos:definition>
    </owl:ObjectProperty>



    <!-- http://example.org/ontology/energy-news#postedBy -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology/energy-news#postedBy">
        <rdfs:subPropertyOf rdf:resource="https://schema.org/author"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/ontology/energy-news#Post"/>
        <rdfs:range rdf:resource="http://example.org/ontology/energy-news#AuthorAccount"/>
        <rdfs:label xml:lang="en">posted by</rdfs:label>
        <skos:definition xml:lang="en">Links a Post to the AuthorAccount who created it</skos:definition>
    </owl:ObjectProperty>



    <!-- http://example.org/ontology/energy-news#publishedBy -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology/energy-news#publishedBy">
        <owl:equivalentProperty rdf:resource="https://schema.org/publisher"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/ontology/energy-news#Article"/>
        <rdfs:range rdf:resource="http://example.org/ontology/energy-news#Publication"/>
        <rdfs:label xml:lang="en">published by</rdfs:label>
        <skos:definition xml:lang="en">Links an Article to the Publication that published it</skos:definition>
    </owl:ObjectProperty>



    <!-- http://example.org/ontology/energy-news#sharesArticle -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology/energy-news#sharesArticle">
        <owl:equivalentProperty rdf:resource="https://schema.org/sharedContent"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/ontology/energy-news#Post"/>
        <rdfs:range rdf:resource="http://example.org/ontology/energy-news#Article"/>
        <rdfs:label xml:lang="en">shares article</rdfs:label>
        <skos:definition xml:lang="en">Links a Post to the Article it shares via embedded link</skos:definition>
    </owl:ObjectProperty>



    <!-- https://schema.org/about -->

    <owl:ObjectProperty rdf:about="https://schema.org/about"/>



    <!-- https://schema.org/author -->

    <owl:ObjectProperty rdf:about="https://schema.org/author"/>



    <!-- https://schema.org/contentLocation -->

    <owl:ObjectProperty rdf:about="https://schema.org/contentLocation"/>



    <!-- https://schema.org/mentions -->

    <owl:ObjectProperty rdf:about="https://schema.org/mentions"/>



    <!-- https://schema.org/publisher -->

    <owl:ObjectProperty rdf:about="https://schema.org/publisher"/>



    <!-- https://schema.org/sharedContent -->

    <owl:ObjectProperty rdf:about="https://schema.org/sharedContent"/>



    <!--
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->




    <!-- http://example.org/ontology/energy-news#description -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/energy-news#description">
        <owl:equivalentProperty rdf:resource="https://schema.org/description"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/ontology/energy-news#Article"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">description</rdfs:label>
        <skos:definition xml:lang="en">The description or summary text of an Article</skos:definition>
    </owl:DatatypeProperty>



    <!-- http://example.org/ontology/energy-news#handle -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/energy-news#handle">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/ontology/energy-news#AuthorAccount"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">handle</rdfs:label>
        <skos:definition xml:lang="en">The handle or username string for an AuthorAccount</skos:definition>
    </owl:DatatypeProperty>



    <!-- http://example.org/ontology/energy-news#publishedDate -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/energy-news#publishedDate">
        <owl:equivalentProperty rdf:resource="https://schema.org/datePublished"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/ontology/energy-news#Article"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:label xml:lang="en">published date</rdfs:label>
        <skos:definition xml:lang="en">The publication date of an Article</skos:definition>
    </owl:DatatypeProperty>



    <!-- http://example.org/ontology/energy-news#siteDomain -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/energy-news#siteDomain">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/ontology/energy-news#Publication"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">site domain</rdfs:label>
        <skos:definition xml:lang="en">The domain name string of a Publication</skos:definition>
    </owl:DatatypeProperty>



    <!-- http://example.org/ontology/energy-news#title -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/energy-news#title">
        <owl:equivalentProperty rdf:resource="https://schema.org/headline"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/ontology/energy-news#Article"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">title</rdfs:label>
        <skos:definition xml:lang="en">The headline or title string of an Article</skos:definition>
    </owl:DatatypeProperty>



    <!-- http://example.org/ontology/energy-news#url -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/energy-news#url">
        <owl:equivalentProperty rdf:resource="https://schema.org/url"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/ontology/energy-news#Article"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <rdfs:label xml:lang="en">url</rdfs:label>
        <skos:definition xml:lang="en">The URL of an Article</skos:definition>
    </owl:DatatypeProperty>



    <!-- https://schema.org/datePublished -->

    <owl:DatatypeProperty rdf:about="https://schema.org/datePublished"/>



    <!-- https://schema.org/description -->

    <owl:DatatypeProperty rdf:about="https://schema.org/description"/>



    <!-- https://schema.org/headline -->

    <owl:DatatypeProperty rdf:about="https://schema.org/headline"/>



    <!-- https://schema.org/url -->

    <owl:DatatypeProperty rdf:about="https://schema.org/url"/>



    <!--
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->




    <!-- http://example.org/ontology/energy-news#Article -->

    <owl:Class rdf:about="http://example.org/ontology/energy-news#Article">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
        <rdfs:subClassOf rdf:resource="https://schema.org/NewsArticle"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/ontology/energy-news#coversTopic"/>
                <owl:someValuesFrom rdf:resource="http://example.org/ontology/energy-news#EnergyTopic"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:hasKey rdf:parseType="Collection">
            <rdf:Description rdf:about="http://example.org/ontology/energy-news#url"/>
        </owl:hasKey>
        <rdfs:label xml:lang="en">article</rdfs:label>
        <skos:definition xml:lang="en">A GenericallyDependentContinuant that represents a news article referenced by an embedded link in a social media post</skos:definition>
    </owl:Class>



    <!-- http://example.org/ontology/energy-news#AuthorAccount -->

    <owl:Class rdf:about="http://example.org/ontology/energy-news#AuthorAccount">
        <owl:equivalentClass rdf:resource="http://rdfs.org/sioc/ns#UserAccount"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/ontology/energy-news#onPlatform"/>
                <owl:someValuesFrom rdf:resource="http://example.org/ontology/energy-news#SocialMediaPlatform"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:hasKey rdf:parseType="Collection">
            <rdf:Description rdf:about="http://example.org/ontology/energy-news#onPlatform"/>
            <rdf:Description rdf:about="http://example.org/ontology/energy-news#handle"/>
        </owl:hasKey>
        <rdfs:label xml:lang="en">author account</rdfs:label>
        <skos:definition xml:lang="en">A GenericallyDependentContinuant that represents a social media account that shares energy news</skos:definition>
        <skos:relatedMatch rdf:resource="https://schema.org/Person"/>
    </owl:Class>



    <!-- http://example.org/ontology/energy-news#EnergyTopic -->

    <owl:Class rdf:about="http://example.org/ontology/energy-news#EnergyTopic">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
        <rdfs:label xml:lang="en">energy topic</rdfs:label>
        <skos:definition xml:lang="en">An owl:Class whose instances are skos:Concept individuals representing subject areas within the energy sector used to classify news articles</skos:definition>
    </owl:Class>



    <!-- http://example.org/ontology/energy-news#Feed -->

    <owl:Class rdf:about="http://example.org/ontology/energy-news#Feed">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/ontology/energy-news#onPlatform"/>
                <owl:someValuesFrom rdf:resource="http://example.org/ontology/energy-news#SocialMediaPlatform"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">feed</rdfs:label>
        <skos:definition xml:lang="en">A GenericallyDependentContinuant that represents a curated social media feed for energy content</skos:definition>
    </owl:Class>



    <!-- http://example.org/ontology/energy-news#GeographicEntity -->

    <owl:Class rdf:about="http://example.org/ontology/energy-news#GeographicEntity">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000029"/>
        <rdfs:subClassOf rdf:resource="https://schema.org/Place"/>
        <rdfs:label xml:lang="en">geographic entity</rdfs:label>
        <skos:definition xml:lang="en">A Site that represents a country region or subnational area relevant to energy news coverage</skos:definition>
    </owl:Class>



    <!-- http://example.org/ontology/energy-news#Organization -->

    <owl:Class rdf:about="http://example.org/ontology/energy-news#Organization">
        <owl:equivalentClass rdf:resource="https://schema.org/Organization"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:label xml:lang="en">organization</rdfs:label>
        <skos:definition xml:lang="en">An Object that represents a company agency or institutional body mentioned in energy news</skos:definition>
    </owl:Class>



    <!-- http://example.org/ontology/energy-news#Post -->

    <owl:Class rdf:about="http://example.org/ontology/energy-news#Post">
        <owl:equivalentClass rdf:resource="https://schema.org/SocialMediaPosting"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/ontology/energy-news#postedBy"/>
                <owl:someValuesFrom rdf:resource="http://example.org/ontology/energy-news#AuthorAccount"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">post</rdfs:label>
        <skos:definition xml:lang="en">A GenericallyDependentContinuant that represents a social media post sharing energy content</skos:definition>
    </owl:Class>



    <!-- http://example.org/ontology/energy-news#Publication -->

    <owl:Class rdf:about="http://example.org/ontology/energy-news#Publication">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:subClassOf rdf:resource="https://schema.org/NewsMediaOrganization"/>
        <owl:hasKey rdf:parseType="Collection">
            <rdf:Description rdf:about="http://example.org/ontology/energy-news#siteDomain"/>
        </owl:hasKey>
        <rdfs:label xml:lang="en">publication</rdfs:label>
        <skos:definition xml:lang="en">An Object that represents a news media outlet or website that publishes articles</skos:definition>
    </owl:Class>



    <!-- http://example.org/ontology/energy-news#SocialMediaPlatform -->

    <owl:Class rdf:about="http://example.org/ontology/energy-news#SocialMediaPlatform">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
        <rdfs:label xml:lang="en">social media platform</rdfs:label>
        <skos:definition xml:lang="en">An owl:Class whose instances are named individuals representing social media platforms</skos:definition>
    </owl:Class>



    <!-- http://purl.obolibrary.org/obo/BFO_0000029 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000029">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:label xml:lang="en">site</rdfs:label>
    </owl:Class>



    <!-- http://purl.obolibrary.org/obo/BFO_0000030 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000030">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:label xml:lang="en">object</rdfs:label>
    </owl:Class>



    <!-- http://purl.obolibrary.org/obo/BFO_0000031 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000031">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:label xml:lang="en">generically dependent continuant</rdfs:label>
    </owl:Class>



    <!-- http://rdfs.org/sioc/ns#UserAccount -->

    <owl:Class rdf:about="http://rdfs.org/sioc/ns#UserAccount">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
    </owl:Class>



    <!-- http://www.w3.org/2004/02/skos/core#Concept -->

    <owl:Class rdf:about="http://www.w3.org/2004/02/skos/core#Concept">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    </owl:Class>



    <!-- http://www.w3.org/2004/02/skos/core#ConceptScheme -->

    <owl:Class rdf:about="http://www.w3.org/2004/02/skos/core#ConceptScheme">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    </owl:Class>



    <!-- https://schema.org/NewsArticle -->

    <owl:Class rdf:about="https://schema.org/NewsArticle">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    </owl:Class>



    <!-- https://schema.org/NewsMediaOrganization -->

    <owl:Class rdf:about="https://schema.org/NewsMediaOrganization">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    </owl:Class>



    <!-- https://schema.org/Organization -->

    <owl:Class rdf:about="https://schema.org/Organization">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
    </owl:Class>



    <!-- https://schema.org/Person -->

    <owl:Class rdf:about="https://schema.org/Person">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    </owl:Class>



    <!-- https://schema.org/Place -->

    <owl:Class rdf:about="https://schema.org/Place">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    </owl:Class>



    <!-- https://schema.org/SocialMediaPosting -->

    <owl:Class rdf:about="https://schema.org/SocialMediaPosting">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
    </owl:Class>



    <!--
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->




    <!-- http://example.org/ontology/energy-news#Affordability -->

    <owl:NamedIndividual rdf:about="http://example.org/ontology/energy-news#Affordability">
        <rdf:type rdf:resource="http://example.org/ontology/energy-news#EnergyTopic"/>
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:label xml:lang="en">affordability</rdfs:label>
        <skos:altLabel xml:lang="en">energy bills</skos:altLabel>
        <skos:altLabel xml:lang="en">energy poverty</skos:altLabel>
        <skos:altLabel xml:lang="en">rate hike</skos:altLabel>
        <skos:broader rdf:resource="http://example.org/ontology/energy-news#EnergyJustice"/>
        <skos:definition xml:lang="en">A skos:Concept representing energy affordability bills rate increases and energy poverty</skos:definition>
        <skos:inScheme rdf:resource="http://example.org/ontology/energy-news#EnergyTopicScheme"/>
    </owl:NamedIndividual>



