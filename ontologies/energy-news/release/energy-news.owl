<?xml version="1.0"?>
<rdf:RDF xmlns="http://example.org/ontology/energy-news#"
     xml:base="http://example.org/ontology/energy-news"
     xmlns:obo="http://purl.obolibrary.org/obo/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:sioc="http://rdfs.org/sioc/ns#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:enews="http://example.org/ontology/energy-news#"
     xmlns:schema="https://schema.org/"
     xmlns:dcterms="http://purl.org/dc/terms/">
    <owl:Ontology rdf:about="http://example.org/ontology/energy-news">
        <owl:versionIRI rdf:resource="http://example.org/ontology/energy-news/0.3.0"/>
        <dcterms:created>2026-02-11</dcterms:created>
        <dcterms:creator>ontology-architect skill</dcterms:creator>
        <dcterms:description xml:lang="en">A lightweight OWL 2 DL ontology modeling the energy news media landscape as observed through social media posts.</dcterms:description>
        <dcterms:license rdf:resource="https://spdx.org/licenses/MIT"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-02-27</dcterms:modified>
        <dcterms:title xml:lang="en">Energy News Ontology</dcterms:title>
        <owl:priorVersion rdf:resource="http://example.org/ontology/energy-news/0.2.0"/>
        <owl:versionInfo>0.3.0</owl:versionInfo>
    </owl:Ontology>



    <!--
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->




    <!-- http://purl.org/dc/terms/created -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/created"/>



    <!-- http://purl.org/dc/terms/creator -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/creator"/>



    <!-- http://purl.org/dc/terms/description -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/description"/>



    <!-- http://purl.org/dc/terms/license -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/license"/>



    <!-- http://purl.org/dc/terms/modified -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/modified"/>



    <!-- http://purl.org/dc/terms/title -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/title"/>



    <!-- http://www.w3.org/2004/02/skos/core#altLabel -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#altLabel"/>



    <!-- http://www.w3.org/2004/02/skos/core#broader -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#broader"/>



    <!-- http://www.w3.org/2004/02/skos/core#definition -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#definition"/>



    <!-- http://www.w3.org/2004/02/skos/core#hasTopConcept -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#hasTopConcept"/>



    <!-- http://www.w3.org/2004/02/skos/core#inScheme -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#inScheme"/>



    <!-- http://www.w3.org/2004/02/skos/core#relatedMatch -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#relatedMatch"/>



    <!-- http://www.w3.org/2004/02/skos/core#topConceptOf -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#topConceptOf"/>



    <!--
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->




    <!-- http://www.w3.org/2001/XMLSchema#date -->

    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>



    <!--
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->




    <!-- http://example.org/ontology/energy-news#aboutProject -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology/energy-news#aboutProject">
        <rdfs:domain rdf:resource="http://example.org/ontology/energy-news#Article"/>
        <rdfs:range rdf:resource="http://example.org/ontology/energy-news#EnergyProject"/>
        <rdfs:label xml:lang="en">about project</rdfs:label>
        <skos:definition xml:lang="en">Links an Article to an EnergyProject it covers</skos:definition>
    </owl:ObjectProperty>



    <!-- http://example.org/ontology/energy-news#coversTechnology -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology/energy-news#coversTechnology">
        <rdfs:domain rdf:resource="http://example.org/ontology/energy-news#Article"/>
        <rdfs:range rdf:resource="http://example.org/ontology/energy-news#EnergyTechnology"/>
        <rdfs:label xml:lang="en">covers technology</rdfs:label>
        <skos:definition xml:lang="en">Links an Article to an EnergyTechnology it discusses</skos:definition>
    </owl:ObjectProperty>



    <!-- http://example.org/ontology/energy-news#coversTopic -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology/energy-news#coversTopic">
        <owl:equivalentProperty rdf:resource="https://schema.org/about"/>
        <rdfs:domain rdf:resource="http://example.org/ontology/energy-news#Article"/>
        <rdfs:range rdf:resource="http://example.org/ontology/energy-news#EnergyTopic"/>
        <rdfs:label xml:lang="en">covers topic</rdfs:label>
        <skos:definition xml:lang="en">Links an Article to an EnergyTopic individual it covers</skos:definition>
    </owl:ObjectProperty>



    <!-- http://example.org/ontology/energy-news#developedThrough -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology/energy-news#developedThrough">
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:range rdf:resource="http://example.org/ontology/energy-news#EnergyProject"/>
        <rdfs:label xml:lang="en">developed through</rdfs:label>
        <skos:definition xml:lang="en">Links a physical energy facility (PowerPlant or RenewableInstallation) to the EnergyProject development process that produced it</skos:definition>
    </owl:ObjectProperty>



    <!-- http://example.org/ontology/energy-news#hasCapacity -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology/energy-news#hasCapacity">
        <rdfs:domain rdf:resource="http://example.org/ontology/energy-news#EnergyProject"/>
        <rdfs:range rdf:resource="http://example.org/ontology/energy-news#CapacityMeasurement"/>
        <rdfs:label xml:lang="en">has capacity</rdfs:label>
        <skos:definition xml:lang="en">Links an EnergyProject to its capacity measurement</skos:definition>
    </owl:ObjectProperty>



    <!-- http://example.org/ontology/energy-news#hasEmbed -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology/energy-news#hasEmbed">
        <rdfs:domain rdf:resource="http://example.org/ontology/energy-news#Post"/>
        <rdfs:range rdf:resource="http://example.org/ontology/energy-news#EmbeddedExternalLink"/>
        <rdfs:label xml:lang="en">has embed</rdfs:label>
        <skos:definition xml:lang="en">Links a Post to its embedded external link</skos:definition>
    </owl:ObjectProperty>



    <!-- http://example.org/ontology/energy-news#hasGeographicFocus -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology/energy-news#hasGeographicFocus">
        <owl:equivalentProperty rdf:resource="https://schema.org/contentLocation"/>
        <rdfs:domain rdf:resource="http://example.org/ontology/energy-news#Article"/>
        <rdfs:range rdf:resource="http://example.org/ontology/energy-news#GeographicEntity"/>
        <rdfs:label xml:lang="en">has geographic focus</rdfs:label>
        <skos:definition xml:lang="en">Links an Article to a GeographicEntity representing its geographic focus</skos:definition>
    </owl:ObjectProperty>



    <!-- http://example.org/ontology/energy-news#hasMedia -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology/energy-news#hasMedia">
        <rdfs:domain rdf:resource="http://example.org/ontology/energy-news#Post"/>
        <rdfs:range rdf:resource="http://example.org/ontology/energy-news#MediaAttachment"/>
        <rdfs:label xml:lang="en">has media</rdfs:label>
        <skos:definition xml:lang="en">Links a Post to its media attachments</skos:definition>
    </owl:ObjectProperty>



    <!-- http://example.org/ontology/energy-news#hasSector -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology/energy-news#hasSector">
        <rdfs:domain rdf:resource="http://example.org/ontology/energy-news#Organization"/>
        <rdfs:range rdf:resource="http://example.org/ontology/energy-news#EnergyTopic"/>
        <rdfs:label xml:lang="en">has sector</rdfs:label>
        <skos:definition xml:lang="en">Links an Organization to an EnergyTopic sector it operates in</skos:definition>
    </owl:ObjectProperty>



    <!-- http://example.org/ontology/energy-news#hasStatus -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology/energy-news#hasStatus">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/ontology/energy-news#EnergyProject"/>
        <rdfs:range rdf:resource="http://example.org/ontology/energy-news#ProjectStatus"/>
        <rdfs:label xml:lang="en">has status</rdfs:label>
        <skos:definition xml:lang="en">Links an EnergyProject to its current status</skos:definition>
    </owl:ObjectProperty>



    <!-- http://example.org/ontology/energy-news#hasTechnology -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology/energy-news#hasTechnology">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://example.org/ontology/energy-news#EnergyTechnology"/>
        <rdfs:label xml:lang="en">has technology</rdfs:label>
        <skos:definition xml:lang="en">Links a RenewableInstallation to its technology type</skos:definition>
    </owl:ObjectProperty>



    <!-- http://example.org/ontology/energy-news#isReplyTo -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology/energy-news#isReplyTo">
        <rdfs:domain rdf:resource="http://example.org/ontology/energy-news#Post"/>
        <rdfs:range rdf:resource="http://example.org/ontology/energy-news#Post"/>
        <rdfs:label xml:lang="en">is reply to</rdfs:label>
        <skos:definition xml:lang="en">Links a reply Post to the parent Post it responds to</skos:definition>
    </owl:ObjectProperty>



    <!-- http://example.org/ontology/energy-news#jurisdiction -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology/energy-news#jurisdiction">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://example.org/ontology/energy-news#GeographicEntity"/>
        <rdfs:label xml:lang="en">jurisdiction</rdfs:label>
        <skos:definition xml:lang="en">Links a RegulatoryBody or PolicyInstrument to the GeographicEntity representing its jurisdictional scope</skos:definition>
    </owl:ObjectProperty>



    <!-- http://example.org/ontology/energy-news#mentionsOrganization -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology/energy-news#mentionsOrganization">
        <rdfs:subPropertyOf rdf:resource="https://schema.org/mentions"/>
        <rdfs:domain rdf:resource="http://example.org/ontology/energy-news#Article"/>
        <rdfs:range rdf:resource="http://example.org/ontology/energy-news#Organization"/>
        <rdfs:label xml:lang="en">mentions organization</rdfs:label>
        <skos:definition xml:lang="en">Links an Article to an Organization mentioned in its coverage</skos:definition>
    </owl:ObjectProperty>



    <!-- http://example.org/ontology/energy-news#onPlatform -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology/energy-news#onPlatform">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://example.org/ontology/energy-news#SocialMediaPlatform"/>
        <rdfs:label xml:lang="en">on platform</rdfs:label>
        <skos:definition xml:lang="en">Links an AuthorAccount or Feed to the SocialMediaPlatform it belongs to</skos:definition>
    </owl:ObjectProperty>



    <!-- http://example.org/ontology/energy-news#operatedBy -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology/energy-news#operatedBy">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://example.org/ontology/energy-news#Organization"/>
        <rdfs:label xml:lang="en">operated by</rdfs:label>
        <skos:definition xml:lang="en">Links a GridZone to its operating organization</skos:definition>
    </owl:ObjectProperty>



    <!-- http://example.org/ontology/energy-news#postedBy -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology/energy-news#postedBy">
        <rdfs:subPropertyOf rdf:resource="https://schema.org/author"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/ontology/energy-news#Post"/>
        <rdfs:range rdf:resource="http://example.org/ontology/energy-news#AuthorAccount"/>
        <rdfs:label xml:lang="en">posted by</rdfs:label>
        <skos:definition xml:lang="en">Links a Post to the AuthorAccount who created it</skos:definition>
    </owl:ObjectProperty>



    <!-- http://example.org/ontology/energy-news#publishedBy -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology/energy-news#publishedBy">
        <owl:equivalentProperty rdf:resource="https://schema.org/publisher"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/ontology/energy-news#Article"/>
        <rdfs:range rdf:resource="http://example.org/ontology/energy-news#Publication"/>
        <rdfs:label xml:lang="en">published by</rdfs:label>
        <skos:definition xml:lang="en">Links an Article to the Publication that published it</skos:definition>
    </owl:ObjectProperty>



    <!-- http://example.org/ontology/energy-news#sharesArticle -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology/energy-news#sharesArticle">
        <owl:equivalentProperty rdf:resource="https://schema.org/sharedContent"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/ontology/energy-news#Post"/>
        <rdfs:range rdf:resource="http://example.org/ontology/energy-news#Article"/>
        <rdfs:label xml:lang="en">shares article</rdfs:label>
        <skos:definition xml:lang="en">Links a Post to the Article it shares via embedded link</skos:definition>
    </owl:ObjectProperty>



    <!-- https://schema.org/about -->

    <owl:ObjectProperty rdf:about="https://schema.org/about"/>



    <!-- https://schema.org/author -->

    <owl:ObjectProperty rdf:about="https://schema.org/author"/>



    <!-- https://schema.org/contentLocation -->

    <owl:ObjectProperty rdf:about="https://schema.org/contentLocation"/>



    <!-- https://schema.org/mentions -->

    <owl:ObjectProperty rdf:about="https://schema.org/mentions"/>



    <!-- https://schema.org/publisher -->

    <owl:ObjectProperty rdf:about="https://schema.org/publisher"/>



    <!-- https://schema.org/sharedContent -->

    <owl:ObjectProperty rdf:about="https://schema.org/sharedContent"/>



    <!--
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->




    <!-- http://example.org/ontology/energy-news#altText -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/energy-news#altText">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/ontology/energy-news#MediaAttachment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">alt text</rdfs:label>
        <skos:definition xml:lang="en">The alternative text description for the media attachment</skos:definition>
    </owl:DatatypeProperty>



    <!-- http://example.org/ontology/energy-news#capacityUnit -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/energy-news#capacityUnit">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/ontology/energy-news#CapacityMeasurement"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">capacity unit</rdfs:label>
        <skos:definition xml:lang="en">The unit of measurement for capacity such as MW, GW, MWh, or GWh</skos:definition>
    </owl:DatatypeProperty>



    <!-- http://example.org/ontology/energy-news#createdAt -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/energy-news#createdAt">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/ontology/energy-news#Post"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:label xml:lang="en">created at</rdfs:label>
        <skos:definition xml:lang="en">The timestamp when a Post was created</skos:definition>
    </owl:DatatypeProperty>



    <!-- http://example.org/ontology/energy-news#description -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/energy-news#description">
        <owl:equivalentProperty rdf:resource="https://schema.org/description"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/ontology/energy-news#Article"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">description</rdfs:label>
        <skos:definition xml:lang="en">The description or summary text of an Article</skos:definition>
    </owl:DatatypeProperty>



    <!-- http://example.org/ontology/energy-news#displayName -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/energy-news#displayName">
        <rdfs:domain rdf:resource="http://example.org/ontology/energy-news#AuthorAccount"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">display name</rdfs:label>
        <skos:definition xml:lang="en">The display name of an AuthorAccount</skos:definition>
    </owl:DatatypeProperty>



    <!-- http://example.org/ontology/energy-news#handle -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/energy-news#handle">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/ontology/energy-news#AuthorAccount"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">handle</rdfs:label>
        <skos:definition xml:lang="en">The handle or username string for an AuthorAccount</skos:definition>
    </owl:DatatypeProperty>



    <!-- http://example.org/ontology/energy-news#likeCount -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/energy-news#likeCount">
        <rdfs:domain rdf:resource="http://example.org/ontology/energy-news#Post"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:label xml:lang="en">like count</rdfs:label>
        <skos:definition xml:lang="en">The number of likes on a Post</skos:definition>
    </owl:DatatypeProperty>



    <!-- http://example.org/ontology/energy-news#linkDescription -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/energy-news#linkDescription">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/ontology/energy-news#EmbeddedExternalLink"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">link description</rdfs:label>
        <skos:definition xml:lang="en">The preview description text of the embedded external link</skos:definition>
    </owl:DatatypeProperty>



    <!-- http://example.org/ontology/energy-news#linkTitle -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/energy-news#linkTitle">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/ontology/energy-news#EmbeddedExternalLink"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">link title</rdfs:label>
        <skos:definition xml:lang="en">The preview title text of the embedded external link</skos:definition>
    </owl:DatatypeProperty>



    <!-- http://example.org/ontology/energy-news#linkUri -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/energy-news#linkUri">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/ontology/energy-news#EmbeddedExternalLink"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <rdfs:label xml:lang="en">link URI</rdfs:label>
        <skos:definition xml:lang="en">The target URI of the embedded external link</skos:definition>
    </owl:DatatypeProperty>



    <!-- http://example.org/ontology/energy-news#measurementDate -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/energy-news#measurementDate">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/ontology/energy-news#CapacityMeasurement"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:label xml:lang="en">measurement date</rdfs:label>
        <skos:definition xml:lang="en">The date when the capacity measurement was recorded</skos:definition>
    </owl:DatatypeProperty>



    <!-- http://example.org/ontology/energy-news#mediaUri -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/energy-news#mediaUri">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/ontology/energy-news#MediaAttachment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <rdfs:label xml:lang="en">media URI</rdfs:label>
        <skos:definition xml:lang="en">The URI of the media resource such as an image or video</skos:definition>
    </owl:DatatypeProperty>



    <!-- http://example.org/ontology/energy-news#mimeType -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/energy-news#mimeType">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/ontology/energy-news#MediaAttachment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">MIME type</rdfs:label>
        <skos:definition xml:lang="en">The MIME type of the media attachment such as image/jpeg or video/mp4</skos:definition>
    </owl:DatatypeProperty>



    <!-- http://example.org/ontology/energy-news#postText -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/energy-news#postText">
        <rdfs:domain rdf:resource="http://example.org/ontology/energy-news#Post"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">post text</rdfs:label>
        <skos:definition xml:lang="en">The text content of a Post</skos:definition>
    </owl:DatatypeProperty>



    <!-- http://example.org/ontology/energy-news#priceCurrency -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/energy-news#priceCurrency">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/ontology/energy-news#PriceDataPoint"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">price currency</rdfs:label>
        <skos:definition xml:lang="en">The ISO 4217 currency code for the price value such as USD, EUR, or GBP</skos:definition>
    </owl:DatatypeProperty>



    <!-- http://example.org/ontology/energy-news#priceDate -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/energy-news#priceDate">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/ontology/energy-news#PriceDataPoint"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:label xml:lang="en">price date</rdfs:label>
        <skos:definition xml:lang="en">The date when the price was recorded or observed</skos:definition>
    </owl:DatatypeProperty>



    <!-- http://example.org/ontology/energy-news#priceValue -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/energy-news#priceValue">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/ontology/energy-news#PriceDataPoint"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:label xml:lang="en">price value</rdfs:label>
        <skos:definition xml:lang="en">The numeric price or cost value</skos:definition>
    </owl:DatatypeProperty>



    <!-- http://example.org/ontology/energy-news#publishedDate -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/energy-news#publishedDate">
        <owl:equivalentProperty rdf:resource="https://schema.org/datePublished"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/ontology/energy-news#Article"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:label xml:lang="en">published date</rdfs:label>
        <skos:definition xml:lang="en">The publication date of an Article</skos:definition>
    </owl:DatatypeProperty>



    <!-- http://example.org/ontology/energy-news#replyCount -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/energy-news#replyCount">
        <rdfs:domain rdf:resource="http://example.org/ontology/energy-news#Post"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:label xml:lang="en">reply count</rdfs:label>
        <skos:definition xml:lang="en">The number of replies to a Post</skos:definition>
    </owl:DatatypeProperty>



    <!-- http://example.org/ontology/energy-news#repostCount -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/energy-news#repostCount">
        <rdfs:domain rdf:resource="http://example.org/ontology/energy-news#Post"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
        <rdfs:label xml:lang="en">repost count</rdfs:label>
        <skos:definition xml:lang="en">The number of reposts of a Post</skos:definition>
    </owl:DatatypeProperty>



    <!-- http://example.org/ontology/energy-news#siteDomain -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/energy-news#siteDomain">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/ontology/energy-news#Publication"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">site domain</rdfs:label>
        <skos:definition xml:lang="en">The domain name string of a Publication</skos:definition>
    </owl:DatatypeProperty>



    <!-- http://example.org/ontology/energy-news#thumbnailUri -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/energy-news#thumbnailUri">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/ontology/energy-news#EmbeddedExternalLink"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <rdfs:label xml:lang="en">thumbnail URI</rdfs:label>
        <skos:definition xml:lang="en">The URI of the preview thumbnail image for the embedded external link</skos:definition>
    </owl:DatatypeProperty>



    <!-- http://example.org/ontology/energy-news#title -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/energy-news#title">
        <owl:equivalentProperty rdf:resource="https://schema.org/headline"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/ontology/energy-news#Article"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">title</rdfs:label>
        <skos:definition xml:lang="en">The headline or title string of an Article</skos:definition>
    </owl:DatatypeProperty>



    <!-- http://example.org/ontology/energy-news#url -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/energy-news#url">
        <owl:equivalentProperty rdf:resource="https://schema.org/url"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/ontology/energy-news#Article"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <rdfs:label xml:lang="en">url</rdfs:label>
        <skos:definition xml:lang="en">The URL of an Article</skos:definition>
    </owl:DatatypeProperty>



    <!-- http://example.org/ontology/energy-news#valueInMW -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/energy-news#valueInMW">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/ontology/energy-news#CapacityMeasurement"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:label xml:lang="en">value in MW</rdfs:label>
        <skos:definition xml:lang="en">The numeric capacity value expressed in megawatts</skos:definition>
    </owl:DatatypeProperty>



    <!-- https://schema.org/datePublished -->

    <owl:DatatypeProperty rdf:about="https://schema.org/datePublished"/>



    <!-- https://schema.org/description -->

    <owl:DatatypeProperty rdf:about="https://schema.org/description"/>



    <!-- https://schema.org/headline -->

    <owl:DatatypeProperty rdf:about="https://schema.org/headline"/>



    <!-- https://schema.org/url -->

    <owl:DatatypeProperty rdf:about="https://schema.org/url"/>



    <!--
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->




    <!-- http://example.org/ontology/energy-news#Article -->

    <owl:Class rdf:about="http://example.org/ontology/energy-news#Article">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
        <rdfs:subClassOf rdf:resource="https://schema.org/NewsArticle"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/ontology/energy-news#coversTopic"/>
                <owl:someValuesFrom rdf:resource="http://example.org/ontology/energy-news#EnergyTopic"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:hasKey rdf:parseType="Collection">
            <rdf:Description rdf:about="http://example.org/ontology/energy-news#url"/>
        </owl:hasKey>
        <rdfs:label xml:lang="en">article</rdfs:label>
        <skos:definition xml:lang="en">A GenericallyDependentContinuant that represents a news article referenced by an embedded link in a social media post</skos:definition>
    </owl:Class>



    <!-- http://example.org/ontology/energy-news#AuthorAccount -->

    <owl:Class rdf:about="http://example.org/ontology/energy-news#AuthorAccount">
        <owl:equivalentClass rdf:resource="http://rdfs.org/sioc/ns#UserAccount"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/ontology/energy-news#onPlatform"/>
                <owl:someValuesFrom rdf:resource="http://example.org/ontology/energy-news#SocialMediaPlatform"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:hasKey rdf:parseType="Collection">
            <rdf:Description rdf:about="http://example.org/ontology/energy-news#onPlatform"/>
            <rdf:Description rdf:about="http://example.org/ontology/energy-news#handle"/>
        </owl:hasKey>
        <rdfs:label xml:lang="en">author account</rdfs:label>
        <skos:definition xml:lang="en">A GenericallyDependentContinuant that represents a social media account that shares energy news</skos:definition>
        <skos:relatedMatch rdf:resource="https://schema.org/Person"/>
    </owl:Class>



    <!-- http://example.org/ontology/energy-news#CapacityMeasurement -->

    <owl:Class rdf:about="http://example.org/ontology/energy-news#CapacityMeasurement">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
        <rdfs:label xml:lang="en">capacity measurement</rdfs:label>
        <skos:definition xml:lang="en">A GenericallyDependentContinuant representing a quantified metric of power generation or storage capability measured in MW, GW, MWh, or equivalent units</skos:definition>
    </owl:Class>



    <!-- http://example.org/ontology/energy-news#EmbeddedExternalLink -->

    <owl:Class rdf:about="http://example.org/ontology/energy-news#EmbeddedExternalLink">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
        <rdfs:label xml:lang="en">embedded external link</rdfs:label>
        <skos:definition xml:lang="en">A GenericallyDependentContinuant representing a hyperlink embedded within a Post pointing to an external web resource with link metadata such as title, description, and URI</skos:definition>
    </owl:Class>



    <!-- http://example.org/ontology/energy-news#EnergyEvent -->

    <owl:Class rdf:about="http://example.org/ontology/energy-news#EnergyEvent">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:label xml:lang="en">energy event</rdfs:label>
        <skos:definition xml:lang="en">A Process representing a significant occurrence in the energy sector including conferences, policy announcements, regulatory decisions, and market disruptions</skos:definition>
    </owl:Class>



    <!-- http://example.org/ontology/energy-news#EnergyProject -->

    <owl:Class rdf:about="http://example.org/ontology/energy-news#EnergyProject">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:label xml:lang="en">energy project</rdfs:label>
        <skos:definition xml:lang="en">A Process representing the planning, permitting, construction, and commissioning activity for developing energy infrastructure such as power plants, renewable installations, and grid upgrades</skos:definition>
    </owl:Class>



    <!-- http://example.org/ontology/energy-news#EnergyTechnology -->

    <owl:Class rdf:about="http://example.org/ontology/energy-news#EnergyTechnology">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
        <rdfs:label xml:lang="en">energy technology</rdfs:label>
        <skos:definition xml:lang="en">A GenericallyDependentContinuant representing a class of technological innovations used in energy generation, storage, transmission, or efficiency</skos:definition>
    </owl:Class>



    <!-- http://example.org/ontology/energy-news#EnergyTopic -->

    <owl:Class rdf:about="http://example.org/ontology/energy-news#EnergyTopic">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
        <rdfs:label xml:lang="en">energy topic</rdfs:label>
        <skos:definition xml:lang="en">An owl:Class whose instances are skos:Concept individuals representing subject areas within the energy sector used to classify news articles</skos:definition>
    </owl:Class>



    <!-- http://example.org/ontology/energy-news#Feed -->

    <owl:Class rdf:about="http://example.org/ontology/energy-news#Feed">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/ontology/energy-news#onPlatform"/>
                <owl:someValuesFrom rdf:resource="http://example.org/ontology/energy-news#SocialMediaPlatform"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">feed</rdfs:label>
        <skos:definition xml:lang="en">A GenericallyDependentContinuant that represents a curated social media feed for energy content</skos:definition>
    </owl:Class>



    <!-- http://example.org/ontology/energy-news#GeographicEntity -->

    <owl:Class rdf:about="http://example.org/ontology/energy-news#GeographicEntity">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000029"/>
        <rdfs:subClassOf rdf:resource="https://schema.org/Place"/>
        <rdfs:label xml:lang="en">geographic entity</rdfs:label>
        <skos:definition xml:lang="en">A Site that represents a country region or subnational area relevant to energy news coverage</skos:definition>
    </owl:Class>



    <!-- http://example.org/ontology/energy-news#GridZone -->

    <owl:Class rdf:about="http://example.org/ontology/energy-news#GridZone">
        <rdfs:subClassOf rdf:resource="http://example.org/ontology/energy-news#GeographicEntity"/>
        <rdfs:label xml:lang="en">grid zone</rdfs:label>
        <skos:definition xml:lang="en">A GeographicEntity that represents a region with defined electrical grid boundaries managed by a specific operator</skos:definition>
    </owl:Class>



    <!-- http://example.org/ontology/energy-news#MarketInstrument -->

    <owl:Class rdf:about="http://example.org/ontology/energy-news#MarketInstrument">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
        <rdfs:label xml:lang="en">market instrument</rdfs:label>
        <skos:definition xml:lang="en">A GenericallyDependentContinuant representing a financial or trading mechanism for energy commodities, capacity, or credits including carbon permits, PPAs, and RECs</skos:definition>
    </owl:Class>



    <!-- http://example.org/ontology/energy-news#MediaAttachment -->

    <owl:Class rdf:about="http://example.org/ontology/energy-news#MediaAttachment">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
        <rdfs:label xml:lang="en">media attachment</rdfs:label>
        <skos:definition xml:lang="en">A GenericallyDependentContinuant representing a multimedia object such as an image, video, or document attached to or embedded in a Post</skos:definition>
    </owl:Class>



    <!-- http://example.org/ontology/energy-news#Organization -->

    <owl:Class rdf:about="http://example.org/ontology/energy-news#Organization">
        <owl:equivalentClass rdf:resource="https://schema.org/Organization"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:label xml:lang="en">organization</rdfs:label>
        <skos:definition xml:lang="en">An Object that represents a company agency or institutional body mentioned in energy news</skos:definition>
    </owl:Class>



    <!-- http://example.org/ontology/energy-news#PolicyInstrument -->

    <owl:Class rdf:about="http://example.org/ontology/energy-news#PolicyInstrument">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
        <rdfs:label xml:lang="en">policy instrument</rdfs:label>
        <skos:definition xml:lang="en">A GenericallyDependentContinuant representing a regulatory, legislative, or economic tool used to incentivize, mandate, or restrict energy production or technology adoption</skos:definition>
    </owl:Class>



    <!-- http://example.org/ontology/energy-news#Post -->

    <owl:Class rdf:about="http://example.org/ontology/energy-news#Post">
        <owl:equivalentClass rdf:resource="https://schema.org/SocialMediaPosting"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/ontology/energy-news#postedBy"/>
                <owl:someValuesFrom rdf:resource="http://example.org/ontology/energy-news#AuthorAccount"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">post</rdfs:label>
        <skos:definition xml:lang="en">A GenericallyDependentContinuant that represents a social media post sharing energy content</skos:definition>
    </owl:Class>



    <!-- http://example.org/ontology/energy-news#PowerPlant -->

    <owl:Class rdf:about="http://example.org/ontology/energy-news#PowerPlant">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:label xml:lang="en">power plant</rdfs:label>
        <skos:definition xml:lang="en">An Object representing a facility that generates electricity or thermal energy, characterized by fuel type, capacity, and operational status</skos:definition>
    </owl:Class>



    <!-- http://example.org/ontology/energy-news#PriceDataPoint -->

    <owl:Class rdf:about="http://example.org/ontology/energy-news#PriceDataPoint">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
        <rdfs:label xml:lang="en">price data point</rdfs:label>
        <skos:definition xml:lang="en">A GenericallyDependentContinuant representing a quantified price or cost metric for energy, technology, or commodities at a specific point in time</skos:definition>
    </owl:Class>



    <!-- http://example.org/ontology/energy-news#ProjectStatus -->

    <owl:Class rdf:about="http://example.org/ontology/energy-news#ProjectStatus">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
        <rdfs:label xml:lang="en">project status</rdfs:label>
        <skos:definition xml:lang="en">A GenericallyDependentContinuant representing a categorical characterization of an energy project phase from planning through decommissioning</skos:definition>
    </owl:Class>



    <!-- http://example.org/ontology/energy-news#Publication -->

    <owl:Class rdf:about="http://example.org/ontology/energy-news#Publication">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:subClassOf rdf:resource="https://schema.org/NewsMediaOrganization"/>
        <owl:hasKey rdf:parseType="Collection">
            <rdf:Description rdf:about="http://example.org/ontology/energy-news#siteDomain"/>
        </owl:hasKey>
        <rdfs:label xml:lang="en">publication</rdfs:label>
        <skos:definition xml:lang="en">An Object that represents a news media outlet or website that publishes articles</skos:definition>
    </owl:Class>



    <!-- http://example.org/ontology/energy-news#RegulatoryBody -->

    <owl:Class rdf:about="http://example.org/ontology/energy-news#RegulatoryBody">
        <rdfs:subClassOf rdf:resource="http://example.org/ontology/energy-news#Organization"/>
        <rdfs:label xml:lang="en">regulatory body</rdfs:label>
        <skos:definition xml:lang="en">An Organization with authority to create, enforce, or adjudicate energy policy and grid operations within a defined jurisdiction</skos:definition>
    </owl:Class>



    <!-- http://example.org/ontology/energy-news#RenewableInstallation -->

    <owl:Class rdf:about="http://example.org/ontology/energy-news#RenewableInstallation">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:label xml:lang="en">renewable installation</rdfs:label>
        <skos:definition xml:lang="en">An Object representing a specific renewable energy facility such as a solar array, wind farm, or geothermal plant, characterized by technology type and capacity</skos:definition>
    </owl:Class>



    <!-- http://example.org/ontology/energy-news#SocialMediaPlatform -->

    <owl:Class rdf:about="http://example.org/ontology/energy-news#SocialMediaPlatform">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000031"/>
        <rdfs:label xml:lang="en">social media platform</rdfs:label>
        <skos:definition xml:lang="en">An owl:Class whose instances are named individuals representing social media platforms</skos:definition>
    </owl:Class>



    <!-- http://purl.obolibrary.org/obo/BFO_0000015 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000015">
        <rdfs:label xml:lang="en">process</rdfs:label>
    </owl:Class>



    <!-- http://purl.obolibrary.org/obo/BFO_0000029 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000029">
        <rdfs:label xml:lang="en">site</rdfs:label>
    </owl:Class>



    <!-- http://purl.obolibrary.org/obo/BFO_0000030 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000030">
        <rdfs:label xml:lang="en">object</rdfs:label>
    </owl:Class>



    <!-- http://purl.obolibrary.org/obo/BFO_0000031 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000031">
        <rdfs:label xml:lang="en">generically dependent continuant</rdfs:label>
    </owl:Class>



    <!-- http://rdfs.org/sioc/ns#UserAccount -->

    <owl:Class rdf:about="http://rdfs.org/sioc/ns#UserAccount"/>



    <!-- http://www.w3.org/2004/02/skos/core#Concept -->

    <owl:Class rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>



    <!-- http://www.w3.org/2004/02/skos/core#ConceptScheme -->

    <owl:Class rdf:about="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>



    <!-- https://schema.org/NewsArticle -->

    <owl:Class rdf:about="https://schema.org/NewsArticle"/>



    <!-- https://schema.org/NewsMediaOrganization -->

    <owl:Class rdf:about="https://schema.org/NewsMediaOrganization"/>



    <!-- https://schema.org/Organization -->

    <owl:Class rdf:about="https://schema.org/Organization"/>



    <!-- https://schema.org/Person -->

    <owl:Class rdf:about="https://schema.org/Person"/>



    <!-- https://schema.org/Place -->

    <owl:Class rdf:about="https://schema.org/Place"/>



    <!-- https://schema.org/SocialMediaPosting -->

    <owl:Class rdf:about="https://schema.org/SocialMediaPosting"/>



    <!--
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->




    <!-- http://example.org/ontology/energy-news#AIAndDataCenterDemand -->

    <owl:NamedIndividual rdf:about="http://example.org/ontology/energy-news#AIAndDataCenterDemand">
        <rdf:type rdf:resource="http://example.org/ontology/energy-news#EnergyTopic"/>
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:label xml:lang="en">AI and data center energy demand</rdfs:label>
        <skos:altLabel xml:lang="en">AI energy</skos:altLabel>
        <skos:altLabel xml:lang="en">AI power demand</skos:altLabel>
        <skos:altLabel xml:lang="en">data center power</skos:altLabel>
        <skos:definition xml:lang="en">A skos:Concept representing electricity demand from artificial intelligence workloads, data centers, and large-scale computing infrastructure</skos:definition>
        <skos:inScheme rdf:resource="http://example.org/ontology/energy-news#EnergyTopicScheme"/>
        <skos:topConceptOf rdf:resource="http://example.org/ontology/energy-news#EnergyTopicScheme"/>
    </owl:NamedIndividual>



    <!-- http://example.org/ontology/energy-news#Affordability -->

    <owl:NamedIndividual rdf:about="http://example.org/ontology/energy-news#Affordability">
        <rdf:type rdf:resource="http://example.org/ontology/energy-news#EnergyTopic"/>
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:label xml:lang="en">affordability</rdfs:label>
        <skos:altLabel xml:lang="en">energy bills</skos:altLabel>
        <skos:altLabel xml:lang="en">energy poverty</skos:altLabel>
        <skos:altLabel xml:lang="en">rate hike</skos:altLabel>
        <skos:broader rdf:resource="http://example.org/ontology/energy-news#EnergyJustice"/>
        <skos:definition xml:lang="en">A skos:Concept representing energy affordability bills rate increases and energy poverty</skos:definition>
        <skos:inScheme rdf:resource="http://example.org/ontology/energy-news#EnergyTopicScheme"/>
    </owl:NamedIndividual>



    <!-- http://example.org/ontology/energy-news#Agrivoltaics -->

    <owl:NamedIndividual rdf:about="http://example.org/ontology/energy-news#Agrivoltaics">
        <rdf:type rdf:resource="http://example.org/ontology/energy-news#EnergyTopic"/>
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:label xml:lang="en">agrivoltaics</rdfs:label>
        <skos:altLabel xml:lang="en">agrivoltaic</skos:altLabel>
