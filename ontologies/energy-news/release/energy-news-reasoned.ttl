@prefix : <http://example.org/ontology/energy-news#> .
@prefix obo: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sioc: <http://rdfs.org/sioc/ns#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix enews: <http://example.org/ontology/energy-news#> .
@prefix schema: <https://schema.org/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@base <http://example.org/ontology/energy-news> .

<http://example.org/ontology/energy-news> rdf:type owl:Ontology ;
                                           owl:versionIRI <http://example.org/ontology/energy-news/0.2.0> ;
                                           dcterms:created "2026-02-11" ;
                                           dcterms:creator "ontology-architect skill" ;
                                           dcterms:description "A lightweight OWL 2 DL ontology modeling the energy news media landscape as observed through social media posts."@en ;
                                           dcterms:license <https://spdx.org/licenses/MIT> ;
                                           dcterms:modified "2026-02-12" ;
                                           dcterms:title "Energy News Ontology"@en ;
                                           owl:priorVersion <http://example.org/ontology/energy-news/0.1.0> ;
                                           owl:versionInfo "0.2.0" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/created
dcterms:created rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/creator
dcterms:creator rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/description
dcterms:description rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
dcterms:license rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/modified
dcterms:modified rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
dcterms:title rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#altLabel
skos:altLabel rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#broader
skos:broader rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#definition
skos:definition rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#hasTopConcept
skos:hasTopConcept rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#inScheme
skos:inScheme rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#relatedMatch
skos:relatedMatch rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#topConceptOf
skos:topConceptOf rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://example.org/ontology/energy-news#coversTopic
enews:coversTopic rdf:type owl:ObjectProperty ;
                  owl:equivalentProperty schema:about ;
                  rdfs:domain enews:Article ;
                  rdfs:range enews:EnergyTopic ;
                  rdfs:label "covers topic"@en ;
                  skos:definition "Links an Article to an EnergyTopic individual it covers"@en .


###  http://example.org/ontology/energy-news#hasGeographicFocus
enews:hasGeographicFocus rdf:type owl:ObjectProperty ;
                         owl:equivalentProperty schema:contentLocation ;
                         rdfs:domain enews:Article ;
                         rdfs:range enews:GeographicEntity ;
                         rdfs:label "has geographic focus"@en ;
                         skos:definition "Links an Article to a GeographicEntity representing its geographic focus"@en .


###  http://example.org/ontology/energy-news#hasSector
enews:hasSector rdf:type owl:ObjectProperty ;
                rdfs:domain enews:Organization ;
                rdfs:range enews:EnergyTopic ;
                rdfs:label "has sector"@en ;
                skos:definition "Links an Organization to an EnergyTopic sector it operates in"@en .


###  http://example.org/ontology/energy-news#mentionsOrganization
enews:mentionsOrganization rdf:type owl:ObjectProperty ;
                           rdfs:subPropertyOf schema:mentions ;
                           rdfs:domain enews:Article ;
                           rdfs:range enews:Organization ;
                           rdfs:label "mentions organization"@en ;
                           skos:definition "Links an Article to an Organization mentioned in its coverage"@en .


###  http://example.org/ontology/energy-news#onPlatform
enews:onPlatform rdf:type owl:ObjectProperty ,
                          owl:FunctionalProperty ;
                 rdfs:range enews:SocialMediaPlatform ;
                 rdfs:label "on platform"@en ;
                 skos:definition "Links an AuthorAccount or Feed to the SocialMediaPlatform it belongs to"@en .


###  http://example.org/ontology/energy-news#postedBy
enews:postedBy rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf schema:author ;
               rdf:type owl:FunctionalProperty ;
               rdfs:domain enews:Post ;
               rdfs:range enews:AuthorAccount ;
               rdfs:label "posted by"@en ;
               skos:definition "Links a Post to the AuthorAccount who created it"@en .


###  http://example.org/ontology/energy-news#publishedBy
enews:publishedBy rdf:type owl:ObjectProperty ;
                  owl:equivalentProperty schema:publisher ;
                  rdf:type owl:FunctionalProperty ;
                  rdfs:domain enews:Article ;
                  rdfs:range enews:Publication ;
                  rdfs:label "published by"@en ;
                  skos:definition "Links an Article to the Publication that published it"@en .


###  http://example.org/ontology/energy-news#sharesArticle
enews:sharesArticle rdf:type owl:ObjectProperty ;
                    owl:equivalentProperty schema:sharedContent ;
                    rdf:type owl:FunctionalProperty ;
                    rdfs:domain enews:Post ;
                    rdfs:range enews:Article ;
                    rdfs:label "shares article"@en ;
                    skos:definition "Links a Post to the Article it shares via embedded link"@en .


###  https://schema.org/about
schema:about rdf:type owl:ObjectProperty .


###  https://schema.org/author
schema:author rdf:type owl:ObjectProperty .


###  https://schema.org/contentLocation
schema:contentLocation rdf:type owl:ObjectProperty .


###  https://schema.org/mentions
schema:mentions rdf:type owl:ObjectProperty .


###  https://schema.org/publisher
schema:publisher rdf:type owl:ObjectProperty .


###  https://schema.org/sharedContent
schema:sharedContent rdf:type owl:ObjectProperty .


#################################################################
#    Data properties
#################################################################

###  http://example.org/ontology/energy-news#description
enews:description rdf:type owl:DatatypeProperty ;
                  owl:equivalentProperty schema:description ;
                  rdf:type owl:FunctionalProperty ;
                  rdfs:domain enews:Article ;
                  rdfs:range xsd:string ;
                  rdfs:label "description"@en ;
                  skos:definition "The description or summary text of an Article"@en .


###  http://example.org/ontology/energy-news#handle
enews:handle rdf:type owl:DatatypeProperty ,
                      owl:FunctionalProperty ;
             rdfs:domain enews:AuthorAccount ;
             rdfs:range xsd:string ;
             rdfs:label "handle"@en ;
             skos:definition "The handle or username string for an AuthorAccount"@en .


###  http://example.org/ontology/energy-news#publishedDate
enews:publishedDate rdf:type owl:DatatypeProperty ;
                    owl:equivalentProperty schema:datePublished ;
                    rdf:type owl:FunctionalProperty ;
                    rdfs:domain enews:Article ;
                    rdfs:range xsd:dateTime ;
                    rdfs:label "published date"@en ;
                    skos:definition "The publication date of an Article"@en .


###  http://example.org/ontology/energy-news#siteDomain
enews:siteDomain rdf:type owl:DatatypeProperty ,
                          owl:FunctionalProperty ;
                 rdfs:domain enews:Publication ;
                 rdfs:range xsd:string ;
                 rdfs:label "site domain"@en ;
                 skos:definition "The domain name string of a Publication"@en .


###  http://example.org/ontology/energy-news#title
enews:title rdf:type owl:DatatypeProperty ;
            owl:equivalentProperty schema:headline ;
            rdf:type owl:FunctionalProperty ;
            rdfs:domain enews:Article ;
            rdfs:range xsd:string ;
            rdfs:label "title"@en ;
            skos:definition "The headline or title string of an Article"@en .


###  http://example.org/ontology/energy-news#url
enews:url rdf:type owl:DatatypeProperty ;
          owl:equivalentProperty schema:url ;
          rdf:type owl:FunctionalProperty ;
          rdfs:domain enews:Article ;
          rdfs:range xsd:anyURI ;
          rdfs:label "url"@en ;
          skos:definition "The URL of an Article"@en .


###  https://schema.org/datePublished
schema:datePublished rdf:type owl:DatatypeProperty .


###  https://schema.org/description
schema:description rdf:type owl:DatatypeProperty .


###  https://schema.org/headline
schema:headline rdf:type owl:DatatypeProperty .


###  https://schema.org/url
schema:url rdf:type owl:DatatypeProperty .


#################################################################
#    Classes
#################################################################

###  http://example.org/ontology/energy-news#Article
enews:Article rdf:type owl:Class ;
              rdfs:subClassOf obo:BFO_0000031 ,
                              schema:NewsArticle ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty enews:coversTopic ;
                                owl:someValuesFrom enews:EnergyTopic
                              ] ;
              owl:hasKey ( enews:url
                         ) ;
              rdfs:label "article"@en ;
              skos:definition "A GenericallyDependentContinuant that represents a news article referenced by an embedded link in a social media post"@en .


###  http://example.org/ontology/energy-news#AuthorAccount
enews:AuthorAccount rdf:type owl:Class ;
                    owl:equivalentClass sioc:UserAccount ;
                    rdfs:subClassOf obo:BFO_0000031 ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty enews:onPlatform ;
                                      owl:someValuesFrom enews:SocialMediaPlatform
                                    ] ;
                    owl:hasKey ( enews:onPlatform
                                 enews:handle
                               ) ;
                    rdfs:label "author account"@en ;
                    skos:definition "A GenericallyDependentContinuant that represents a social media account that shares energy news"@en ;
                    skos:relatedMatch schema:Person .


###  http://example.org/ontology/energy-news#EnergyTopic
enews:EnergyTopic rdf:type owl:Class ;
                  rdfs:subClassOf obo:BFO_0000031 ;
                  rdfs:label "energy topic"@en ;
                  skos:definition "An owl:Class whose instances are skos:Concept individuals representing subject areas within the energy sector used to classify news articles"@en .


###  http://example.org/ontology/energy-news#Feed
enews:Feed rdf:type owl:Class ;
           rdfs:subClassOf obo:BFO_0000031 ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty enews:onPlatform ;
                             owl:someValuesFrom enews:SocialMediaPlatform
                           ] ;
           rdfs:label "feed"@en ;
           skos:definition "A GenericallyDependentContinuant that represents a curated social media feed for energy content"@en .


###  http://example.org/ontology/energy-news#GeographicEntity
enews:GeographicEntity rdf:type owl:Class ;
                       rdfs:subClassOf obo:BFO_0000029 ,
                                       schema:Place ;
                       rdfs:label "geographic entity"@en ;
                       skos:definition "A Site that represents a country region or subnational area relevant to energy news coverage"@en .


###  http://example.org/ontology/energy-news#Organization
enews:Organization rdf:type owl:Class ;
                   owl:equivalentClass schema:Organization ;
                   rdfs:subClassOf obo:BFO_0000030 ;
                   rdfs:label "organization"@en ;
                   skos:definition "An Object that represents a company agency or institutional body mentioned in energy news"@en .


###  http://example.org/ontology/energy-news#Post
enews:Post rdf:type owl:Class ;
           owl:equivalentClass schema:SocialMediaPosting ;
           rdfs:subClassOf obo:BFO_0000031 ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty enews:postedBy ;
                             owl:someValuesFrom enews:AuthorAccount
                           ] ;
           rdfs:label "post"@en ;
           skos:definition "A GenericallyDependentContinuant that represents a social media post sharing energy content"@en .


###  http://example.org/ontology/energy-news#Publication
enews:Publication rdf:type owl:Class ;
                  rdfs:subClassOf obo:BFO_0000030 ,
                                  schema:NewsMediaOrganization ;
                  owl:hasKey ( enews:siteDomain
                             ) ;
                  rdfs:label "publication"@en ;
                  skos:definition "An Object that represents a news media outlet or website that publishes articles"@en .


###  http://example.org/ontology/energy-news#SocialMediaPlatform
enews:SocialMediaPlatform rdf:type owl:Class ;
                          rdfs:subClassOf obo:BFO_0000031 ;
                          rdfs:label "social media platform"@en ;
                          skos:definition "An owl:Class whose instances are named individuals representing social media platforms"@en .


###  http://purl.obolibrary.org/obo/BFO_0000029
obo:BFO_0000029 rdf:type owl:Class ;
                rdfs:subClassOf owl:Thing ;
                rdfs:label "site"@en .


###  http://purl.obolibrary.org/obo/BFO_0000030
obo:BFO_0000030 rdf:type owl:Class ;
                rdfs:subClassOf owl:Thing ;
                rdfs:label "object"@en .


###  http://purl.obolibrary.org/obo/BFO_0000031
obo:BFO_0000031 rdf:type owl:Class ;
                rdfs:subClassOf owl:Thing ;
                rdfs:label "generically dependent continuant"@en .


###  http://rdfs.org/sioc/ns#UserAccount
sioc:UserAccount rdf:type owl:Class ;
                 rdfs:subClassOf obo:BFO_0000031 .


###  http://www.w3.org/2004/02/skos/core#Concept
skos:Concept rdf:type owl:Class ;
             rdfs:subClassOf owl:Thing .


###  http://www.w3.org/2004/02/skos/core#ConceptScheme
skos:ConceptScheme rdf:type owl:Class ;
                   rdfs:subClassOf owl:Thing .


###  https://schema.org/NewsArticle
schema:NewsArticle rdf:type owl:Class ;
                   rdfs:subClassOf owl:Thing .


###  https://schema.org/NewsMediaOrganization
schema:NewsMediaOrganization rdf:type owl:Class ;
                             rdfs:subClassOf owl:Thing .


###  https://schema.org/Organization
schema:Organization rdf:type owl:Class ;
                    rdfs:subClassOf obo:BFO_0000030 .


###  https://schema.org/Person
schema:Person rdf:type owl:Class ;
              rdfs:subClassOf owl:Thing .


###  https://schema.org/Place
schema:Place rdf:type owl:Class ;
             rdfs:subClassOf owl:Thing .


###  https://schema.org/SocialMediaPosting
schema:SocialMediaPosting rdf:type owl:Class ;
                          rdfs:subClassOf obo:BFO_0000031 .


#################################################################
#    Individuals
#################################################################

###  http://example.org/ontology/energy-news#Affordability
enews:Affordability rdf:type owl:NamedIndividual ,
                             enews:EnergyTopic ,
                             skos:Concept ;
                    rdfs:label "affordability"@en ;
                    skos:altLabel "energy bills"@en ,
                                  "energy poverty"@en ,
                                  "rate hike"@en ;
                    skos:broader enews:EnergyJustice ;
                    skos:definition "A skos:Concept representing energy affordability bills rate increases and energy poverty"@en ;
                    skos:inScheme enews:EnergyTopicScheme .


###  http://example.org/ontology/energy-news#Agrivoltaics
enews:Agrivoltaics rdf:type owl:NamedIndividual ,
                            enews:EnergyTopic ,
                            skos:Concept ;
                   rdfs:label "agrivoltaics"@en ;
                   skos:altLabel "agrivoltaic"@en ,
                                 "solar farming"@en ;
                   skos:broader enews:EnvironmentAndLandUse ;
                   skos:definition "A skos:Concept representing co-location of solar panels and agriculture"@en ;
                   skos:inScheme enews:EnergyTopicScheme .


###  http://example.org/ontology/energy-news#Bluesky
enews:Bluesky rdf:type owl:NamedIndividual ,
                       enews:SocialMediaPlatform ;
              owl:differentFrom enews:Twitter ;
              rdfs:label "Bluesky"@en ;
              skos:altLabel "Bluesky Social"@en ,
                            "bsky"@en ;
              skos:definition "A SocialMediaPlatform individual representing the Bluesky social network"@en .


###  http://example.org/ontology/energy-news#BuildingElectrification
enews:BuildingElectrification rdf:type owl:NamedIndividual ,
                                       enews:EnergyTopic ,
                                       skos:Concept ;
                              rdfs:label "building electrification"@en ;
                              skos:altLabel "building electrification"@en ,
                                            "gas-to-electric"@en ;
                              skos:broader enews:BuildingsAndEfficiency ;
                              skos:definition "A skos:Concept representing switching buildings from gas to electric systems"@en ;
                              skos:inScheme enews:EnergyTopicScheme .


###  http://example.org/ontology/energy-news#BuildingsAndEfficiency
enews:BuildingsAndEfficiency rdf:type owl:NamedIndividual ,
                                      enews:EnergyTopic ,
                                      skos:Concept ;
                             rdfs:label "buildings and efficiency"@en ;
                             skos:altLabel "building energy"@en ,
                                           "energy efficiency"@en ;
                             skos:definition "A skos:Concept representing building energy performance retrofits and distributed generation"@en ;
                             skos:inScheme enews:EnergyTopicScheme ;
                             skos:topConceptOf enews:EnergyTopicScheme .


###  http://example.org/ontology/energy-news#CarbonCapture
enews:CarbonCapture rdf:type owl:NamedIndividual ,
                             enews:EnergyTopic ,
                             skos:Concept ;
                    rdfs:label "carbon capture"@en ;
                    skos:altLabel "CCS"@en ,
                                  "CCUS"@en ,
                                  "carbon capture"@en ;
                    skos:definition "A skos:Concept representing carbon capture utilization and storage technologies"@en ;
                    skos:inScheme enews:EnergyTopicScheme ;
                    skos:topConceptOf enews:EnergyTopicScheme .


###  http://example.org/ontology/energy-news#ClimateAndEmissions
enews:ClimateAndEmissions rdf:type owl:NamedIndividual ,
                                   enews:EnergyTopic ,
                                   skos:Concept ;
                          rdfs:label "climate and emissions"@en ;
                          skos:altLabel "GHG"@en ,
                                        "climate"@en ,
                                        "emissions"@en ;
                          skos:definition "A skos:Concept representing climate change and greenhouse gas emissions in the energy context"@en ;
                          skos:inScheme enews:EnergyTopicScheme ;
                          skos:topConceptOf enews:EnergyTopicScheme .


###  http://example.org/ontology/energy-news#Coal
enews:Coal rdf:type owl:NamedIndividual ,
                    enews:EnergyTopic ,
                    skos:Concept ;
           rdfs:label "coal"@en ;
           skos:altLabel "coal power"@en ,
                         "coal-fired"@en ;
           skos:broader enews:Fossil ;
           skos:definition "A skos:Concept representing coal extraction and coal-fired power generation"@en ;
           skos:inScheme enews:EnergyTopicScheme .


###  http://example.org/ontology/energy-news#Commodity
enews:Commodity rdf:type owl:NamedIndividual ,
                         enews:EnergyTopic ,
                         skos:Concept ;
                rdfs:label "commodity"@en ;
                skos:altLabel "commodity trading"@en ,
                              "gas prices"@en ,
                              "oil futures"@en ;
                skos:broader enews:EnergyMarkets ;
                skos:definition "A skos:Concept representing oil futures gas spot prices and energy commodity trading"@en ;
                skos:inScheme enews:EnergyTopicScheme .


###  http://example.org/ontology/energy-news#CommunityEnergy
enews:CommunityEnergy rdf:type owl:NamedIndividual ,
                               enews:EnergyTopic ,
                               skos:Concept ;
                      rdfs:label "community energy"@en ;
                      skos:altLabel "community solar"@en ,
                                    "cooperative energy"@en ;
                      skos:broader enews:EnergyJustice ;
                      skos:definition "A skos:Concept representing community-owned energy projects and cooperatives"@en ;
                      skos:inScheme enews:EnergyTopicScheme .


###  http://example.org/ontology/energy-news#CorporateDeals
enews:CorporateDeals rdf:type owl:NamedIndividual ,
                              enews:EnergyTopic ,
                              skos:Concept ;
                     rdfs:label "corporate deals"@en ;
                     skos:altLabel "M&A"@en ,
                                   "acquisition"@en ,
                                   "merger"@en ;
                     skos:broader enews:EnergyFinance ;
                     skos:definition "A skos:Concept representing acquisitions mergers and corporate stakes in energy companies"@en ;
                     skos:inScheme enews:EnergyTopicScheme .


###  http://example.org/ontology/energy-news#CriticalMinerals
enews:CriticalMinerals rdf:type owl:NamedIndividual ,
                                enews:EnergyTopic ,
                                skos:Concept ;
                       rdfs:label "critical minerals"@en ;
                       skos:altLabel "cobalt"@en ,
                                     "lithium"@en ,
                                     "rare earth"@en ,
                                     "silicon"@en ;
                       skos:broader enews:EnergyGeopolitics ;
                       skos:definition "A skos:Concept representing critical minerals required for energy technologies"@en ;
                       skos:inScheme enews:EnergyTopicScheme .


###  http://example.org/ontology/energy-news#DataCenterDemand
enews:DataCenterDemand rdf:type owl:NamedIndividual ,
                                enews:EnergyTopic ,
                                skos:Concept ;
                       rdfs:label "data center demand"@en ;
                       skos:altLabel "AI energy demand"@en ,
                                     "data center energy"@en ;
                       skos:definition "A skos:Concept representing electricity demand from data centers and artificial intelligence workloads"@en ;
                       skos:inScheme enews:EnergyTopicScheme ;
                       skos:topConceptOf enews:EnergyTopicScheme .


###  http://example.org/ontology/energy-news#Decarbonization
enews:Decarbonization rdf:type owl:NamedIndividual ,
                               enews:EnergyTopic ,
                               skos:Concept ;
                      rdfs:label "decarbonization"@en ;
                      skos:altLabel "carbon reduction"@en ,
                                    "decarbonisation"@en ;
                      skos:broader enews:ClimateAndEmissions ;
                      skos:definition "A skos:Concept representing strategies and progress toward reducing carbon emissions"@en ;
                      skos:inScheme enews:EnergyTopicScheme .


###  http://example.org/ontology/energy-news#Distribution
enews:Distribution rdf:type owl:NamedIndividual ,
                            enews:EnergyTopic ,
                            skos:Concept ;
                   rdfs:label "distribution"@en ;
                   skos:altLabel "local grid"@en ,
                                 "power distribution"@en ;
                   skos:broader enews:GridAndInfrastructure ;
                   skos:definition "A skos:Concept representing local electricity distribution networks"@en ;
                   skos:inScheme enews:EnergyTopicScheme .


###  http://example.org/ontology/energy-news#EVCharging
enews:EVCharging rdf:type owl:NamedIndividual ,
                          enews:EnergyTopic ,
                          skos:Concept ;
                 rdfs:label "ev charging"@en ;
                 skos:altLabel "EV charger"@en ,
                               "EVSE"@en ,
                               "charging station"@en ;
                 skos:broader enews:Electrification ;
                 skos:definition "A skos:Concept representing electric vehicle charging infrastructure and networks"@en ;
                 skos:inScheme enews:EnergyTopicScheme .


###  http://example.org/ontology/energy-news#EfficiencyRecords
enews:EfficiencyRecords rdf:type owl:NamedIndividual ,
                                 enews:EnergyTopic ,
                                 skos:Concept ;
                        owl:differentFrom enews:Patent ;
                        rdfs:label "efficiency records"@en ;
                        skos:altLabel "solar efficiency"@en ,
                                      "technology record"@en ;
                        skos:broader enews:ResearchAndInnovation ;
                        skos:definition "A skos:Concept representing technology efficiency records and breakthrough achievements"@en ;
                        skos:inScheme enews:EnergyTopicScheme .


###  http://example.org/ontology/energy-news#ElectricTransport
enews:ElectricTransport rdf:type owl:NamedIndividual ,
                                 enews:EnergyTopic ,
                                 skos:Concept ;
                        rdfs:label "electric transport"@en ;
                        skos:altLabel "e-mobility"@en ,
                                      "electric bus"@en ,
                                      "electric ferry"@en ;
                        skos:broader enews:Electrification ;
                        skos:definition "A skos:Concept representing electrification of ships ferries buses and other transport"@en ;
                        skos:inScheme enews:EnergyTopicScheme .


###  http://example.org/ontology/energy-news#ElectricVehicles
enews:ElectricVehicles rdf:type owl:NamedIndividual ,
                                enews:EnergyTopic ,
                                skos:Concept ;
                       rdfs:label "electric vehicles"@en ;
                       skos:altLabel "BEV"@en ,
                                     "EV"@en ,
                                     "electric car"@en ;
                       skos:broader enews:Electrification ;
                       skos:definition "A skos:Concept representing battery and plug-in electric vehicles"@en ;
                       skos:inScheme enews:EnergyTopicScheme .


###  http://example.org/ontology/energy-news#Electrification
enews:Electrification rdf:type owl:NamedIndividual ,
                               enews:EnergyTopic ,
                               skos:Concept ;
                      rdfs:label "electrification"@en ;
                      skos:altLabel "electric transition"@en ,
                                    "electrification"@en ;
