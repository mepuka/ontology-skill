@prefix obo: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://example.org/ontology/energy-news/bfo-declarations> a owl:Ontology ;
    rdfs:label "BFO Declarations for Energy News Ontology" ;
    rdfs:comment "MIREOT-style BFO class stubs. Not a substitute for full BFO import." .

obo:BFO_0000015 a owl:Class ;
    rdfs:label "process"@en .

obo:BFO_0000029 a owl:Class ;
    rdfs:label "site"@en .

obo:BFO_0000030 a owl:Class ;
    rdfs:label "object"@en .

obo:BFO_0000031 a owl:Class ;
    rdfs:label "generically dependent continuant"@en .
