<https://skygest.dev/vocab/energy> a owl:Ontology ;
    dcterms:created "2026-04-11"^^xsd:date ;
    dcterms:description "A SKOS vocabulary mapping natural-language surface forms in energy chart text to canonical data-variable facets for the Skygest Stage 2 resolver pipeline."@en ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:title "Skygest Energy Vocabulary"@en ;
    owl:imports <https://skygest.dev/vocab/energy/imports/datacube-extract>,
        <https://skygest.dev/vocab/energy/imports/dcat-extract>,
        <https://skygest.dev/vocab/energy/imports/foaf-extract>,
        <https://skygest.dev/vocab/energy/imports/schema-extract> ;
    owl:versionIRI sevocab:0.2.0 ;
    owl:versionInfo "0.2.0" .

sevocab:Annual a skos:Concept ;
    rdfs:label "annual"@en ;
    skos:altLabel "annual data"@en,
        "year"@en,
        "yearly"@en ;
