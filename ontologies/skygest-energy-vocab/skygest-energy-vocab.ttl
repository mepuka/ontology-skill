sevocab:hasVariable a owl:ObjectProperty ;
    rdfs:label "has variable"@en ;
    rdfs:comment "Higher-level dataset-to-variable view. The structural path in this vocabulary runs Dataset → Series → Variable via sevocab:hasSeries and sevocab:implementsVariable; hasVariable remains as the denormalized view asserting that a dataset is associated with a given variable regardless of how many series realize it. CQ/SPARQL consumers should traverse the explicit hasSeries + implementsVariable path rather than relying on OWL property-chain entailment, because simple entailment does not compute property chains."@en ;
    rdfs:domain sevocab:EnergyDataset ;
    rdfs:range sevocab:EnergyVariable ;
    skos:definition "Links an energy dataset to a constituent energy variable. Documented as the higher-level view over the Dataset → Series → Variable chain."@en .

sevocab:hasSeries a owl:ObjectProperty ;
    rdfs:label "has series"@en ;
    rdfs:comment "Links an EnergyDataset to a concrete published Series that implements a Variable in that dataset's reporting context. Inverse of sevocab:publishedInDataset."@en ;
    rdfs:domain sevocab:EnergyDataset ;
    rdfs:range sevocab:Series ;
    owl:inverseOf sevocab:publishedInDataset ;
    skos:definition "Structural link from an energy dataset to a concrete series it publishes."@en .

sevocab:implementsVariable a owl:ObjectProperty,
        owl:FunctionalProperty ;
    rdfs:label "implements variable"@en ;
    rdfs:comment "Functional link from a Series to the single EnergyVariable it realizes in its publishing dataset's reporting context. A Series implements exactly one Variable."@en ;
    rdfs:domain sevocab:Series ;
    rdfs:range sevocab:EnergyVariable ;
    skos:definition "The energy variable realized by this series."@en .

sevocab:publishedInDataset a owl:ObjectProperty,
        owl:FunctionalProperty ;
    rdfs:label "published in dataset"@en ;
    rdfs:comment "Functional link from a Series back to the EnergyDataset that publishes it. A Series belongs to exactly one dataset. Inverse of sevocab:hasSeries."@en ;
    rdfs:domain sevocab:Series ;
    rdfs:range sevocab:EnergyDataset ;
    owl:inverseOf sevocab:hasSeries ;
    skos:definition "The energy dataset in which this series is published."@en .

sevocab:EnergyAgent a owl:Class ;
    rdfs:label "energy agent"@en ;
    rdfs:subClassOf foaf:Agent ;
    skos:definition "A FOAF agent that publishes one or more energy datasets."@en .

sevocab:EnergyDataset a owl:Class ;
    rdfs:label "energy dataset"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty dcat:distribution ;
            owl:someValuesFrom dcat:Distribution ],
        [ a owl:Restriction ;
            owl:onProperty sevocab:hasVariable ;
            owl:someValuesFrom sevocab:EnergyVariable ],
        [ a owl:Restriction ;
            owl:onProperty dcterms:publisher ;
            owl:someValuesFrom sevocab:EnergyAgent ],
        dcat:Dataset ;
    skos:definition "A DCAT dataset that contains one or more energy variables and is published by an energy agent."@en .

sevocab:Wind a skos:Concept ;
    rdfs:label "wind"@en ;
    skos:altLabel "Windenergie"@de,
        "Windkraft"@de,
        "AWE"@en,
        "HAWP"@en,
        "airborne wind energy"@en,
        "airborne wind power"@en,
        "clean power"@en,
        "ecological energy"@en,
        "ecological power"@en,
        "green electricity"@en,
        "green energy"@en,
        "green power"@en,
        "high-altitude wind power"@en,
        "low-carbon energy"@en,
        "renewable energy"@en,
        "sustainable energy"@en,
        "wind"@en,
        "wind power"@en,
        "wind power energy"@en ;
    skos:definition "A technologyOrFuel concept representing wind energy generation technology"@en ;
    skos:inScheme sevocab:TechnologyOrFuelScheme ;
    skos:prefLabel "wind"@en ;
    skos:topConceptOf sevocab:TechnologyOrFuelScheme .

sevocab:aggregation a qb:DimensionProperty,
        owl:ObjectProperty ;
    rdfs:label "aggregation"@en ;
    qb:codeList sevocab:AggregationScheme ;
    skos:definition "The temporal aggregation method."@en .

sevocab:domainObject a qb:DimensionProperty,
        owl:ObjectProperty ;
    rdfs:label "domain object"@en ;
    qb:codeList sevocab:DomainObjectScheme ;
    skos:definition "The entity or system the measurement is about."@en .

sevocab:measuredProperty a qb:DimensionProperty,
        owl:ObjectProperty ;
    rdfs:label "measured property"@en ;
    qb:codeList sevocab:MeasuredPropertyScheme ;
    skos:definition "The physical or economic quantity being measured."@en .

sevocab:policyInstrument a qb:DimensionProperty,
        owl:ObjectProperty ;
    rdfs:label "policy instrument"@en ;
    qb:codeList sevocab:PolicyInstrumentScheme ;
    skos:definition "The policy mechanism involved."@en .

sevocab:statisticType a qb:DimensionProperty,
        owl:ObjectProperty ;
    rdfs:label "statistic type"@en ;
    qb:codeList sevocab:StatisticTypeScheme ;
    skos:definition "The kind of statistical measure."@en .

sevocab:technologyOrFuel a qb:DimensionProperty,
        owl:ObjectProperty ;
    rdfs:label "technology or fuel"@en ;
    qb:codeList sevocab:TechnologyOrFuelScheme ;
    skos:definition "The energy technology or fuel type."@en .

sevocab:unitFamily a qb:DimensionProperty,
        owl:ObjectProperty ;
    rdfs:label "unit family"@en ;
    qb:codeList sevocab:UnitFamilyScheme ;
    skos:definition "The family of measurement units."@en .

sevocab:EnergyVariable a owl:Class ;
    rdfs:label "energy variable"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass skos:Concept ;
            owl:onProperty sevocab:aggregation ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass skos:Concept ;
            owl:onProperty sevocab:statisticType ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass skos:Concept ;
            owl:onProperty sevocab:unitFamily ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass skos:Concept ;
            owl:onProperty sevocab:policyInstrument ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass skos:Concept ;
            owl:onProperty sevocab:measuredProperty ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass skos:Concept ;
            owl:onProperty sevocab:technologyOrFuel ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass skos:Concept ;
            owl:onProperty sevocab:domainObject ],
        schema:StatisticalVariable ;
    skos:definition "A statistical variable that is composed of up to seven facet dimensions drawn from sevocab concept schemes."@en .

sevocab:Series a owl:Class ;
    rdfs:label "series"@en ;
    rdfs:comment """A concrete published series that implements exactly one EnergyVariable within exactly one EnergyDataset's reporting context. Each Series sits on the structural path EnergyAgent ← EnergyDataset ← Series → EnergyVariable, with sevocab:publishedInDataset and sevocab:implementsVariable as functional links.

Naming disambiguation (important):

(1) sevocab:Series is NOT dcat:DatasetSeries. dcat:DatasetSeries in DCAT 3 groups curated editions of related datasets (e.g. annual releases of a statistical publication); sevocab:Series is an intra-dataset structural node that names how a single Variable is realized inside one dataset.

(2) sevocab:Series is also distinct from the pre-existing 'dataset-series' family concepts used elsewhere in the Skygest runtime data (e.g. dataset-series/dser_* references). Those name publisher-side dataset groupings; sevocab:Series names the Variable-implementing record a dataset exposes.

Fixed-dimension bag semantics (place/market/frequency/etc.) are deliberately deferred and are not modelled on this class in this slice."""@en ;
    skos:definition "A concrete published series that implements a single EnergyVariable within a single EnergyDataset's reporting context."@en .

sevocab:StatisticTypeScheme a skos:ConceptScheme ;
    rdfs:label "statistic type scheme"@en ;
    skos:definition "A concept scheme that partitions the statistical-measure space into the types of quantity a chart can depict"@en ;
    skos:prefLabel "statistic type scheme"@en .

sevocab:FrequencyScheme a skos:ConceptScheme ;
    rdfs:label "frequency scheme"@en ;
    skos:definition "A concept scheme that classifies temporal resolution of chart data series (Phase 2 — FixedDims)"@en ;
    skos:prefLabel "frequency scheme"@en .

sevocab:AggregationScheme a skos:ConceptScheme ;
    rdfs:label "aggregation scheme"@en ;
    skos:definition "A concept scheme that partitions temporal aggregation methods applied to chart data"@en ;
    skos:prefLabel "aggregation scheme"@en .

sevocab:UnitFamilyScheme a skos:ConceptScheme ;
    rdfs:label "unit family scheme"@en ;
    skos:definition "A concept scheme that partitions measurement-unit families used in energy chart axis labels"@en ;
    skos:prefLabel "unit family scheme"@en .

sevocab:PolicyInstrumentScheme a skos:ConceptScheme ;
    rdfs:label "policy instrument scheme"@en ;
    skos:definition "A concept scheme that classifies energy policy mechanisms referenced in chart text, covering market mechanisms, support instruments, and procurement structures"@en ;
    skos:prefLabel "policy instrument scheme"@en .

sevocab:MeasuredPropertyScheme a skos:ConceptScheme ;
    rdfs:label "measured property scheme"@en ;
    skos:definition "A concept scheme that classifies what is being measured in an energy statistic, aligned with IEA energy balance flow categories"@en ;
    skos:prefLabel "measured property scheme"@en .

sevocab:TechnologyOrFuelScheme a skos:ConceptScheme ;
    rdfs:label "technology or fuel scheme"@en ;
    skos:definition "A concept scheme that enumerates energy technologies and fuels referenced in chart text"@en ;
    skos:prefLabel "technology or fuel scheme"@en .

sevocab:DomainObjectScheme a skos:ConceptScheme ;
    rdfs:label "domain object scheme"@en ;
    skos:definition "A concept scheme that classifies the domain object to which an energy measurement applies, covering IEA sectors, energy carriers, and technology domains"@en ;
    skos:prefLabel "domain object scheme"@en .

[] a owl:AllDisjointClasses ;
    owl:members ( sevocab:EnergyVariable sevocab:EnergyDataset sevocab:EnergyAgent sevocab:Series ) .
