# =============================================================================
# D. CROSS-SCHEME COLLISION PREVENTION
# Within each scheme, no two concepts may share the same English altLabel.
# This is the SHACL equivalent of the build-time collision check in build.py.
# =============================================================================

sevocab-shapes:IntraSchemeAltLabelUniqueness a sh:NodeShape ;
    sh:targetClass skos:Concept ;
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "Intra-scheme altLabel collision: concept {?this} and concept {?other} in the same scheme share English altLabel '{?label}'" ;
        sh:select """
            PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
            SELECT $this ?label ?other WHERE {
                $this skos:inScheme ?scheme ;
                      skos:altLabel ?label .
                ?other skos:inScheme ?scheme ;
                       skos:altLabel ?label .
                FILTER(LANG(?label) = "en")
                FILTER(STR($this) < STR(?other))
            }
        """
    ] .


# =============================================================================
# E. SURFACE FORM PROVENANCE — SurfaceFormEntryShape
# Validates provenance annotations on surface form entries.
# =============================================================================

sevocab-shapes:SurfaceFormEntryShape a sh:NodeShape ;
    sh:targetClass sevocab:SurfaceFormEntry ;

    # surfaceFormValue is required and functional
    sh:property [
        sh:path sevocab:surfaceFormValue ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:minLength 1 ;
        sh:name "surface form value" ;
        sh:message "SurfaceFormEntry must have exactly one non-empty surfaceFormValue"
    ] ;

    # provenance is required, functional, and constrained to 7 values
    sh:property [
        sh:path sevocab:provenance ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:in ( "cold-start-corpus" "hand-curated" "oeo-derived"
                "ucum-derived" "wikidata-derived" "agent-curated"
                "eval-feedback" ) ;
        sh:name "provenance tag" ;
        sh:message "SurfaceFormEntry must have exactly one valid provenance tag"
    ] ;

    # CQ-028: notes required for agent-curated and eval-feedback
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "Notes are required when provenance is agent-curated or eval-feedback (CQ-028)" ;
        sh:select """
            PREFIX sevocab: <https://skygest.dev/vocab/energy/>
            PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
            SELECT $this WHERE {
                $this sevocab:provenance ?prov .
                FILTER(?prov IN ("agent-curated", "eval-feedback"))
                FILTER NOT EXISTS { $this skos:note ?note }
            }
        """
    ] .
