@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix sevocab: <https://skygest.dev/vocab/energy/> .
@prefix sevocab-shapes: <https://skygest.dev/vocab/energy/shapes/> .

# =============================================================================
# A. STRUCTURAL COMPLETENESS — ConceptShape
# Validates every skos:Concept in the vocabulary.
# =============================================================================

sevocab-shapes:ConceptShape a sh:NodeShape ;
    sh:targetClass skos:Concept ;

    # CQ-022: every concept must have exactly one prefLabel
    sh:property [
        sh:path skos:prefLabel ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype rdf:langString ;
        sh:name "preferred label" ;
        sh:message "Every concept must have exactly one skos:prefLabel (CQ-022)"
    ] ;

    # CQ-024: every concept must have an rdfs:label
    sh:property [
        sh:path rdfs:label ;
        sh:minCount 1 ;
        sh:name "label" ;
        sh:message "Every concept must have at least one rdfs:label (CQ-024)"
    ] ;

    # CQ-024: every concept must have a skos:definition
    sh:property [
        sh:path skos:definition ;
        sh:minCount 1 ;
        sh:name "definition" ;
        sh:message "Every concept must have a skos:definition (CQ-024)"
    ] ;

    # CQ-015: every concept must have at least one altLabel
    sh:property [
        sh:path skos:altLabel ;
        sh:minCount 1 ;
        sh:name "surface form" ;
        sh:message "Every concept must have at least one skos:altLabel surface form (CQ-015)"
    ] ;

    # CQ-023: every concept must belong to exactly one scheme
    sh:property [
        sh:path skos:inScheme ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class skos:ConceptScheme ;
        sh:name "scheme membership" ;
        sh:message "Every concept must belong to exactly one ConceptScheme (CQ-023)"
    ] ;

    # B-1: prefLabel language must be "en"
    sh:property [
        sh:path skos:prefLabel ;
        sh:languageIn ( "en" ) ;
        sh:name "prefLabel language" ;
        sh:message "prefLabel must use language tag 'en'"
    ] ;

    # B-2: altLabel must have a language tag
    sh:property [
        sh:path skos:altLabel ;
        sh:datatype rdf:langString ;
        sh:name "altLabel type" ;
        sh:message "Every altLabel must have a language tag (rdf:langString)"
    ] ;

    # C-1: no leading/trailing whitespace in prefLabel
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "prefLabel must not have leading or trailing whitespace: '{?label}'" ;
        sh:select """
            PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
            SELECT $this ?label WHERE {
                $this skos:prefLabel ?label .
                FILTER(STR(?label) != REPLACE(STR(?label), "^\\\\s+|\\\\s+$", ""))
            }
        """
    ] ;

    # C-2: no leading/trailing whitespace in altLabels
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "altLabel must not have leading or trailing whitespace: '{?label}'" ;
        sh:select """
            PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
            SELECT $this ?label WHERE {
                $this skos:altLabel ?label .
                FILTER(LANG(?label) = "en")
                FILTER(STR(?label) != REPLACE(STR(?label), "^\\\\s+|\\\\s+$", ""))
            }
        """
    ] .


# =============================================================================
# A. SCHEME-LEVEL METADATA — ConceptSchemeShape
# Validates ConceptScheme instances.
# =============================================================================

sevocab-shapes:ConceptSchemeShape a sh:NodeShape ;
    sh:targetClass skos:ConceptScheme ;

    sh:property [
        sh:path skos:prefLabel ;
        sh:minCount 1 ;
        sh:name "scheme label" ;
        sh:message "Every ConceptScheme must have a skos:prefLabel"
    ] ;

    sh:property [
        sh:path skos:definition ;
        sh:minCount 1 ;
        sh:name "scheme definition" ;
        sh:message "Every ConceptScheme must have a skos:definition"
    ] .


# =============================================================================
# A. PER-SCHEME CANONICAL VALUE CONSTRAINTS (sh:in enums)
# These are the source of truth for TypeScript Schema.Literals enums.
# Each shape uses a SPARQL-based target to scope to concepts in that scheme.
# =============================================================================

# --- StatisticType canonical values ---
# Maps to: Schema.Literals(["stock", "flow", "price", "share", "count"])
sevocab-shapes:StatisticTypeConceptShape a sh:NodeShape ;
    sh:target [
        a sh:SPARQLTarget ;
        sh:select """
            PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
            PREFIX sevocab: <https://skygest.dev/vocab/energy/>
            SELECT ?this WHERE {
                ?this skos:inScheme sevocab:StatisticTypeScheme .
            }
        """
    ] ;
    sh:property [
        sh:path skos:prefLabel ;
        sh:in ( "stock"@en "flow"@en "price"@en "share"@en "count"@en ) ;
        sh:name "StatisticType canonical value" ;
        sh:message "prefLabel must be one of the StatisticType canonical values: stock, flow, price, share, count"
    ] .

# --- Aggregation canonical values ---
# Maps to: Schema.Literals(["point", "end_of_period", "sum", "average", "max", "min", "settlement"])
sevocab-shapes:AggregationConceptShape a sh:NodeShape ;
    sh:target [
        a sh:SPARQLTarget ;
        sh:select """
            PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
            PREFIX sevocab: <https://skygest.dev/vocab/energy/>
            SELECT ?this WHERE {
                ?this skos:inScheme sevocab:AggregationScheme .
            }
        """
    ] ;
    sh:property [
        sh:path skos:prefLabel ;
        sh:in ( "point"@en "end_of_period"@en "sum"@en "average"@en
                "max"@en "min"@en "settlement"@en ) ;
        sh:name "Aggregation canonical value" ;
        sh:message "prefLabel must be one of the Aggregation canonical values: point, end_of_period, sum, average, max, min, settlement"
    ] .

