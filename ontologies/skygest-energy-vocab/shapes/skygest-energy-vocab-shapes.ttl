                "mass_co2e"@en "intensity"@en "dimensionless"@en "other"@en ) ;
        sh:name "UnitFamily canonical value" ;
        sh:message "prefLabel must be one of the UnitFamily canonical values: power, energy, currency, currency_per_energy, mass_co2e, intensity, dimensionless, other"
    ] .

# --- TechnologyOrFuel canonical values ---
# Maps to: Schema.String (open vocabulary — not a closed enum in TS)
sevocab-shapes:TechnologyOrFuelConceptShape a sh:NodeShape ;
    sh:target [
        a sh:SPARQLTarget ;
        sh:select """
            PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
            PREFIX sevocab: <https://skygest.dev/vocab/energy/>
            SELECT ?this WHERE {
                ?this skos:inScheme sevocab:TechnologyOrFuelScheme .
            }
        """
    ] ;
    sh:property [
        sh:path skos:prefLabel ;
        sh:in ( "battery"@en "biomass"@en "brown coal"@en
                "carbon capture"@en "coal"@en "combined heat and power"@en
                "diesel"@en "fossil fuel"@en "fuel cell"@en
                "gas CCGT"@en "geothermal"@en "heat pump"@en "hydro"@en
                "hydrogen"@en "marine"@en "methane"@en "natural gas"@en
                "nuclear"@en "offshore wind"@en "oil"@en "onshore wind"@en
                "pumped hydro"@en "renewable"@en "solar PV"@en
                "solar thermal"@en "synthetic fuel"@en "waste"@en "wind"@en ) ;
        sh:name "TechnologyOrFuel canonical value" ;
        sh:message "prefLabel must be one of the TechnologyOrFuel canonical values"
    ] .

