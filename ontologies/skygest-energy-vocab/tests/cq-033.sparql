# CQ-033: What surface forms exist for the measuredProperty concept 'capacity'?
# Expected: non_empty
# Use case: UC-009

PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX sevocab: <https://skygest.dev/vocab/energy/>

SELECT ?surfaceForm ?lang WHERE {
  sevocab:Capacity skos:altLabel ?surfaceForm .
  BIND(LANG(?surfaceForm) AS ?lang)
}
ORDER BY ?lang ?surfaceForm
