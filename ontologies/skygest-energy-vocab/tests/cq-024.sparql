# CQ-024: Does every concept have an rdfs:label and skos:definition?
# Expected: empty (zero violations)
# Use case: UC-003

PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?concept WHERE {
  ?concept skos:inScheme ?scheme .
  FILTER(
    !EXISTS { ?concept rdfs:label ?l } ||
    !EXISTS { ?concept skos:definition ?d }
  )
}
