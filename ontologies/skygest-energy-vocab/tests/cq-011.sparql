# CQ-011: What are all five ConceptSchemes in the vocabulary?
# Expected: non_empty (exactly 5 rows)
# Use case: UC-001

PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX sevocab: <https://skygest.dev/vocab/energy/>

SELECT ?scheme ?label WHERE {
  ?scheme a skos:ConceptScheme ;
          skos:prefLabel ?label .
}
ORDER BY ?label
