# CQ-032: What canonical domainObject does the surface form 'electricity' map to?
# Expected: non_empty
# Use case: UC-009

PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX sevocab: <https://skygest.dev/vocab/energy/>

SELECT ?concept ?scheme WHERE {
  ?concept skos:altLabel "electricity"@en ;
           skos:inScheme ?scheme .
  FILTER(?scheme = sevocab:DomainObjectScheme)
}
