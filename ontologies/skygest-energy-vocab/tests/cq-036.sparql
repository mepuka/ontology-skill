# CQ-036: What surface forms distinguish measuredProperty 'generation' from 'demand'?
# Expected: non_empty
# Use case: UC-009

PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX sevocab: <https://skygest.dev/vocab/energy/>

SELECT ?concept ?surfaceForm WHERE {
  VALUES ?concept { sevocab:Generation sevocab:Demand }
  ?concept skos:altLabel ?surfaceForm .
  FILTER(LANG(?surfaceForm) = "en")
  FILTER NOT EXISTS {
    VALUES ?other { sevocab:Generation sevocab:Demand }
    ?other skos:altLabel ?surfaceForm .
    FILTER(?other != ?concept)
  }
}
ORDER BY ?concept ?surfaceForm
