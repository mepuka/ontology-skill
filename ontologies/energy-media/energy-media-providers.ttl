@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix emedia: <http://example.org/ontology/energy-media#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<http://example.org/ontology/energy-media/providers> a owl:Ontology ;
    dcterms:created "2026-03-17" ;
    dcterms:creator "ontology-architect skill" ;
    dcterms:description "SKOS concept scheme for alt text provenance and EnergyDataProvider individuals for the Energy Media Ontology."@en ;
    dcterms:license <https://spdx.org/licenses/MIT> ;
    dcterms:modified "2026-03-17" ;
    dcterms:title "Energy Media Ontology — Providers & Alt Text Provenance"@en ;
    owl:versionIRI <http://example.org/ontology/energy-media/providers/0.1.0> ;
    owl:versionInfo "0.1.0" .

emedia:provider_aeso a emedia:EnergyDataProvider ;
    rdfs:label "AESO"@en ;
    skos:definition "Alberta Electric System Operator, managing the Alberta electricity market."@en .

emedia:provider_bchydro a emedia:EnergyDataProvider ;
    rdfs:label "BC Hydro"@en ;
    skos:definition "British Columbia's primary electric utility, providing generation and transmission data."@en .

emedia:provider_eia a emedia:EnergyDataProvider ;
    rdfs:label "EIA"@en ;
    skos:definition "The U.S. Energy Information Administration, providing comprehensive energy statistics and analysis."@en .

emedia:provider_entsoe a emedia:EnergyDataProvider ;
    rdfs:label "ENTSO-E"@en ;
    skos:definition "European Network of Transmission System Operators for Electricity, providing pan-European grid data."@en .

emedia:provider_gridstatus a emedia:EnergyDataProvider ;
    rdfs:label "GridStatus"@en ;
    skos:definition "An energy data aggregator providing real-time and historical grid data for North American ISOs/RTOs."@en .

emedia:provider_ieso a emedia:EnergyDataProvider ;
    rdfs:label "IESO"@en ;
    skos:definition "Independent Electricity System Operator, managing Ontario's electricity market."@en .

emedia:AltTextAbsent a skos:Concept ;
    rdfs:label "Absent"@en ;
    skos:definition "No alt text exists for this media attachment"@en ;
    skos:inScheme emedia:AltTextProvenanceScheme ;
    skos:topConceptOf emedia:AltTextProvenanceScheme .

emedia:AltTextOriginal a skos:Concept ;
    rdfs:label "Original"@en ;
    skos:definition "Alt text provided by the post author"@en ;
    skos:inScheme emedia:AltTextProvenanceScheme ;
    skos:topConceptOf emedia:AltTextProvenanceScheme .

emedia:AltTextSynthetic a skos:Concept ;
    rdfs:label "Synthetic"@en ;
    skos:definition "Alt text generated by a vision model (e.g., Gemini 2.5 Flash)"@en ;
    skos:inScheme emedia:AltTextProvenanceScheme ;
    skos:topConceptOf emedia:AltTextProvenanceScheme .

emedia:AltTextProvenanceScheme a skos:ConceptScheme ;
    rdfs:label "Alt Text Provenance Scheme"@en ;
    skos:definition "Classifies the origin of a media attachment's descriptive text."@en ;
    skos:hasTopConcept emedia:AltTextAbsent,
        emedia:AltTextOriginal,
        emedia:AltTextSynthetic .

[] a owl:AllDifferent ;
    owl:distinctMembers ( emedia:provider_gridstatus emedia:provider_eia emedia:provider_aeso emedia:provider_ieso emedia:provider_bchydro emedia:provider_entsoe ) .

[] a owl:AllDifferent ;
    owl:distinctMembers ( emedia:AltTextOriginal emedia:AltTextSynthetic emedia:AltTextAbsent ) .
