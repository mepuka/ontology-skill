# Custom ROBOT report query: check for missing skos:definition
# Replaces the default missing_definition check (which uses IAO:0000115).
# Returns ?entity ?property ?value as required by ROBOT report.

PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>

SELECT DISTINCT ?entity ?property ?value WHERE {
  VALUES ?property { skos:definition }

  # Find declared classes and properties (not individuals, not ontology headers)
  {
    ?entity a owl:Class .
    FILTER NOT EXISTS { ?entity a owl:Ontology }
  } UNION {
    ?entity a owl:ObjectProperty .
  } UNION {
    ?entity a owl:DatatypeProperty .
  }

  # Must not already have a skos:definition
  FILTER NOT EXISTS { ?entity skos:definition ?value }

  # Exclude deprecated entities
  FILTER NOT EXISTS { ?entity owl:deprecated true }

  # Exclude blank nodes (restrictions, anonymous classes)
  FILTER (!isBlank(?entity))

  # Only flag entities in the project namespace (exclude external vocabularies)
  FILTER (STRSTARTS(STR(?entity), "http://example.org/ontology/energy-news"))
}
ORDER BY ?entity
