# Constraint: every domain class must have a named rdfs:subClassOf parent
# Expected: zero results (ROBOT verify passes on zero rows)
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX enews: <http://example.org/ontology/energy-news#>

SELECT ?class WHERE {
  ?class a owl:Class .
  FILTER(STRSTARTS(STR(?class), STR(enews:)))
  FILTER NOT EXISTS {
    ?class rdfs:subClassOf ?parent .
    FILTER(isIRI(?parent))
  }
}
