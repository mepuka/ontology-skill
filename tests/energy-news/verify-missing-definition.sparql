# Constraint: every domain class must have skos:definition
# Expected: zero results (ROBOT verify passes on zero rows)
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX enews: <http://example.org/ontology/energy-news#>

SELECT ?class WHERE {
  ?class a owl:Class .
  FILTER(STRSTARTS(STR(?class), STR(enews:)))
  FILTER NOT EXISTS { ?class skos:definition ?def }
}
