# CQ-015: What type or sector does a given organization belong to?
# Expected: non_empty (at least one result row)

PREFIX enews: <http://example.org/ontology/energy-news#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?sector ?sectorLabel WHERE {
  enews:org_catl a enews:Organization ;
                 enews:hasSector ?sector .
  ?sector rdfs:label ?sectorLabel .
}
