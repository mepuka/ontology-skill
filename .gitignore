# Python
__pycache__/
*.py[cod]
*$py.class
*.so
build/
dist/
wheels/
*.egg-info/
*.egg

# Virtual environments
.venv/
venv/

# uv
uv.lock

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Testing / coverage
htmlcov/
.coverage
.coverage.*
.pytest_cache/
.mypy_cache/

# Local tools (ROBOT CLI, etc.)
.local/

# Ontology build artifacts
*.owx
*.ofn

# Triple store data
*.db
*.sqlite
ontologies/*/data/oxigraph/

# Secrets
.env
.env.*
!.env.example

# Large reference PDFs (copyrighted)
docs/*.pdf
ontologies/*/release/pao-docs.html
.rlm/

# Large full upstream ontology snapshots (rebuilt on-demand from pinned versions)
ontologies/*/imports/oeo-full.owl

# ROBOT-derived MIREOT subsets (rebuilt via `uv run python ontologies/*/scripts/run_gates.py`
# or scripts/build_v1_imports.py)
ontologies/*/imports/oeo-technology-subset.ttl
ontologies/*/imports/oeo-carrier-subset.ttl
ontologies/*/imports/oeo-technology-subset-fixed.ttl
ontologies/*/imports/oeo-carrier-subset-fixed.ttl
ontologies/*/imports/qudt-units-subset.ttl

# Cached upstream vocab sources (large; rebuilt via build scripts, manifest pins versions)
ontologies/*/imports/qudt-source/

# Machine-generated validation artefacts (rebuilt by run_gates.py; not source-of-truth)
ontologies/*/validation/merged-*.ttl
ontologies/*/validation/reasoned-*.ttl
ontologies/*/validation/report-*.tsv
!ontologies/*/validation/report-allowlist.tsv
ontologies/*/validation/merge-*.log
ontologies/*/validation/reason-*.log
ontologies/*/validation/profile-validate-project-only.txt
ontologies/*/validation/profile-validate-*.log

# Per-release validation evidence directories (architect + validator gate runs;
# rebuilt on demand; reports cite these but the report is the source of truth)
ontologies/*/validation/v1/
ontologies/*/validation/v1-bfo-remediation/
ontologies/*/validation/v2/
ontologies/*/validation/merged-top-level-with-oeo.ttl
